@model ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.WarehouseExportDto
@using ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs
@{
    ViewData["Title"] = "Yêu cầu xuất hóa đơn";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var isMultiItem = (Model.Details?.Count ?? 0) > 1;
}

<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Products">Sản phẩm</a></span>
            <span class="devider">/</span>
            <span><a asp-action="Exports">Phiếu xuất kho</a></span>
            <span class="devider">/</span>
            <span>Yêu cầu xuất hóa đơn</span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Yêu cầu xuất hóa đơn</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger">@err</div>
        }

        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            @if (isMultiItem)
            {
                <span>Bạn có thể tách hóa đơn bằng cách nhập số lượng cần tách cho từng sản phẩm, hoặc bấm <strong>Gửi yêu cầu</strong> để tạo hóa đơn cho toàn bộ phiếu xuất.</span>
            }
            else
            {
                <span>Bấm <strong>Gửi yêu cầu</strong> để yêu cầu xuất hóa đơn cho phiếu xuất kho này.</span>
            }
            <br />Phiếu xuất: <strong>@Model.Warehouse_export_code</strong>
        </div>

        <form asp-action="RequestInvoiceSplit" asp-route-exportId="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div style="border: 1px solid #eee; border-radius: 8px; overflow: hidden; background: #fff;">
                <div style="background: #f8f8f8; padding: 15px 20px; font-weight: 600;">
                    Chi tiết sản phẩm @(isMultiItem ? "- Nhập số lượng cần tách (tùy chọn)" : "")
                </div>
                <div style="padding: 20px;">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center" style="width: 100px;">Số lượng gốc</th>
                                @if (isMultiItem)
                                {
                                    <th class="text-center" style="width: 140px;">Số lượng tách</th>
                                }
                                <th class="text-end">Đơn giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Details ?? new List<WarehouseExportDetailDto>())
                            {
                                <tr>
                                    <td>@d.Product_name</td>
                                    <td class="text-center">@d.Quantity_shipped</td>
                                    @if (isMultiItem)
                                    {
                                        <td class="text-center">
                                            <input type="number" name="qty_@d.Product_id" value="0" min="0" max="@d.Quantity_shipped"
                                                   class="form-control form-control-sm text-center qty-input"
                                                   style="max-width: 80px; margin: 0 auto;" />
                                        </td>
                                    }
                                    <td class="text-end">@d.Unit_price.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="padding: 15px 20px; background: #fafafa; display: flex; justify-content: space-between; align-items: center;">
                    <a asp-action="Exports" class="btn btn-outline-secondary" style="background: #546e7a; color: #fff; border: none;">Quay lại</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-1"></i>Gửi yêu cầu xuất hóa đơn
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>
