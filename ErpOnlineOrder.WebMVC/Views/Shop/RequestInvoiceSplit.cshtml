@model ErpOnlineOrder.Application.DTOs.InvoiceDTOs.InvoiceDto
@using ErpOnlineOrder.Application.DTOs.InvoiceDTOs
@{
    ViewData["Title"] = "Yêu cầu tách hóa đơn";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var export = ViewBag.Export as ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.WarehouseExportDto;
}

<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Products">Sản phẩm</a></span>
            <span class="devider">/</span>
            <span><a asp-action="Exports">Phiếu xuất kho</a></span>
            <span class="devider">/</span>
            <span>Yêu cầu tách hóa đơn</span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Yêu cầu tách hóa đơn</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger">@err</div>
        }

        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Chọn số lượng cần tách cho từng sản phẩm. Phần còn lại sẽ giữ trong hóa đơn gốc.
            Phiếu xuất: <strong>@(export?.Warehouse_export_code)</strong> | Hóa đơn: <strong>@Model.Invoice_code</strong>
        </div>

        <form asp-action="RequestInvoiceSplit" asp-route-exportId="@(export?.Id)" method="post">
            @Html.AntiForgeryToken()
            <div style="border: 1px solid #eee; border-radius: 8px; overflow: hidden; background: #fff;">
                <div style="background: #f8f8f8; padding: 15px 20px; font-weight: 600;">
                    Chi tiết sản phẩm - Nhập số lượng cần tách
                </div>
                <div style="padding: 20px;">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center" style="width: 100px;">Số lượng gốc</th>
                                <th class="text-center" style="width: 140px;">Số lượng tách</th>
                                <th class="text-end">Đơn giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Details ?? new List<InvoiceDetailDto>())
                            {
                                <tr>
                                    <td>@d.Product_name</td>
                                    <td class="text-center">@d.Quantity</td>
                                    <td class="text-center">
                                        <input type="number" name="qty_@d.Id" value="0" min="0" max="@d.Quantity"
                                               class="form-control form-control-sm text-center qty-input"
                                               style="max-width: 80px; margin: 0 auto;" />
                                    </td>
                                    <td class="text-end">@d.Unit_price.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="padding: 15px 20px; background: #fafafa; display: flex; justify-content: space-between; align-items: center;">
                    <a asp-action="Exports" class="btn btn-outline-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-1"></i>Gửi yêu cầu tách hóa đơn
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>
