@{
    ViewData["Title"] = "Tài khoản";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<section class="sh-account-page">
    <div class="container">
        @if (Context.Session.GetInt32("UserId") != null)
        {
            <!-- Profile banner -->
            <div class="sh-profile-banner">
                <div class="sh-profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="sh-profile-info">
                    <h2 class="sh-profile-name">@Context.Session.GetString("FullName")</h2>
                    <span class="sh-profile-username">@Context.Session.GetString("Username")</span>
                </div>
            </div>

            <!-- Quick action cards -->
            <div class="sh-account-grid">
                <a asp-action="Orders" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#f0fdf4; color:#1a7f37;">
                        <i class="fas fa-box"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Đơn hàng</h3>
                        <p>Xem và theo dõi đơn hàng</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-action="UpdateOrganization" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#e3f2fd; color:#1976d2;">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Đơn vị</h3>
                        <p>Chỉnh sửa thông tin tổ chức</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-action="Cart" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#e8f5e9; color:#388e3c;">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Giỏ hàng</h3>
                        <p>Xem giỏ hàng của bạn</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-action="Invoices" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#fff8e1; color:#f9a825;">
                        <i class="fas fa-file-invoice"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Hóa đơn</h3>
                        <p>Xem hóa đơn đã mua</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-action="Exports" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#ede7f6; color:#5e35b1;">
                        <i class="fas fa-truck-loading"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Phiếu xuất kho</h3>
                        <p>Xem phiếu xuất kho của bạn</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-action="MyStaff" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#e0f2f1; color:#00796b;">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Cán bộ phụ trách</h3>
                        <p>Xem cán bộ quản lý của bạn</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-controller="Shop" asp-action="ChangePassword" class="sh-account-card">
                    <div class="sh-account-card-icon" style="background:#fff3e0; color:#e65100;">
                        <i class="fas fa-key"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Đổi mật khẩu</h3>
                        <p>Thay đổi mật khẩu tài khoản</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>

                <a asp-controller="Auth" asp-action="LogoutGet" class="sh-account-card sh-account-card--danger">
                    <div class="sh-account-card-icon" style="background:#ffebee; color:#e53935;">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>
                    <div class="sh-account-card-body">
                        <h3>Đăng xuất</h3>
                        <p>Thoát khỏi tài khoản</p>
                    </div>
                    <i class="fas fa-chevron-right sh-account-card-arrow"></i>
                </a>
            </div>
        }
        else
        {
            <!-- Not logged in -->
            <div class="sh-account-guest">
                <div class="sh-profile-avatar sh-profile-avatar--lg">
                    <i class="fas fa-user"></i>
                </div>
                <h2>Đăng nhập tài khoản</h2>
                <p>Đăng nhập để theo dõi đơn hàng và quản lý tài khoản.</p>
                <a asp-controller="Auth" asp-action="Login" class="sh-btn-primary">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </a>
            </div>
        }
    </div>
</section>
