@{
    ViewData["Title"] = "Thông tin";
    var slug = ViewBag.Slug as string ?? "gioi-thieu";
    var titles = new Dictionary<string, string>
    {
        ["gioi-thieu"] = "Giới thiệu",
        ["chinh-sach-giao-hang"] = "Chính sách giao hàng",
        ["chinh-sach-bao-hanh"] = "Chính sách bảo hành",
        ["chinh-sach-bao-mat"] = "Chính sách bảo mật",
        ["dieu-khoan-su-dung"] = "Điều khoản sử dụng",
        ["tuyen-dung"] = "Tuyển dụng",
        ["tin-tuc"] = "Tin tức"
    };
    var title = titles.GetValueOrDefault(slug, "Thông tin");
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="mb-4" style="color:#1a7f37;font-weight:600;">@title</h1>
                <div class="bg-light rounded-3 p-4">
                    <p class="text-muted mb-0">
                        Nội dung đang được cập nhật. Vui lòng quay lại sau hoặc liên hệ hotline <strong>0123 456 789</strong> để được hỗ trợ.
                    </p>
                </div>
                <div class="mt-4">
                    <a asp-controller="Shop" asp-action="Products" class="btn btn-outline-success">← Về sản phẩm</a>
                    <a asp-controller="Shop" asp-action="Products" class="btn btn-success ms-2">Xem sản phẩm</a>
                </div>
            </div>
        </div>
    </div>
</section>
