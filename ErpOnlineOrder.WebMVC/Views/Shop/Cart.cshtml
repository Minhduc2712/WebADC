@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<!-- Breadcrumb -->
<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Products">Sản phẩm</a></span>
            <span class="devider">/</span>
            <span><a href="#">Giỏ hàng</a></span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Giỏ hàng</h1>
        </div>
    </div>
</section>

<!-- Cart Section -->
<section class="product-cart product footer-padding">
    <div class="container">
        <!-- Empty Cart -->
        <div id="emptyCart" class="text-center py-5">
            <div style="max-width: 200px; margin: 0 auto 20px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="120" height="120" style="opacity: 0.3;">
                    <circle cx="32" cy="32" r="30" fill="#f0f0f0"/>
                    <path d="M20 20h24l-3 20H23L20 20z" stroke="#999" stroke-width="2" fill="none"/>
                    <circle cx="26" cy="48" r="3" fill="#999"/>
                    <circle cx="38" cy="48" r="3" fill="#999"/>
                </svg>
            </div>
            <h5>Giỏ hàng của bạn đang trống</h5>
            <p style="color: #888;">Hãy thêm sản phẩm vào giỏ hàng.</p>
            <a asp-action="Products" class="shop-btn mt-2">Chọn thêm sản phẩm</a>
        </div>

        <!-- Cart with Items -->
        <div id="cartWithItems" style="display: none;">
            <div class="cart-section">
                <table>
                    <tbody>
                        <tr class="table-row table-top-row">
                            <td class="table-wrapper wrapper-product">
                                <h5 class="table-heading">SẢN PHẨM</h5>
                            </td>
                            <td class="table-wrapper">
                                <div class="table-wrapper-center">
                                    <h5 class="table-heading">GIÁ</h5>
                                </div>
                            </td>
                            <td class="table-wrapper">
                                <div class="table-wrapper-center">
                                    <h5 class="table-heading">SỐ LƯỢNG</h5>
                                </div>
                            </td>
                            <td class="table-wrapper wrapper-total">
                                <div class="table-wrapper-center">
                                    <h5 class="table-heading">TỔNG</h5>
                                </div>
                            </td>
                            <td class="table-wrapper">
                                <div class="table-wrapper-center">
                                    <h5 class="table-heading">XÓA</h5>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                    <tbody id="cartTableBody">
                    </tbody>
                </table>
            </div>
            <div class="wishlist-btn cart-btn">
                <a href="javascript:void(0)" class="clean-btn" onclick="clearCart()">Xóa giỏ hàng</a>
                <a asp-action="Products" class="shop-btn update-btn">Chọn thêm sản phẩm</a>
                <a asp-action="Checkout" class="shop-btn">Đặt hàng</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    function getCart() {
        return JSON.parse(localStorage.getItem('shopCart') || '[]');
    }

    function saveCart(cart) {
        localStorage.setItem('shopCart', JSON.stringify(cart));
    }

    // SVG tĩnh cho nút xóa (không chứa dữ liệu người dùng)
    var DELETE_SVG = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.7 0.3C9.3 -0.1 8.7 -0.1 8.3 0.3L5 3.6L1.7 0.3C1.3 -0.1 0.7 -0.1 0.3 0.3C-0.1 0.7 -0.1 1.3 0.3 1.7L3.6 5L0.3 8.3C-0.1 8.7 -0.1 9.3 0.3 9.7C0.7 10.1 1.3 10.1 1.7 9.7L5 6.4L8.3 9.7C8.7 10.1 9.3 10.1 9.7 9.7C10.1 9.3 10.1 8.7 9.7 8.3L6.4 5L9.7 1.7C10.1 1.3 10.1 0.7 9.7 0.3Z" fill="#AAAAAA"></path></svg>';
    var FALLBACK_IMG = '/shop/images/homepage-one/product-img/product-img-1.webp';

    function safeImgSrc(src) {
        // Chỉ cho phép đường dẫn tương đối (bắt đầu bằng /) để tránh javascript: hoặc data: URI độc hại
        if (typeof src === 'string' && /^\/[^/]/.test(src)) return src;
        return FALLBACK_IMG;
    }

    function renderCart() {
        var cart = getCart();
        if (cart.length === 0) {
            document.getElementById('emptyCart').style.display = 'block';
            document.getElementById('cartWithItems').style.display = 'none';
            return;
        }

        document.getElementById('emptyCart').style.display = 'none';
        document.getElementById('cartWithItems').style.display = 'block';

        var tbody = document.getElementById('cartTableBody');
        tbody.innerHTML = ''; // xóa hàng cũ (không có dữ liệu người dùng)

        cart.forEach(function(item, index) {
            var itemTotal = item.price * item.quantity;

            var tr = document.createElement('tr');
            tr.className = 'table-row ticket-row';

            // Cột 1: Ảnh + tên sản phẩm
            var td1 = document.createElement('td');
            td1.className = 'table-wrapper wrapper-product';
            var wrapper = document.createElement('div');
            wrapper.className = 'wrapper';
            var wrapperImg = document.createElement('div');
            wrapperImg.className = 'wrapper-img';
            var img = document.createElement('img');
            img.src = safeImgSrc(item.image);  // URL đã được kiểm tra
            img.alt = 'img';
            wrapperImg.appendChild(img);
            var wrapperContent = document.createElement('div');
            wrapperContent.className = 'wrapper-content';
            var h5Name = document.createElement('h5');
            h5Name.className = 'heading';
            h5Name.textContent = item.name;  // textContent tự escape HTML
            wrapperContent.appendChild(h5Name);
            wrapper.appendChild(wrapperImg);
            wrapper.appendChild(wrapperContent);
            td1.appendChild(wrapper);

            // Cột 2: Giá
            var td2 = document.createElement('td');
            td2.className = 'table-wrapper';
            var center2 = document.createElement('div');
            center2.className = 'table-wrapper-center';
            var h5Price = document.createElement('h5');
            h5Price.className = 'heading';
            h5Price.textContent = item.priceText;  // textContent tự escape HTML
            center2.appendChild(h5Price);
            td2.appendChild(center2);

            // Cột 3: Số lượng
            var td3 = document.createElement('td');
            td3.className = 'table-wrapper';
            var center3 = document.createElement('div');
            center3.className = 'table-wrapper-center';
            var quantityDiv = document.createElement('div');
            quantityDiv.className = 'quantity';
            var minus = document.createElement('span');
            minus.className = 'minus';
            minus.textContent = '-';
            minus.addEventListener('click', (function(i, q) {
                return function() { updateQuantity(i, q - 1); };
            })(index, item.quantity));
            var input = document.createElement('input');
            input.type = 'number';
            input.min = '1';
            input.className = 'number';
            input.value = item.quantity;
            input.style.cssText = 'width:52px;text-align:center;border:1px solid #ddd;border-radius:4px;font-size:1.3rem;padding:2px 4px;';
            input.addEventListener('change', (function(i) {
                return function() { updateQuantity(i, parseInt(this.value) || 1); };
            })(index));
            input.addEventListener('click', function() { this.select(); });
            var plus = document.createElement('span');
            plus.className = 'plus';
            plus.textContent = '+';
            plus.addEventListener('click', (function(i, q) {
                return function() { updateQuantity(i, q + 1); };
            })(index, item.quantity));
            quantityDiv.appendChild(minus);
            quantityDiv.appendChild(input);
            quantityDiv.appendChild(plus);
            center3.appendChild(quantityDiv);
            td3.appendChild(center3);

            // Cột 4: Tổng tiền (số nguyên, an toàn)
            var td4 = document.createElement('td');
            td4.className = 'table-wrapper wrapper-total';
            var center4 = document.createElement('div');
            center4.className = 'table-wrapper-center';
            var h5Total = document.createElement('h5');
            h5Total.className = 'heading';
            h5Total.textContent = itemTotal.toLocaleString();
            center4.appendChild(h5Total);
            td4.appendChild(center4);

            // Cột 5: Nút xóa (SVG tĩnh, không có dữ liệu người dùng)
            var td5 = document.createElement('td');
            td5.className = 'table-wrapper';
            var center5 = document.createElement('div');
            center5.className = 'table-wrapper-center';
            var deleteSpan = document.createElement('span');
            deleteSpan.style.cursor = 'pointer';
            deleteSpan.innerHTML = DELETE_SVG;  // SVG tĩnh, không chứa dữ liệu người dùng
            deleteSpan.addEventListener('click', (function(i) {
                return function() { removeFromCart(i); };
            })(index));
            center5.appendChild(deleteSpan);
            td5.appendChild(center5);

            tr.appendChild(td1);
            tr.appendChild(td2);
            tr.appendChild(td3);
            tr.appendChild(td4);
            tr.appendChild(td5);
            tbody.appendChild(tr);
        });
    }

    function updateQuantity(index, qty) {
        if (qty < 1) return;
        var cart = getCart();
        cart[index].quantity = parseInt(qty) || 1;
        saveCart(cart);
        renderCart();
    }

    function removeFromCart(index) {
        var cart = getCart();
        cart.splice(index, 1);
        saveCart(cart);
        renderCart();
    }

    function clearCart() {
        localStorage.removeItem('shopCart');
        renderCart();
    }

    renderCart();
</script>
}
