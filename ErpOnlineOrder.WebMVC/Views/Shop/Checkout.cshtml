@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var orgShippingAddress = (ViewBag.OrganizationShippingAddress as string) ?? string.Empty;
    var hasOrgShippingAddress = (ViewBag.HasOrganizationShippingAddress as bool?) ?? false;
    var recipientName = (ViewBag.RecipientName as string) ?? string.Empty;
    var customerEmail = (ViewBag.CustomerEmail as string) ?? string.Empty;
    var customerPhone = (ViewBag.RecipientPhone as string) ?? (ViewBag.CustomerPhone as string) ?? string.Empty;
    var provinces = ViewBag.Provinces as List<ErpOnlineOrder.Application.DTOs.ProvinceDTOs.ProvinceDTO> ?? new List<ErpOnlineOrder.Application.DTOs.ProvinceDTOs.ProvinceDTO>();
    var organizationName = (ViewBag.OrganizationName as string) ?? string.Empty;
    var organizationTaxNumber = (ViewBag.OrganizationTaxNumber as string) ?? string.Empty;
    var nameParts = recipientName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var firstName = nameParts.Length > 0 ? nameParts[^1] : string.Empty;
    var lastName = nameParts.Length > 1 ? string.Join(" ", nameParts[..^1]) : string.Empty;
}

<!-- Breadcrumb -->
<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Products">Sản phẩm</a></span>
            <span class="devider">/</span>
            <span><a asp-action="Cart">Giỏ hàng</a></span>
            <span class="devider">/</span>
            <span><a href="#">Thanh toán</a></span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Thanh toán</h1>
        </div>
    </div>
</section>

<!-- Checkout Section -->
<section class="checkout product footer-padding">
    <div class="container">
        <div class="checkout-section">
            <div class="row gy-5">
                <!-- Billing Details -->
                <div class="col-lg-6">
                    <div class="checkout-wrapper">
                        @if (Context.Session.GetInt32("UserId") == null)
                        {
                            <a asp-controller="Auth" asp-action="Login" class="shop-btn">Đăng nhập tài khoản</a>
                        }
                        <div class="account-section billing-section">
                            <h5 class="wrapper-heading">Thông tin giao hàng</h5>

                            <!-- Thông tin người nhận -->
                            <div class="checkout-info-card mb-3">
                                <div class="checkout-info-card-header">
                                    <span>Người nhận</span>
                                </div>
                                <div class="checkout-info-card-body" style="padding: 12px 16px;">
                                    <div class="mb-3">
                                        <label class="d-block mb-1" style="font-size:0.82rem;color:#6b7280;">Họ và tên <span class="text-danger">*</span></label>
                                        <input type="text" id="recipientName" class="form-control checkout-input" value="@recipientName" placeholder="Nhập họ và tên người nhận">
                                    </div>
                                    <div class="mb-3">
                                        <label class="d-block mb-1" style="font-size:0.82rem;color:#6b7280;">Số điện thoại <span class="text-danger">*</span></label>
                                        <input type="tel" id="recipientPhone" class="form-control checkout-input" value="@customerPhone" placeholder="Nhập số điện thoại">
                                    </div>
                                    <div>
                                        <label class="d-block mb-1" style="font-size:0.82rem;color:#6b7280;">Email</label>
                                        <input type="email" id="recipientEmail" class="form-control checkout-input" value="@customerEmail" placeholder="Nhập email">
                                    </div>
                                </div>
                            </div>

                            <!-- Thông tin đơn vị -->
                            <div class="checkout-info-card mb-3">
                                <div class="checkout-info-card-header">
                                    <span>Đơn vị</span>
                                    <a asp-action="UpdateOrganization" asp-route-returnToCheckout="true" class="checkout-info-edit-link">Cập nhật</a>
                                </div>
                                <div class="checkout-info-card-body">
                                    <div class="checkout-info-row">
                                        <span class="checkout-info-label">Tên đơn vị</span>
                                        <span class="checkout-info-value">@(string.IsNullOrWhiteSpace(organizationName) ? "—" : organizationName)</span>
                                    </div>
                                    <div class="checkout-info-row">
                                        <span class="checkout-info-label">Mã số thuế</span>
                                        <span class="checkout-info-value">@(string.IsNullOrWhiteSpace(organizationTaxNumber) ? "—" : organizationTaxNumber)</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Địa chỉ nhận hàng (editable) -->
                            <div class="review-form">
                                <h6 class="wrapper-heading" style="font-size:0.85rem;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.4px;">Địa chỉ nhận hàng</h6>
                                <div class="review-form-name address-form">
                                    <label for="address" class="form-label" style="font-size:0.82rem;color:#6b7280;">Địa chỉ <span class="text-danger">*</span></label>
                                    <input type="text" id="address" class="form-control form-control-sm" value="@orgShippingAddress" placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố" style="font-size:0.88rem;">
                                </div>
                                @if (!hasOrgShippingAddress)
                                {
                                    <div id="addressWarning" class="alert alert-warning mt-2 mb-2" role="alert">
                                        Bạn chưa có địa chỉ mặc định. Vui lòng nhập địa chỉ giao hàng hoặc cập nhật tại
                                        <a asp-action="UpdateOrganization">Thông tin đơn vị</a>.
                                    </div>
                                }
                                else
                                {
                                    <div id="addressWarning" class="alert alert-info mt-2 mb-2" role="alert">
                                        Địa chỉ đã được lấy từ thông tin đơn vị. Bạn có thể chỉnh sửa nếu muốn giao đến nơi khác.
                                    </div>
                                }
                                <div class="review-form-name address-form mt-2">
                                    <label for="note" class="form-label" style="font-size:0.82rem;color:#6b7280;">Ghi chú đơn hàng</label>
                                    <textarea id="note" class="form-control form-control-sm" rows="3" placeholder="Ghi chú thêm cho đơn hàng (nếu có)..." style="font-size:0.88rem;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-6">
                    <div class="checkout-wrapper">
                        <div class="account-section billing-section">
                            <h5 class="wrapper-heading">Đơn hàng của bạn</h5>
                            <div class="order-summery">
                                <div class="subtotal product-total">
                                    <h5 class="wrapper-heading">SẢN PHẨM</h5>
                                    <h5 class="wrapper-heading">THÀNH TIỀN</h5>
                                </div>
                                <hr>
                                <div class="subtotal product-total">
                                    <ul class="product-list" id="checkoutItems">
                                    </ul>
                                </div>
                                <hr>
                                <div class="subtotal product-total">
                                    <h5 class="wrapper-heading">TẠM TÍNH</h5>
                                    <h5 class="wrapper-heading" id="checkoutSubtotal">0</h5>
                                </div>
                                <div class="subtotal product-total">
                                    <ul class="product-list">
                                        <li>
                                            <div class="product-info">
                                                <p class="paragraph">VẬN CHUYỂN</p>
                                                <h5 class="wrapper-heading">Miễn phí</h5>
                                            </div>
                                            <div class="price">
                                                <h5 class="wrapper-heading">0</h5>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                                <hr>
                                <div class="subtotal total">
                                    <h5 class="wrapper-heading">TỔNG CỘNG</h5>
                                    <h5 class="wrapper-heading price" id="checkoutTotal">0</h5>
                                </div>
                                <a href="javascript:void(0)" class="shop-btn" id="placeOrderBtn" onclick="placeOrder()">Đặt hàng ngay</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<style>
    .checkout-info-card {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }
    .checkout-info-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8f9fa;
        padding: 10px 16px;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
        font-size: 1rem;
        color: #374151;
    }
    .checkout-info-edit-link {
        font-size: 0.85rem;
        font-weight: 400;
        color: #6b7280;
        text-decoration: none;
    }
    .checkout-info-edit-link:hover {
        color: #111;
        text-decoration: underline;
    }
    .checkout-info-card-body {
        padding: 4px 0;
    }
    .checkout-info-row {
        display: flex;
        align-items: baseline;
        padding: 10px 16px;
        border-bottom: 1px solid #f3f4f6;
        gap: 12px;
    }
    .checkout-info-row:last-child {
        border-bottom: none;
    }
    .checkout-info-label {
        min-width: 120px;
        font-size: 0.88rem;
        color: #9ca3af;
        flex-shrink: 0;
    }
    .checkout-info-value {
        font-size: 1.05rem;
        font-weight: 500;
        color: #111827;
        word-break: break-word;
    }
    /* Input nhận được: ô gọn, chữ to, dễ đọc */
    .checkout-input {
        font-size: 1.05rem !important;
        padding: 6px 12px !important;
        height: auto !important;
        line-height: 1.5 !important;
        color: #111827 !important;
    }
    .checkout-input::placeholder {
        font-size: 0.92rem;
        color: #adb5bd;
    }
    .col-lg-6 .account-section.billing-section .order-summery .wrapper-heading {
        font-size: 0.88rem !important;
    }
    .col-lg-6 .account-section.billing-section .order-summery .subtotal.total .wrapper-heading {
        font-size: 1rem !important;
    }
    .col-lg-6 .account-section.billing-section .order-summery .paragraph {
        font-size: 0.82rem;
    }
</style>
<script>
    function renderCheckout() {
        var cart = getCart();
        if (cart.length === 0) {
            window.location.href = '@Url.Action("Cart")';
            return;
        }

        var itemsHtml = '';
        var total = 0;

        cart.forEach(function(item) {
            var itemTotal = item.price * item.quantity;
            total += itemTotal;
            itemsHtml += '<li>' +
                '<div class="product-info">' +
                '<h5 class="wrapper-heading">' + item.name + ' x' + item.quantity + '</h5>' +
                '</div>' +
                '<div class="price"><h5 class="wrapper-heading">' + itemTotal.toLocaleString() + '</h5></div>' +
                '</li>';
        });

        document.getElementById('checkoutItems').innerHTML = itemsHtml;
        document.getElementById('checkoutSubtotal').textContent = total.toLocaleString();
        document.getElementById('checkoutTotal').textContent = total.toLocaleString();
    }

    function placeOrder() {
        var cart = getCart();
        if (cart.length === 0) {
            showToast('Giỏ hàng trống!', 'error');
            return;
        }

        var recipientNameVal = (document.getElementById('recipientName')?.value || '').trim();
        if (!recipientNameVal) {
            showToast('Vui lòng nhập tên người nhận.', 'error');
            document.getElementById('recipientName')?.focus();
            return;
        }

        var recipientPhoneVal = (document.getElementById('recipientPhone')?.value || '').trim();
        if (!recipientPhoneVal) {
            showToast('Vui lòng nhập số điện thoại người nhận.', 'error');
            document.getElementById('recipientPhone')?.focus();
            return;
        }

        var shippingAddressInput = document.getElementById('address');
        var shippingAddress = shippingAddressInput ? shippingAddressInput.value.trim() : '';
        if (!shippingAddress) {
            showToast('Vui lòng nhập địa chỉ giao hàng hoặc cập nhật địa chỉ trong thông tin đơn vị.', 'error');
            var warning = document.getElementById('addressWarning');
            if (warning) {
                warning.classList.remove('alert-info');
                warning.classList.add('alert-warning');
                warning.style.display = 'block';
            }
            if (shippingAddressInput) {
                shippingAddressInput.focus();
            }
            return;
        }

        var btn = document.getElementById('placeOrderBtn');
        btn.textContent = 'Đang xử lý...';
        btn.style.pointerEvents = 'none';
        btn.style.opacity = '0.7';

        var orderData = {
            items: cart.map(function(item) {
                return {
                    productId: item.productId,
                    quantity: item.quantity,
                    price: item.price
                };
            }),
            note: document.getElementById('note') ? document.getElementById('note').value : '',
            shippingAddress: shippingAddress,
            recipientName: recipientNameVal,
            recipientPhone: recipientPhoneVal,
            recipientEmail: (document.getElementById('recipientEmail')?.value || '').trim()
        };

        fetch('@Url.Action("PlaceOrder", "Shop")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(orderData)
        })
        .then(function(response) { return response.json(); })
        .then(function(result) {
            if (result.success) {
                localStorage.removeItem('shopCart');
                updateCartBadge();
                showToast('Đặt hàng thành công! Mã đơn: ' + result.orderCode, 'success');
                setTimeout(function() {
                    window.location.href = '@Url.Action("Orders")';
                }, 2000);
            } else {
                showToast(result.message || 'Không thể đặt hàng. Vui lòng kiểm tra giỏ hàng và thông tin giao hàng.', 'error');
                btn.textContent = 'Đặt hàng ngay';
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            showToast('Không thể kết nối để đặt hàng. Vui lòng thử lại sau.', 'error');
            btn.textContent = 'Đặt hàng ngay';
            btn.style.pointerEvents = 'auto';
            btn.style.opacity = '1';
        });
    }

    renderCheckout();
</script>
}
