@using ErpOnlineOrder.Application.DTOs
@using ErpOnlineOrder.Application.DTOs.OrderDTOs
@model OrderDTO
@{
    ViewData["Title"] = "Theo dõi đơn hàng #" + Model.Order_code;
    Layout = "~/Views/Shared/_ShopLayout.cshtml";

    // Xác định trạng thái để render Timeline
    var status = Model.Order_status ?? "Pending";
    var isCancelled = status == "Cancelled" || status == "Rejected";
    var isPending = status == "Pending";
    var isApproved = status == "Approved" || status == "Confirmed";
    var isCompleted = status == "Completed";
    
    int step = 1;
    if (isApproved) step = 2;
    if (isCompleted) step = 4;
}

<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span><a asp-action="Orders">Đơn hàng của tôi</a></span>
            <span class="devider">/</span>
            <span><a href="#">#@Model.Order_code</a></span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Chi tiết & Theo dõi đơn hàng</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Trạng thái đơn hàng: <span class="text-primary">@status</span></h5>
                        @if (isCancelled)
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-times-circle me-2"></i> Đơn hàng này đã bị hủy.
                            </div>
                        }
                        else
                        {
                            <!-- Thanh Timeline Tracking -->
                            <div class="position-relative mx-4 mt-5 mb-4">
                                <div class="progress" style="height: 4px;">
                                    <div class="progress-bar bg-success" role="progressbar" 
                                         style="width: @(step == 1 ? "25%" : (step == 2 ? "50%" : (step == 3 ? "75%" : "100%")))" 
                                         aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="d-flex justify-content-between position-absolute w-100" style="top: -12px;">
                                    <div class="text-center" style="width: 20px;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-white @(step >= 1 ? "bg-success text-white" : "bg-light text-muted")" style="width: 28px; height: 28px;">
                                            <i class="fas fa-file-invoice" style="font-size: 12px;"></i>
                                        </div>
                                        <small class="mt-2 d-block fw-bold position-absolute" style="transform: translateX(-35%);">Chờ xử lý</small>
                                    </div>
                                    <div class="text-center" style="width: 20px;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-white @(step >= 2 ? "bg-success text-white" : "bg-light text-muted")" style="width: 28px; height: 28px;">
                                            <i class="fas fa-box-open" style="font-size: 12px;"></i>
                                        </div>
                                        <small class="mt-2 d-block fw-bold position-absolute" style="transform: translateX(-35%);">Đã xác nhận</small>
                                    </div>
                                    <div class="text-center" style="width: 20px;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-white @(step >= 3 ? "bg-success text-white" : "bg-light text-muted")" style="width: 28px; height: 28px;">
                                            <i class="fas fa-shipping-fast" style="font-size: 12px;"></i>
                                        </div>
                                        <small class="mt-2 d-block fw-bold position-absolute" style="transform: translateX(-35%);">Đang giao hàng</small>
                                    </div>
                                    <div class="text-center" style="width: 20px;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-white @(step >= 4 ? "bg-success text-white" : "bg-light text-muted")" style="width: 28px; height: 28px;">
                                            <i class="fas fa-check-circle" style="font-size: 12px;"></i>
                                        </div>
                                        <small class="mt-2 d-block fw-bold position-absolute" style="transform: translateX(-40%);">Đã hoàn thành</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Danh sách sản phẩm</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if(Model.Order_details != null)
                                    {
                                        foreach (var item in Model.Order_details)
                                        {
                                            <tr>
                                                <td>
                                                    <h6 class="mb-0">@item.Product_name</h6>
                                                    <small class="text-muted">Mã SP: @item.Product_id</small>
                                                </td>
                                                <td class="text-center">@item.Quantity</td>
                                                <td class="text-end">@item.Unit_price.ToString("N0") đ</td>
                                                <td class="text-end fw-bold">@item.Total_price.ToString("N0") đ</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold pt-3 pb-3">Tổng cộng:</td>
                                        <td class="text-end fw-bold text-success fs-5 pt-3 pb-3">@Model.Total_price.ToString("N0") đ</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Thông tin đơn hàng</h5>
                        <p class="mb-3"><i class="fas fa-calendar-alt text-muted me-2"></i> <strong>Ngày đặt:</strong><br/> @Model.Order_date.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-muted me-2"></i> <strong>Địa chỉ nhận hàng:</strong><br/> @(string.IsNullOrEmpty(Model.Shipping_address) ? "Không có" : Model.Shipping_address)</p>
                        <p class="mb-3"><i class="fas fa-sticky-note text-muted me-2"></i> <strong>Ghi chú:</strong><br/> @(string.IsNullOrEmpty(Model.note) ? "Không có" : Model.note)</p>
                        
                        <hr class="my-4">
                        
                        <div class="d-grid gap-2">
                            <a asp-action="PrintOrder" asp-route-id="@Model.Id" class="btn btn-outline-primary" target="_blank">
                                <i class="fas fa-print me-2"></i> In đơn hàng
                            </a>
                            @if (isPending)
                            {
                                <button class="btn btn-outline-danger" onclick="cancelOrder(@Model.Id)">
                                    <i class="fas fa-times me-2"></i> Hủy đơn hàng
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Re-use logic huỷ đơn hàng từ form Orders nếu có, ở đây gọi api đã định nghĩa
        function cancelOrder(id) {
            if(confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?')) {
                // Gửi request tới /Shop/CancelOrder
                fetch(`@Url.Action("CancelOrder", "Shop")?id=${id}`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value } })
                  .then(res => res.json())
                  .then(data => { alert(data.message); if(data.success) location.reload(); });
            }
        }
    </script>
}