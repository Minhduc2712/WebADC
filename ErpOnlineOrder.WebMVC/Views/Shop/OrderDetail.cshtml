@using ErpOnlineOrder.Application.DTOs
@using ErpOnlineOrder.Application.DTOs.OrderDTOs
@model OrderDTO
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Order_code;
    Layout = "~/Views/Shared/_ShopLayout.cshtml";

    var status = Model.Order_status ?? "Pending";
    var isCancelled = status == "Cancelled" || status == "Rejected";
    var isPending = status == "Pending";
    var isApproved = status == "Approved" || status == "Confirmed";
    var isCompleted = status == "Completed";
    var statusVi = status switch
    {
        "Pending" => "Chờ xử lý",
        "WaitingCustomer" => "Cần xác nhận",
        "Approved" => "Đã duyệt",
        "Confirmed" => "Đã xác nhận",
        "Exporting" => "Đang xuất kho",
        "Completed" => "Hoàn thành",
        "Cancelled" => "Đã hủy",
        "Rejected" => "Đã từ chối",
        "Split" => "Đã tách",
        _ => status
    };
    var statusColor = status switch
    {
        "Pending" => "#e07b00",
        "WaitingCustomer" => "#b45309",
        "Approved" or "Confirmed" => "#1565c0",
        "Exporting" => "#00838f",
        "Completed" => "#2e7d32",
        "Cancelled" or "Rejected" => "#b71c1c",
        "Split" => "#546e7a",
        _ => "#546e7a"
    };
    var statusIcon = status switch
    {
        "Pending" => "fa-clock",
        "WaitingCustomer" => "fa-bell",
        "Approved" or "Confirmed" => "fa-thumbs-up",
        "Exporting" => "fa-truck",
        "Completed" => "fa-check-double",
        "Cancelled" or "Rejected" => "fa-times-circle",
        "Split" => "fa-cut",
        _ => "fa-info-circle"
    };
    int step = 1;
    if (isApproved) step = 2;
    if (status == "Exporting") step = 3;
    if (isCompleted) step = 4;
    // Pre-compute timeline circle/label styles (no quotes in values = safe in style attributes)
    var s1c = step >= 1 ? "background:#1a7f37;border:3px solid #1a7f37;" : "background:#e9ecef;border:3px solid #dee2e6;";
    var s1i = step >= 1 ? "#fff" : "#adb5bd";
    var s1l = step >= 1 ? "font-weight:700;color:#2e7d32;" : "color:#adb5bd;";
    var s2c = step >= 2 ? "background:#1a7f37;border:3px solid #1a7f37;" : "background:#e9ecef;border:3px solid #dee2e6;";
    var s2i = step >= 2 ? "#fff" : "#adb5bd";
    var s2l = step >= 2 ? "font-weight:700;color:#2e7d32;" : "color:#adb5bd;";
    var s3c = step >= 3 ? "background:#1a7f37;border:3px solid #1a7f37;" : "background:#e9ecef;border:3px solid #dee2e6;";
    var s3i = step >= 3 ? "#fff" : "#adb5bd";
    var s3l = step >= 3 ? "font-weight:700;color:#2e7d32;" : "color:#adb5bd;";
    var s4c = step >= 4 ? "background:#1a7f37;border:3px solid #1a7f37;" : "background:#e9ecef;border:3px solid #dee2e6;";
    var s4i = step >= 4 ? "#fff" : "#adb5bd";
    var s4l = step >= 4 ? "font-weight:700;color:#2e7d32;" : "color:#adb5bd;";
    var progressPct = step switch { 1 => "0%", 2 => "33%", 3 => "66%", _ => "100%" };
}

<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span><a asp-action="Orders">Đơn hàng của tôi</a></span>
            <span class="devider">/</span>
            <span><a href="#">#@Model.Order_code</a></span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Chi tiết & Theo dõi đơn hàng</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 mb-4">
                <div class="card shadow-sm border-0" style="overflow: hidden; border-radius: 12px;">
                    <div style="background: @statusColor; padding: 18px 28px; display: flex; align-items: center; gap: 16px;">
                        <div style="width: 44px; height: 44px; background: rgba(255,255,255,0.18); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="fas @statusIcon" style="color: white; font-size: 1.15rem;"></i>
                        </div>
                        <div>
                            <div style="color: rgba(255,255,255,0.75); font-size: 11px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 2px;">Trạng thái đơn hàng</div>
                            <div style="color: white; font-size: 1.2rem; font-weight: 700;">@statusVi</div>
                        </div>
                        <div class="ms-auto">
                            <span style="background: rgba(255,255,255,0.18); color: white; padding: 5px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;">#@Model.Order_code</span>
                        </div>
                    </div>
                    @if (isCancelled)
                    {
                        <div class="p-4">
                            <div class="d-flex align-items-center gap-3 p-3 rounded" style="background: #fef2f2; border: 1.5px solid #fecaca;">
                                <i class="fas fa-times-circle" style="color: #b71c1c; font-size: 1.5rem; flex-shrink: 0;"></i>
                                <div>
                                    <div style="font-weight: 700; color: #7f1d1d; margin-bottom: 3px;">Đơn hàng đã bị hủy</div>
                                    <div style="color: #991b1b; font-size: 0.9rem;">Đơn hàng này không còn hiệu lực và sẽ không được xử lý thêm.</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="padding: 28px 40px 24px; position: relative;">
                            <div style="position: absolute; top: 48px; left: calc(12.5% + 20px); right: calc(12.5% + 20px); height: 3px; background: #e9ecef;">
                                <div style="height: 100%; background: #1a7f37; width: @progressPct;"></div>
                            </div>
                            <div class="d-flex justify-content-around">
                                <div class="d-flex flex-column align-items-center" style="position: relative; z-index: 1;">
                                    <div style="@s1c width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fas fa-file-invoice" style="color:@s1i;font-size:14px;"></i>
                                    </div>
                                    <div style="margin-top:10px;font-size:12px;text-align:center;@s1l">Đặt hàng</div>
                                </div>
                                <div class="d-flex flex-column align-items-center" style="position: relative; z-index: 1;">
                                    <div style="@s2c width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fas fa-check" style="color:@s2i;font-size:14px;"></i>
                                    </div>
                                    <div style="margin-top:10px;font-size:12px;text-align:center;@s2l">Xác nhận</div>
                                </div>
                                <div class="d-flex flex-column align-items-center" style="position: relative; z-index: 1;">
                                    <div style="@s3c width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fas fa-truck" style="color:@s3i;font-size:14px;"></i>
                                    </div>
                                    <div style="margin-top:10px;font-size:12px;text-align:center;@s3l">Giao hàng</div>
                                </div>
                                <div class="d-flex flex-column align-items-center" style="position: relative; z-index: 1;">
                                    <div style="@s4c width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fas fa-check-double" style="color:@s4i;font-size:14px;"></i>
                                    </div>
                                    <div style="margin-top:10px;font-size:12px;text-align:center;@s4l">Hoàn thành</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Danh sách sản phẩm</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" style="font-size:15px;">
                                <thead class="table-light" style="font-size:13px;">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if(Model.Order_details != null)
                                    {
                                        foreach (var item in Model.Order_details)
                                        {
                                            <tr>
                                                <td>
                                                    <span class="fw-semibold">@item.Product_name</span>
                                                    <br/><small class="text-muted">Mã SP: @item.Product_id</small>
                                                </td>
                                                <td class="text-center fw-semibold">@item.Quantity</td>
                                                <td class="text-end">@item.Unit_price.ToString("N0") đ</td>
                                                <td class="text-end fw-semibold text-danger">@item.Total_price.ToString("N0") đ</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold pt-3 pb-3" style="font-size:15px;">Tổng cộng:</td>
                                        <td class="text-end fw-bold text-success pt-3 pb-3" style="font-size:18px;">@Model.Total_price.ToString("N0") đ</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden;">
                    <div style="background: #1a7f37; padding: 14px 20px;">
                        <div style="color: white; font-weight: 700; font-size: 0.95rem;">
                            <i class="fas fa-info-circle me-2"></i>Thông tin đơn hàng
                        </div>
                    </div>
                    <div class="p-4">
                        <div class="mb-3" style="border-left: 3px solid #1a7f37; padding-left: 12px;">
                            <div style="font-size: 11px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;">Ngày đặt</div>
                            <div style="font-size: 14px; font-weight: 600; color: #222;">
                                <i class="fas fa-calendar-alt me-1 text-muted" style="font-size: 12px;"></i>@Model.Order_date.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="mb-3" style="border-left: 3px solid #1a7f37; padding-left: 12px;">
                            <div style="font-size: 11px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;">Địa chỉ nhận hàng</div>
                            <div style="font-size: 14px; font-weight: 500; color: #333;">
                                <i class="fas fa-map-marker-alt me-1 text-muted" style="font-size: 12px;"></i>@(string.IsNullOrEmpty(Model.Shipping_address) ? "Chưa có" : Model.Shipping_address)
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.note))
                        {
                            <div class="mb-3" style="border-left: 3px solid #ff9800; padding-left: 12px;">
                                <div style="font-size: 11px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;">Ghi chú</div>
                                <div style="font-size: 13px; color: #555; font-style: italic;">@Model.note</div>
                            </div>
                        }
                        <hr style="border-color: #f0f0f0; margin: 18px 0;" />
                        <div class="d-grid gap-2">
                            <a asp-action="Orders" style="padding: 10px 18px; border-radius: 8px; font-weight: 600; font-size: 14px; background: #546e7a; color: #fff; text-decoration: none; text-align: center; display: block;">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại đơn hàng
                            </a>
                            <a asp-action="PrintOrder" asp-route-id="@Model.Id" target="_blank" style="padding: 10px 18px; border-radius: 8px; font-weight: 600; font-size: 14px; background: #1565c0; color: #fff; text-decoration: none; text-align: center; display: block;">
                                <i class="fas fa-print me-2"></i>In đơn hàng
                            </a>
                            @if (isPending)
                            {
                                <button onclick="cancelOrder(@Model.Id)" style="padding: 10px 18px; border-radius: 8px; font-weight: 600; font-size: 14px; background: none; border: 2px solid #dc3545; color: #dc3545; cursor: pointer; width: 100%;">
                                    <i class="fas fa-times me-2"></i>Hủy đơn hàng
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Re-use logic huỷ đơn hàng từ form Orders nếu có, ở đây gọi api đã định nghĩa
        function cancelOrder(id) {
            if(confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?')) {
                // Gửi request tới /Shop/CancelOrder
                fetch(`@Url.Action("CancelOrder", "Shop")?id=${id}`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value } })
                  .then(res => res.json())
                  .then(data => { alert(data.message); if(data.success) location.reload(); });
            }
        }
    </script>
}