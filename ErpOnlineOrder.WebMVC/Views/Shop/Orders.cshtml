@using ErpOnlineOrder.Application.DTOs
@using ErpOnlineOrder.Application.DTOs.OrderDTOs
@model PagedResult<OrderDTO>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span><a href="#">Đơn hàng của tôi</a></span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Danh sách đơn hàng</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        <div class="row justify-content-center mt-4">
            <div class="col-lg-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <a asp-action="Account" class="btn btn-sm btn-outline-secondary" style="background: #546e7a; color: #fff; border: none;" title="Quay lại trang tài khoản">
                                    <i class="fas fa-arrow-left me-1"></i> Tài khoản
                                </a>
                                <h5 class="fw-bold mb-0">Quản lý đơn hàng</h5>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center"
                                        style="width:22px;height:22px;padding:0;border-radius:50%;font-size:13px;font-weight:600;"
                                        data-bs-toggle="collapse" data-bs-target="#statusGuide"
                                        title="Xem hướng dẫn ý nghĩa các trạng thái đơn hàng">?
                                </button>
                            </div>
                            <form method="get" class="d-flex gap-2">
                                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Chờ xử lý</option>
                                    <option value="WaitingCustomer" selected="@(ViewBag.Status == "WaitingCustomer")">⚠ Cần xác nhận</option>
                                    <option value="Approved" selected="@(ViewBag.Status == "Approved")">Đã duyệt</option>
                                    <option value="Exporting" selected="@(ViewBag.Status == "Exporting")">Đang xuất kho</option>
                                    <option value="Completed" selected="@(ViewBag.Status == "Completed")">Hoàn thành</option>
                                    <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã hủy</option>
                                    <option value="Split" selected="@(ViewBag.Status == "Split")">Đã tách</option>
                                </select>
                            </form>
                        </div>

                        <!-- Bảng hướng dẫn trạng thái (ẩn/hiện khi bấm ?) -->
                        <div class="collapse mb-3" id="statusGuide">
                            <div class="card card-body border-0 py-3" style="background:#f8f9fa;">
                                <p class="fw-bold mb-2" style="font-size:13px;"><i class="fas fa-question-circle text-primary me-1"></i> Ý nghĩa các trạng thái đơn hàng:</p>
                                <div class="row g-2" style="font-size:13px;">
                                    <div class="col-md-6">
                                        <span class="badge bg-warning text-dark me-1">Chờ xử lý</span>
                                        Đơn vừa đặt, đang chờ nhân viên xem xét.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge text-dark me-1" style="background:#ff9800;">⚠ Cần xác nhận</span>
                                        Nhân viên đã điều chỉnh đơn — <u>bạn cần đồng ý hoặc từ chối</u>.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge bg-primary me-1">Đã duyệt</span>
                                        Đơn đã được nhân viên duyệt, đang chuẩn bị hàng.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge bg-info text-dark me-1">Đang xuất kho</span>
                                        Hàng đang được chuẩn bị và sắp giao.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge bg-success me-1">Hoàn thành</span>
                                        Đơn hàng đã được giao thành công.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge bg-danger me-1">Đã hủy</span>
                                        Đơn hàng đã bị hủy, không còn hiệu lực.
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge bg-secondary me-1">Đã tách</span>
                                        Đơn gốc đã được tách ra thành nhiều đơn nhỏ hơn.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle" style="font-size:15px;">
                                <thead class="table-light">
                                    <tr style="font-size:13px;">
                                        <th>Mã đơn</th>
                                        <th>Ngày đặt</th>
                                        <th class="text-end">Tổng tiền</th>
                                        <th class="text-center">
                                            Trạng thái
                                            <i class="fas fa-question-circle text-muted ms-1" style="font-size:11px;cursor:pointer;"
                                               data-bs-toggle="collapse" data-bs-target="#statusGuide"
                                               title="Bấm để xem ý nghĩa các trạng thái"></i>
                                        </th>
                                        <th class="text-center" style="width:60px;">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Items != null && Model.Items.Any())
                                    {
                                        foreach (var item in Model.Items)
                                        {
                                            var isChild = item.IndentLevel > 0;
                                            var rowClass = isChild ? "bg-light" : ""; 
                                            var paddingLeft = isChild ? "ps-5" : "ps-3";

                                            <tr class="@rowClass">
                                                <td class="@paddingLeft">
                                                    @if (isChild)
                                                    {
                                                        <span class="text-muted me-1">|_</span>
                                                        <a asp-action="OrderDetail" asp-route-id="@item.Id" class="text-decoration-none text-secondary fw-semibold" title="Đơn con tách từ đơn gốc">
                                                            #@item.Order_code
                                                        </a>
                                                        <span class="badge bg-info ms-2" style="font-size:11px;">Đơn tách</span>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="OrderDetail" asp-route-id="@item.Id" class="text-decoration-none fw-semibold text-dark">
                                                            #@item.Order_code
                                                        </a>
                                                    }
                                                </td>
                                                <td>@item.Order_date.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="text-end fw-semibold text-danger">@item.Total_price.ToString("N0") đ</td>
                                                <td class="text-center">
                                                    @if (item.Order_status == "Pending")
                                                    {
                                                        <span class="badge bg-warning text-dark"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Đơn hàng đang chờ nhân viên xem xét và xử lý">
                                                            Chờ xử lý <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "WaitingCustomer")
                                                    {
                                                        <span class="badge text-dark"
                                                              style="background:#ff9800;font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Nhân viên đã điều chỉnh đơn hàng — bạn cần xác nhận Đồng ý hoặc Từ chối để tiếp tục">
                                                            <i class="fas fa-bell me-1"></i>Cần xác nhận <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "Exporting")
                                                    {
                                                        <span class="badge bg-info text-dark"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Hàng đang được chuẩn bị và sắp được giao đến bạn">
                                                            Đang xuất kho <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "Approved")
                                                    {
                                                        <span class="badge bg-primary"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Đơn hàng đã được duyệt, đang chờ xuất kho">
                                                            Đã duyệt <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "Completed")
                                                    {
                                                        <span class="badge bg-success"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Đơn hàng đã hoàn tất — hàng đã được giao thành công">
                                                            Hoàn thành <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "Cancelled")
                                                    {
                                                        <span class="badge bg-danger"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Đơn hàng đã bị hủy và không còn hiệu lực">
                                                            Đã hủy <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else if (item.Order_status == "Split")
                                                    {
                                                        <span class="badge bg-secondary"
                                                              style="font-size:12px;padding:5px 10px;"
                                                              data-bs-toggle="tooltip"
                                                              title="Đơn hàng gốc đã được tách thành các đơn nhỏ hơn — xem bên dưới">
                                                            Đã tách <i class="fas fa-question-circle ms-1 opacity-75"></i>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary" style="font-size:12px;padding:5px 10px;">@item.Order_status</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <div class="dropdown">
                                                        <button class="btn btn-sm" type="button"
                                                                data-bs-toggle="dropdown" aria-expanded="false"
                                                                style="background:none;border:none;font-size:20px;line-height:1;color:#555;padding:2px 8px;letter-spacing:1px;">
                                                            &#x22EF;
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:13px;min-width:170px;border-radius:10px;padding:6px 0;border:1px solid #e0e0e0;">
                                                            <li>
                                                                <a class="dropdown-item d-flex align-items-center gap-2 py-2 px-3"
                                                                   asp-action="OrderDetail" asp-route-id="@item.Id"
                                                                   style="color:#1565c0;font-weight:500;border-radius:6px;margin:1px 4px;">
                                                                    <span style="width:22px;height:22px;border-radius:50%;background:#e3f0ff;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                                        <i class="fas fa-eye" style="font-size:10px;"></i>
                                                                    </span>
                                                                    Xem chi tiết
                                                                </a>
                                                            </li>
                                                            @if (item.Order_status == "WaitingCustomer")
                                                            {
                                                                <li><hr class="dropdown-divider my-1 mx-3" /></li>
                                                                <li>
                                                                    <button class="dropdown-item d-flex align-items-center gap-2 py-2 px-3" type="button"
                                                                            onclick="approveOrder(@item.Id)"
                                                                            style="color:#1b5e20;font-weight:500;border-radius:6px;margin:1px 4px;background:none;border:none;width:calc(100% - 8px);">
                                                                        <span style="width:22px;height:22px;border-radius:50%;background:#e8f5e9;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                                            <i class="fas fa-check" style="font-size:10px;color:#2e7d32;"></i>
                                                                        </span>
                                                                        Đồng ý
                                                                    </button>
                                                                </li>
                                                                <li>
                                                                    <button class="dropdown-item d-flex align-items-center gap-2 py-2 px-3" type="button"
                                                                            onclick="rejectOrder(@item.Id)"
                                                                            style="color:#b71c1c;font-weight:500;border-radius:6px;margin:1px 4px;background:none;border:none;width:calc(100% - 8px);">
                                                                        <span style="width:22px;height:22px;border-radius:50%;background:#fef2f2;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                                            <i class="fas fa-times" style="font-size:10px;color:#c62828;"></i>
                                                                        </span>
                                                                        Từ chối
                                                                    </button>
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </td>
                                            </tr>
                                            @if (item.Order_status == "WaitingCustomer")
                                            {
                                                <tr style="background:#fffbee;">
                                                    <td colspan="5" class="py-2 px-4" style="border-top: 2px dashed #ff9800 !important;">
                                                        <div class="d-flex align-items-start gap-2" style="font-size:13px; color:#7a5c00;">
                                                            <i class="fas fa-exclamation-circle mt-1" style="color:#ff9800; flex-shrink:0;"></i>
                                                            <span>
                                                                <strong>Cần xác nhận của bạn:</strong>
                                                                Nhân viên đã điều chỉnh phân bổ đơn hàng này.
                                                                Chọn <strong class="text-success">Đồng ý</strong> để tiến hành giao hàng,
                                                                hoặc <strong class="text-danger">Từ chối</strong> để đơn về lại trạng thái Chờ xử lý.
                                                            </span>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-5 text-muted">
                                                <i class="fas fa-box-open fa-3x mb-3 text-light"></i><br/>
                                                Bạn chưa có đơn hàng nào. <a asp-action="Products" class="text-primary text-decoration-none">Tiếp tục mua sắm</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Pagination -->
                        @if (Model.TotalPages > 1)
                        {
                            <nav class="mt-4">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                        <a class="page-link" asp-action="Orders" asp-route-page="@(Model.Page - 1)" asp-route-status="@ViewBag.Status">Trước</a>
                                    </li>
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(Model.Page == i ? "active" : "")">
                                            <a class="page-link" asp-action="Orders" asp-route-page="@i" asp-route-status="@ViewBag.Status">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" asp-action="Orders" asp-route-page="@(Model.Page + 1)" asp-route-status="@ViewBag.Status">Sau</a>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    async function handlePost(url, payload = null) {
        try {
            const options = {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest' // Báo cho server biết đây là AJAX
                }
            };
            
            // Chỉ gửi Content-Type JSON khi thực sự có dữ liệu truyền đi
            if (payload) {
                options.headers['Content-Type'] = 'application/json';
                options.body = JSON.stringify(payload);
            }
            
            const res = await fetch(url, options);
            
            // Xử lý mượt mà nếu bị mất Session đăng nhập
            if (res.status === 401 || res.status === 403 || res.redirected) {
                window.location.href = '/Auth/Login';
                return { success: false, message: "Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại." };
            }
            
            const contentType = res.headers.get("content-type");
            if (contentType && contentType.indexOf("application/json") !== -1) {
                return await res.json();
            } else {
                const text = await res.text();
                console.error("Non-JSON response from server:", text);
                return { success: false, message: "Lỗi hệ thống: Máy chủ phản hồi sai định dạng. Vui lòng xem Console (F12) để biết chi tiết." };
            }
        } catch (error) {
            console.error("Fetch error:", error);
            return { success: false, message: "Không thể kết nối đến máy chủ." };
        }
    }

    // Khởi tạo Bootstrap Tooltip cho toàn trang
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el, { trigger: 'hover' });
        });
    });

    function approveOrder(id) {
        if (confirm(
            '✅ Xác nhận đồng ý đơn hàng?\n\n' +
            'Bạn đồng ý tiếp nhận đơn hàng đã được điều chỉnh.\n' +
            'Hệ thống sẽ tiếp tục xử lý và chuẩn bị giao hàng cho bạn.'
        )) {
            handlePost('@Url.Action("CustomerApproveOrder", "Shop")?id=' + id)
            .then(data => {
                if (data.success) location.reload();
                else alert(data.message || 'Có lỗi xảy ra.');
            });
        }
    }

    function rejectOrder(id) {
        if (confirm(
            '❌ Xác nhận từ chối đơn hàng?\n\n' +
            'Bạn không đồng ý với điều chỉnh này.\n' +
            'Hệ thống sẽ hoàn tác và đưa đơn hàng về trạng thái Chờ xử lý.'
        )) {
            handlePost('@Url.Action("CustomerRejectOrder", "Shop")?id=' + id)
            .then(data => {
                if (data.success) location.reload();
                else alert(data.message || 'Có lỗi xảy ra.');
            });
        }
    }
</script>
}