@model ErpOnlineOrder.Application.DTOs.CustomerDTOs.UpdateOrganizationByCustomerDto

@{
    ViewData["Title"] = "Chỉnh sửa thông tin đơn vị";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var organizations = ViewBag.Organizations as List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO> ?? new List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO>();
    var returnToCheckout = (ViewBag.ReturnToCheckout as bool?) ?? false;
    var currentOrg = ViewBag.CurrentOrg as ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO;
    var taxClass = (currentOrg != null && !string.IsNullOrEmpty(currentOrg.Tax_number)) ? "" : "d-none";
}

<!-- Breadcrumb -->
<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-controller="Shop" asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span>Thông tin đơn vị</span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Chỉnh sửa thông tin đơn vị</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        <div class="checkout-section">
            <div class="row justify-content-center">
                <div class="col-lg-12">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none; background: #e8f5e9;">
                            <i class="fas fa-check-circle me-2" style="color: #1a7f37; font-size: 1.2rem;"></i>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none; background: #fef2f2;">
                            <i class="fas fa-exclamation-circle me-2" style="color: #dc3545; font-size: 1.2rem;"></i>
                            <span>@errorMsg</span>
                        </div>
                    }

                    <!-- Đơn vị hiện tại -->
                    @if (currentOrg != null)
                    {
                        <div class="mb-4 p-4" style="background: #f0faf4; border: 1.5px solid #b7dfca; border-radius: 12px;">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width: 48px; height: 48px; background: #1a7f37; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="fas fa-building" style="color: white; font-size: 1.3rem;"></i>
                                </div>
                                <div>
                                    <div style="font-weight: 700; color: #0d5c2e; font-size: 1.1rem;">@currentOrg.Organization_name</div>
                                    <div style="color: #555; font-size: 0.95rem;">
                                        Mã: <strong>@currentOrg.Organization_code</strong>
                                        <span class="@taxClass"> &#124; MST: <strong>@currentOrg.Tax_number</strong></span>
                                    </div>
                                </div>
                                <div class="ms-auto">
                                    <span class="badge" style="background: #e8f5e9; color: #1a7f37; font-size: 0.85rem; padding: 6px 14px; border-radius: 20px; font-weight: 600;">
                                        <i class="fas fa-check-circle me-1"></i>Đơn vị hiện tại
                                    </span>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- ===== PHẦN 1: CHỌN ĐƠN VỊ ===== -->
                    <div class="account-section billing-section mb-4" style="padding: 0; overflow: hidden; border-radius: 12px;">
                        <!-- Header Phần 1 -->
                        <div style="background: #1a7f37; border-bottom: 2px solid #e8f5e9; padding: 24px 40px;">
                            <div class="d-flex align-items-center">
                                <div style="width: 48px; height: 48px; background: #e8f5e9; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 16px; flex-shrink: 0;">
                                    <i class="fas fa-exchange-alt" style="font-size: 1.25rem; color: #1a7f37;"></i>
                                </div>
                                <div>
                                    <h5 style="margin: 0; font-weight: 700; font-size: 1.2rem; color: #fff;">Phần 1 — Chọn đơn vị</h5>
                                    <span style="font-size: 0.95rem; color: #fff;">Chọn đơn vị khác hoặc cập nhật thông tin người nhận</span>
                                </div>
                            </div>
                        </div>

                        <!-- Form Phần 1 -->
                        <div style="padding: 36px 40px;">
                            <form asp-controller="Shop" asp-action="UpdateOrganization" asp-route-returnToCheckout="@returnToCheckout" method="post">
                                <input type="hidden" asp-for="Customer_id" />

                                <!-- Chọn đơn vị -->
                                <h6 style="font-weight: 700; color: #1a7f37; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e8f5e9; font-size: 1.1rem;">
                                    <i class="fas fa-building me-2"></i>Chọn đơn vị
                                </h6>
                                <div class="row g-4 mb-5">
                                    <div class="col-12">
                                        <label asp-for="Organization_information_id" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">
                                            Đơn vị <span class="text-danger">*</span>
                                        </label>
                                        <select asp-for="Organization_information_id" class="form-select form-select-lg" style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;">
                                            <option value="0">-- Chọn đơn vị --</option>
                                            @foreach (var org in organizations)
                                            {
                                                <option value="@org.Id" selected="@(Model.Organization_information_id == org.Id)">
                                                    @org.Organization_name (@org.Organization_code)
                                                </option>
                                            }
                                        </select>
                                        <span asp-validation-for="Organization_information_id" class="text-danger" style="font-size: 0.9rem;"></span>
                                    </div>
                                </div>

                                <!-- Thông tin nhận hàng -->
                                <h6 style="font-weight: 700; color: #1a7f37; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e8f5e9; font-size: 1.1rem;">
                                    <i class="fas fa-truck me-2"></i>Thông tin nhận hàng
                                </h6>
                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <label asp-for="Recipient_name" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Người nhận hàng</label>
                                        <input asp-for="Recipient_name" class="form-control form-control-lg" placeholder="Họ tên người nhận" style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Recipient_phone" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Số điện thoại</label>
                                        <input asp-for="Recipient_phone" class="form-control form-control-lg" type="text" placeholder="VD: 0901234567" style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Recipient_address" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Địa chỉ nhận hàng</label>
                                        <input asp-for="Recipient_address" class="form-control form-control-lg" placeholder="Địa chỉ giao hàng" style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                    </div>
                                </div>

                                <!-- Buttons Phần 1 -->
                                <div class="d-flex gap-3 pt-2">
                                    <button type="submit" class="shop-btn" style="padding: 14px 40px; border-radius: 12px; font-weight: 600; font-size: 1.05rem;">
                                        <i class="fas fa-save me-2"></i>Lưu thay đổi
                                    </button>
                                    @if (returnToCheckout)
                                    {
                                        <a asp-controller="Shop" asp-action="Checkout" class="shop-btn" style="padding: 14px 36px; border-radius: 12px; font-weight: 600; font-size: 1.05rem; background: #546e7a; color: #fff; border: none; text-decoration: none;">
                                            <i class="fas fa-arrow-left me-2"></i>Quay về đặt hàng
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Shop" asp-action="Account" class="shop-btn" style="padding: 14px 36px; border-radius: 12px; font-weight: 600; font-size: 1.05rem; background: #546e7a; color: #fff; border: none; text-decoration: none;">
                                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                                        </a>
                                    }
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- ===== PHẦN 2: SỬA THÔNG TIN ĐƠN VỊ HIỆN TẠI ===== -->
                    <div class="account-section billing-section" style="padding: 0; overflow: hidden; border-radius: 12px;">
                        <!-- Header Phần 2 -->
                        <div style="background: #1a7f37; border-bottom: 2px solid #e8eef8; padding: 24px 40px;">
                            <div class="d-flex align-items-center">
                                <div style="width: 48px; height: 48px; background: #e8eef8; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 16px; flex-shrink: 0;">
                                    <i class="fas fa-edit" style="font-size: 1.25rem; color: #3a7bd5;"></i>
                                </div>
                                <div>
                                    <h5 style="margin: 0; font-weight: 700; font-size: 1.2rem; color: #fff;">Phần 2 — Sửa thông tin đơn vị hiện tại</h5>
                                    <span style="font-size: 0.95rem; color: #fff;">Chỉ áp dụng với đơn vị do chính bạn tạo</span>
                                </div>
                            </div>
                        </div>

                        <!-- Nội dung Phần 2 -->
                        <div style="padding: 36px 40px;">
                            @if (currentOrg == null)
                            {
                                <div class="text-center py-4" style="color: #888;">
                                    <i class="fas fa-info-circle me-2" style="font-size: 1.3rem;"></i>
                                    <span style="font-size: 1.05rem;">Bạn chưa chọn đơn vị. Vui lòng chọn đơn vị ở Phần 1 trước.</span>
                                </div>
                            }
                            else if (!currentOrg.AllowUpdate)
                            {
                                <div class="d-flex align-items-start gap-3 p-4 mb-4" style="background: #fff8e1; border: 1.5px solid #ffe082; border-radius: 12px;">
                                    <i class="fas fa-lock" style="color: #f59e0b; font-size: 1.4rem; margin-top: 2px; flex-shrink: 0;"></i>
                                    <div>
                                        <div style="font-weight: 700; color: #92400e; font-size: 1rem; margin-bottom: 4px;">Không thể tự chỉnh sửa đơn vị này</div>
                                        <div style="color: #78350f; font-size: 0.95rem;">
                                            Đơn vị <strong>@currentOrg.Organization_name</strong> được quản lý bởi quản trị viên.
                                            Vui lòng gửi yêu cầu bên dưới để chúng tôi hỗ trợ cập nhật.
                                        </div>
                                    </div>
                                </div>

                                <hr style="border-color: #e8f5e9; margin-bottom: 24px;" />

                                <h6 style="font-weight: 700; color: #1a7f37; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e8f5e9; font-size: 1.1rem;">
                                    <i class="fas fa-paper-plane me-2"></i>Gửi yêu cầu chỉnh sửa thông tin đơn vị
                                </h6>

                                <form asp-controller="Shop" asp-action="RequestOrgUpdate" asp-route-returnToCheckout="@returnToCheckout" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Customer_id" value="0" />

                                    <div class="row g-4 mb-5">
                                        <div class="col-md-6">
                                            <label for="req_org_name" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">
                                                Tên đơn vị mong muốn <span class="text-danger">*</span>
                                            </label>
                                            <input id="req_org_name" name="Organization_name" class="form-control form-control-lg"
                                                   value="@currentOrg.Organization_name" placeholder="Tên đơn vị / tổ chức"
                                                   required style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="req_org_code" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">
                                                Mã đơn vị
                                            </label>
                                            <input id="req_org_code" name="Organization_code" class="form-control form-control-lg"
                                                   value="@currentOrg.Organization_code" placeholder="Mã đơn vị"
                                                   style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="req_org_tax" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Mã số thuế</label>
                                            <input id="req_org_tax" name="Tax_number" class="form-control form-control-lg"
                                                   value="@currentOrg.Tax_number" placeholder="VD: 0123456789"
                                                   style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="req_org_address" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Địa chỉ đơn vị</label>
                                            <input id="req_org_address" name="Address" class="form-control form-control-lg"
                                                   value="@currentOrg.Address" placeholder="Địa chỉ trụ sở"
                                                   style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-12">
                                            <label for="req_org_note" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Ghi chú / lý do</label>
                                            <textarea id="req_org_note" name="Note" class="form-control form-control-lg" rows="3"
                                                      placeholder="Mô tả lý do hoặc thông tin cần thay đổi..."
                                                      style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem;"></textarea>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-3 pt-2">
                                        <button type="submit" class="shop-btn" style="padding: 14px 40px; border-radius: 12px; font-weight: 600; font-size: 1.05rem; background: linear-gradient(135deg, #0d5c2e, #1a7f37);">
                                            <i class="fas fa-paper-plane me-2"></i>Gửi yêu cầu
                                        </button>
                                    </div>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Shop" asp-action="UpdateOrgInfo" asp-route-returnToCheckout="@returnToCheckout" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@currentOrg.Id" />

                                    <h6 style="font-weight: 700; color: #3a7bd5; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e8f0fe; font-size: 1.1rem;">
                                        <i class="fas fa-info-circle me-2"></i>Thông tin đơn vị — <em style="font-weight: 400; font-style: normal; font-size: 0.95rem;">@currentOrg.Organization_name</em>
                                    </h6>

                                    <div class="row g-4 mb-5">
                                        <div class="col-md-6">
                                            <label for="org_name" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">
                                                Tên đơn vị <span class="text-danger">*</span>
                                            </label>
                                            <input id="org_name" name="Organization_name" class="form-control form-control-lg"
                                                   value="@currentOrg.Organization_name" placeholder="Tên đơn vị / tổ chức"
                                                   required style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="org_code" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">
                                                Mã đơn vị <span class="text-danger">*</span>
                                            </label>
                                            <input id="org_code" name="Organization_code" class="form-control form-control-lg"
                                                   value="@currentOrg.Organization_code" placeholder="Mã đơn vị"
                                                   required style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="org_tax" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Mã số thuế</label>
                                            <input id="org_tax" name="Tax_number" class="form-control form-control-lg"
                                                   value="@currentOrg.Tax_number" placeholder="VD: 0123456789"
                                                   style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="org_address" class="form-label" style="font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 8px;">Địa chỉ đơn vị</label>
                                            <input id="org_address" name="Address" class="form-control form-control-lg"
                                                   value="@currentOrg.Address" placeholder="Địa chỉ trụ sở"
                                                   style="border-radius: 12px; padding: 14px 18px; border: 1.5px solid #e0e0e0; font-size: 1rem; height: auto;" />
                                        </div>
                                    </div>

                                    <!-- Buttons Phần 2 -->
                                    <div class="d-flex gap-3 pt-2">
                                        <button type="submit" class="shop-btn" style="padding: 14px 40px; border-radius: 12px; font-weight: 600; font-size: 1.05rem; background: linear-gradient(135deg, #2c5364, #3a7bd5);">
                                            <i class="fas fa-save me-2"></i>Lưu thông tin đơn vị
                                        </button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
<style>
    .billing-section .form-control:focus,
    .billing-section .form-select:focus {
        border-color: #1a7f37 !important;
        box-shadow: 0 0 0 3px rgba(26, 127, 55, 0.12);
    }
    .billing-section .shop-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        transition: all 0.2s;
    }
</style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
