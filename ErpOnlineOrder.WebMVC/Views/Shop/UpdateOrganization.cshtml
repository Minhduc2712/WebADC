@model ErpOnlineOrder.Application.DTOs.CustomerDTOs.UpdateOrganizationByCustomerDto

@{
    ViewData["Title"] = "Chỉnh sửa thông tin đơn vị";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var organizations = ViewBag.Organizations as List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO> ?? new List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO>();
    var returnToCheckout = (ViewBag.ReturnToCheckout as bool?) ?? false;
}

<!-- Breadcrumb -->
<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-controller="Shop" asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span>Thông tin đơn vị</span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Chỉnh sửa thông tin đơn vị</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        <div class="checkout-section">
            <div class="row justify-content-center">
                <div class="col-lg-12">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none; background: #e8f5e9;">
                            <i class="fas fa-check-circle me-2" style="color: #1a7f37; font-size: 1.2rem;"></i>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none; background: #fef2f2;">
                            <i class="fas fa-exclamation-circle me-2" style="color: #dc3545; font-size: 1.2rem;"></i>
                            <span>@errorMsg</span>
                        </div>
                    }

                    <div class="account-section billing-section" style="padding: 0; overflow: hidden; border-radius: 12px;">
                        <!-- Header -->
                        <div style="background: linear-gradient(135deg, #0d5c2e 0%, #1a7f37 100%); padding: 36px 48px; color: white;">
                            <div class="d-flex align-items-center">
                                <div style="width: 64px; height: 64px; background: rgba(255,255,255,0.15); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-right: 22px;">
                                    <i class="fas fa-building" style="font-size: 1.8rem;"></i>
                                </div>
                                <div>
                                    <h5 style="margin: 0; font-weight: 700; font-size: 1.6rem;">Thông tin đơn vị</h5>
                                    <span style="opacity: 0.85; font-size: 1.1rem;">Cập nhật thông tin tổ chức và địa chỉ nhận hàng</span>
                                </div>
                            </div>
                        </div>

                        <!-- Form -->
                        <div style="padding: 44px 48px;">
                            <form asp-controller="Shop" asp-action="UpdateOrganization" asp-route-returnToCheckout="@returnToCheckout" method="post">
                                <input type="hidden" asp-for="Customer_id" />


                                <!-- Thông tin đơn vị -->
                                <h6 style="font-weight: 700; color: #1a7f37; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 2.5px solid #e8f5e9; font-size: 1.25rem;">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin đơn vị
                                </h6>

                                <div class="row g-4 mb-5">
                                    <div class="col-12">
                                        <label asp-for="Organization_information_id" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 8px;">Đơn vị <span class="text-danger">*</span></label>
                                        <select asp-for="Organization_information_id" class="form-select form-select-lg" style="border-radius: 12px; padding: 16px 20px; border: 1.5px solid #e0e0e0; font-size: 1.1rem; height: auto;">
                                            <option value="0">-- Chọn đơn vị --</option>
                                            @foreach (var org in organizations)
                                            {
                                                <option value="@org.Id" selected="@(Model.Organization_information_id == org.Id)">
                                                    @org.Organization_name (@org.Organization_code)
                                                </option>
                                            }
                                        </select>
                                        <span asp-validation-for="Organization_information_id" class="text-danger" style="font-size: 0.9rem;"></span>
                                    </div>
                                </div>

                                <!-- Thông tin nhận hàng -->
                                <h6 style="font-weight: 700; color: #1a7f37; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 2.5px solid #e8f5e9; font-size: 1.25rem;">
                                    <i class="fas fa-truck me-2"></i>Thông tin nhận hàng
                                </h6>

                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <label asp-for="Recipient_name" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 8px;">Người nhận hàng</label>
                                        <input asp-for="Recipient_name" class="form-control form-control-lg" placeholder="Họ tên người nhận" style="border-radius: 12px; padding: 16px 20px; border: 1.5px solid #e0e0e0; font-size: 1.1rem; height: auto;" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Recipient_phone" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 8px;">Số điện thoại</label>
                                        <input asp-for="Recipient_phone" class="form-control form-control-lg" type="text" placeholder="VD: 0901234567" style="border-radius: 12px; padding: 16px 20px; border: 1.5px solid #e0e0e0; font-size: 1.1rem; height: auto;" />
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="Recipient_address" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 8px;">Địa chỉ nhận hàng</label>
                                        <input asp-for="Recipient_address" class="form-control form-control-lg" placeholder="Địa chỉ giao hàng" style="border-radius: 12px; padding: 16px 20px; border: 1.5px solid #e0e0e0; font-size: 1.1rem; height: auto;" />
                                    </div>
                                </div>

                                <!-- Buttons -->
                                <div class="d-flex gap-3 pt-3">
                                    <button type="submit" class="shop-btn" style="padding: 16px 48px; border-radius: 12px; font-weight: 600; font-size: 1.15rem;">
                                        <i class="fas fa-save me-2"></i>Cập nhật
                                    </button>
                                    @if (returnToCheckout)
                                    {
                                        <a asp-controller="Shop" asp-action="Checkout" class="shop-btn" style="padding: 16px 40px; border-radius: 12px; font-weight: 600; font-size: 1.15rem; background: #fff; color: #333; border: 1.5px solid #ddd; text-decoration: none;">
                                            <i class="fas fa-arrow-left me-2"></i>Quay về đặt hàng
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Shop" asp-action="Account" class="shop-btn" style="padding: 16px 40px; border-radius: 12px; font-weight: 600; font-size: 1.15rem; background: #fff; color: #333; border: 1.5px solid #ddd; text-decoration: none;">
                                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                                        </a>
                                    }
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
<style>
    .billing-section .form-control:focus {
        border-color: #1a7f37 !important;
        box-shadow: 0 0 0 3px rgba(26, 127, 55, 0.12);
    }
    .billing-section .shop-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        transition: all 0.2s;
    }
</style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
