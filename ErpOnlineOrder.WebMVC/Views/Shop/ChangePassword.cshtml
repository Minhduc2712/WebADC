@model ErpOnlineOrder.Application.DTOs.AuthDTOs.ChangePasswordDto
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<!-- Breadcrumb -->
<section class="blog about-blog">
    <div class="container">
        <div class="blog-bradcrum">
            <span><a asp-controller="Shop" asp-action="Account">Tài khoản</a></span>
            <span class="devider">/</span>
            <span>Đổi mật khẩu</span>
        </div>
        <div class="blog-heading about-heading">
            <h1 class="heading">Đổi mật khẩu</h1>
        </div>
    </div>
</section>

<section class="product footer-padding">
    <div class="container">
        @await Html.PartialAsync("_AccountNavbar")
        <div class="checkout-section">
            <div class="row justify-content-center">
                <div class="col-lg-9">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none; background: #e8f5e9;">
                            <i class="fas fa-check-circle me-2" style="color: #1a7f37; font-size: 1.2rem;"></i>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }

                    <div class="account-section billing-section" style="padding: 0; overflow: hidden; border-radius: 12px;">
                        <!-- Header -->
                        <div style="background: linear-gradient(135deg, #b8860b 0%, #d4a017 100%); padding: 36px 48px; color: white;">
                            <div class="d-flex align-items-center">
                                <div style="width: 64px; height: 64px; background: rgba(255,255,255,0.15); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-right: 22px;">
                                    <i class="fas fa-key" style="font-size: 1.8rem;"></i>
                                </div>
                                <div>
                                    <h5 style="margin: 0; font-weight: 700; font-size: 1.6rem;">Đổi mật khẩu</h5>
                                    <span style="opacity: 0.85; font-size: 1.1rem;">Thay đổi mật khẩu để bảo mật tài khoản</span>
                                </div>
                            </div>
                        </div>

                        <!-- Form -->
                        <div style="padding: 44px 48px;">
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                            {
                                <div class="alert alert-danger d-flex align-items-center mb-4" role="alert" style="border-radius: 10px; border: none;">
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                                </div>
                            }

                            <form asp-controller="Shop" asp-action="ChangePassword" method="post" id="changePasswordForm">
                                @Html.AntiForgeryToken()

                                <div class="mb-5">
                                    <label asp-for="OldPassword" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 10px;">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text" style="border-radius: 12px 0 0 12px; border: 1.5px solid #e0e0e0; border-right: none; background: #fafafa; padding: 16px 18px;">
                                            <i class="fas fa-lock" style="color: #888; font-size: 1.1rem;"></i>
                                        </span>
                                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại" autocomplete="current-password"
                                               style="border-radius: 0 12px 12px 0; padding: 16px 20px; border: 1.5px solid #e0e0e0; border-left: none; font-size: 1.1rem;" />
                                    </div>
                                    <span asp-validation-for="OldPassword" class="text-danger" style="font-size: 0.9rem;"></span>
                                </div>

                                <div class="mb-5">
                                    <label asp-for="NewPassword" class="form-label" style="font-weight: 600; color: #333; font-size: 1.1rem; margin-bottom: 10px;">Mật khẩu mới <span class="text-danger">*</span></label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text" style="border-radius: 12px 0 0 12px; border: 1.5px solid #e0e0e0; border-right: none; background: #fafafa; padding: 16px 18px;">
                                            <i class="fas fa-key" style="color: #888; font-size: 1.1rem;"></i>
                                        </span>
                                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" autocomplete="new-password"
                                               style="border-radius: 0 12px 12px 0; padding: 16px 20px; border: 1.5px solid #e0e0e0; border-left: none; font-size: 1.1rem;" />
                                    </div>
                                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size: 0.9rem;"></span>
                                </div>

                                <!-- Buttons -->
                                <div class="d-flex gap-3 pt-3">
                                    <button type="submit" class="shop-btn" id="btnSubmit" style="padding: 16px 48px; border-radius: 12px; font-weight: 600; font-size: 1.15rem;">
                                        <i class="fas fa-save me-2"></i>Đổi mật khẩu
                                    </button>
                                    <a asp-controller="Shop" asp-action="Account" class="shop-btn" style="padding: 16px 40px; border-radius: 12px; font-weight: 600; font-size: 1.15rem; background: #fff; color: #333; border: 1.5px solid #ddd; text-decoration: none;">
                                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
<style>
    .billing-section .form-control:focus {
        border-color: #d4a017 !important;
        box-shadow: 0 0 0 3px rgba(212, 160, 23, 0.12);
    }
    .billing-section .input-group:focus-within .input-group-text {
        border-color: #d4a017 !important;
    }
    .billing-section .shop-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        transition: all 0.2s;
    }
</style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('changePasswordForm').addEventListener('submit', function () {
            var btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
        });
    </script>
}
