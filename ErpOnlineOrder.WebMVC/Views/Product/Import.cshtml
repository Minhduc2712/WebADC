@using ErpOnlineOrder.Application.DTOs.ProductDTOs
@{
    ViewData["Title"] = "Nhập sản phẩm từ Excel";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var result = ViewBag.Result as ImportProductResultDto;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Nhập sản phẩm từ Excel</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Sản phẩm</a></li>
                <li class="breadcrumb-item active">Nhập Excel</li>
            </ol>
        </nav>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
</div>

<!-- Upload form -->
<div class="table-card mb-4">
    <div class="card-header">
        <i class="fas fa-file-upload me-2"></i>Tải lên file Excel
    </div>
    <div class="card-body p-4">
        <div class="mb-3">
            <a href="@Url.Action("DownloadImportTemplate")" class="btn btn-outline-success">
                <i class="fas fa-download me-1"></i>Tải file mẫu (.xlsx)
            </a>
            <small class="text-muted ms-2">Tải file mẫu để biết định dạng chuẩn trước khi nhập dữ liệu.</small>
        </div>
        <hr />
        <form method="post" enctype="multipart/form-data" asp-action="Import">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Chọn file Excel <span class="text-danger">*</span></label>
                    <input type="file" name="file" class="form-control" accept=".xlsx,.xls" required />
                    <div class="form-text">Chỉ hỗ trợ định dạng .xlsx, .xls</div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-file-import me-1"></i>Nhập dữ liệu
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Import result -->
@if (result != null)
{
    <div class="table-card mb-4">
        <div class="card-header">
            <i class="fas fa-chart-bar me-2"></i>Kết quả nhập dữ liệu
        </div>
        <div class="card-body p-4">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="border rounded p-3 text-center">
                        <div class="fs-4 fw-bold text-secondary">@result.TotalRows</div>
                        <div class="text-muted small">Tổng số dòng</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 text-center">
                        <div class="fs-4 fw-bold text-success">@result.Succeeded</div>
                        <div class="text-muted small">Nhập thành công</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 text-center">
                        <div class="fs-4 fw-bold text-warning">@result.Skipped</div>
                        <div class="text-muted small">Bỏ qua</div>
                    </div>
                </div>
            </div>

            @if (result.Succeeded > 0)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-2"></i>
                    Đã nhập thành công <strong>@result.Succeeded</strong> sản phẩm.
                </div>
            }

            @if (result.Errors != null && result.Errors.Count > 0)
            {
                <h6 class="fw-semibold mt-3 mb-2 text-danger">
                    <i class="fas fa-exclamation-triangle me-1"></i>Danh sách lỗi (@result.Errors.Count dòng)
                </h6>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-danger">
                            <tr>
                                <th style="width: 80px;">Dòng</th>
                                <th style="width: 150px;">Mã sản phẩm</th>
                                <th>Lý do</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var err in result.Errors)
                            {
                                <tr>
                                    <td>@err.Row</td>
                                    <td>@(string.IsNullOrEmpty(err.ProductCode) ? "-" : err.ProductCode)</td>
                                    <td>@err.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
