@model PagedResult<ErpOnlineOrder.Application.DTOs.InvoiceDTOs.InvoiceDto>
@using ErpOnlineOrder.Domain.Constants
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var items = Model?.Items ?? new List<ErpOnlineOrder.Application.DTOs.InvoiceDTOs.InvoiceDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Quản lý hóa đơn</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item active">Hóa đơn</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="@Url.Action("ExportExcel", new { status = ViewBag.Status })" class="btn btn-success me-2">
            <i class="fas fa-file-excel me-1"></i>Xuất Excel
        </a>
        <a href="@Url.Action("Merge")" class="btn btn-primary">
            <i class="fas fa-compress-arrows-alt me-1"></i>Gộp hóa đơn
        </a>
    </div>
</div>

<!-- Bộ lọc -->
<div class="table-card mb-4">
    <div class="card-header">
        <i class="fas fa-filter me-2"></i>Bộ lọc
    </div>
    <div class="card-body p-4">
        <form asp-action="Index" method="get" id="filterForm">
            <input type="hidden" name="page" value="1" />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả --</option>
                        <option value="Draft" selected="@(ViewBag.Status == "Draft")">Nháp</option>
                        <option value="Confirmed" selected="@(ViewBag.Status == "Confirmed")">Đã xác nhận</option>
                        <option value="Completed" selected="@(ViewBag.Status == "Completed")">Hoàn thành</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Số dòng/trang</label>
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                        <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-1"></i>Lọc
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo me-1"></i>Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Thống kê nhanh - Compact -->
<div class="row mb-2 g-2">
    @{
        var draft = items.Count(i => i.Status == "Draft");
        var pending = items.Count(i => i.Status == "Pending");
        var confirmed = items.Count(i => i.Status == "Confirmed");
        var completed = items.Count(i => i.Status == "Completed");
        var totalAmount = items.Sum(i => i.Grand_total);
    }
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Tổng hóa đơn</div>
                    <div class="stat-value">@(Model?.TotalCount ?? 0)</div>
                </div>
                <div class="stat-icon-sm blue"><i class="fas fa-file-invoice"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Chờ xử lý</div>
                    <div class="stat-value">@pending</div>
                </div>
                <div class="stat-icon-sm yellow"><i class="fas fa-clock"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Hoàn thành</div>
                    <div class="stat-value">@completed</div>
                </div>
                <div class="stat-icon-sm green"><i class="fas fa-check-double"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Tổng doanh thu (VNĐ)</div>
                    <div class="stat-value" style="font-size: 0.95rem;">@totalAmount.ToString("N0")</div>
                </div>
                <div class="stat-icon-sm orange"><i class="fas fa-coins"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách hóa đơn -->
<div class="table-card">
    <div class="card-header">
        <i class="fas fa-file-invoice me-2"></i>Danh sách hóa đơn (@(Model?.TotalCount ?? 0) hóa đơn)
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã hóa đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày lập</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-end">Thuế</th>
                        <th class="text-end">Thành tiền</th>
                        <th>Trạng thái</th>
                        <th style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                Không có hóa đơn nào
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var invoice in items.OrderByDescending(i => i.Invoice_date))
                        {
                            var statusClass = ErpOnlineOrder.Domain.Constants.InvoiceStatuses.ToCssClass(invoice.Status);
                            var statusText = ErpOnlineOrder.Domain.Constants.InvoiceStatuses.ToDisplayText(invoice.Status);
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@invoice.Invoice_code</span>
                                    @if (invoice.Parent_invoice_id.HasValue)
                                    {
                                        <br /><small class="text-muted">Từ: @invoice.Parent_invoice_code</small>
                                    }
                                </td>
                                <td>@invoice.Customer_name</td>
                                <td>@invoice.Invoice_date.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">@invoice.Total_amount.ToString("N0")</td>
                                <td class="text-end">@invoice.Tax_amount.ToString("N0")</td>
                                <td class="text-end fw-bold text-success">@invoice.Grand_total.ToString("N0")</td>
                                <td>
                                    @{
                                        var allowed = InvoiceStatuses.AllowedTransitions.TryGetValue(invoice.Status, out var t) ? t : Array.Empty<string>();
                                    }
                                    <span class="badge @statusClass">@statusText</span>
                                    @if (allowed.Length > 0)
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="mt-1" style="min-width:140px" onsubmit="return confirm('Xác nhận chuyển trạng thái?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@invoice.Id" />
                                            <div class="input-group input-group-sm">
                                                <select name="status" class="form-select form-select-sm">
                                                    @foreach (var ns in allowed)
                                                    {
                                                        <option value="@ns">@InvoiceStatuses.ToDisplayText(ns)</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-sync-alt"></i></button>
                                            </div>
                                        </form>
                                    }
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                                                data-bs-toggle="dropdown" data-bs-strategy="fixed" data-bs-offset="0,4" aria-expanded="false">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" asp-action="Details" asp-route-id="@invoice.Id">
                                                    <i class="fas fa-eye me-2 text-primary"></i>Xem chi tiết
                                                </a>
                                            </li>
                                            @if (invoice.Status != "Completed" && invoice.Status != "Cancelled" && invoice.Status != "Merged" && (invoice.Details?.Count > 1 || invoice.Details?.Any(d => d.Quantity > 1) == true))
                                            {
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <a class="dropdown-item" asp-action="Split" asp-route-id="@invoice.Id">
                                                        <i class="fas fa-expand-arrows-alt me-2 text-info"></i>Tách hóa đơn
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model != null && Model.TotalPages > 1)
        {
            ViewBag.PaginationItemLabel = "hóa đơn";
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>
