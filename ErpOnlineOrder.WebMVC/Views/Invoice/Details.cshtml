@model ErpOnlineOrder.Application.DTOs.InvoiceDTOs.InvoiceDto
@using ErpOnlineOrder.Domain.Constants
@{
    ViewData["Title"] = "Chi tiết hóa đơn";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var statusClass = InvoiceStatuses.ToCssClass(Model.Status);
    var statusText = InvoiceStatuses.ToDisplayText(Model.Status);
    var canUpdate = (bool)(ViewBag.CanUpdate ?? false);
    var allowedTransitions = InvoiceStatuses.AllowedTransitions.TryGetValue(Model.Status, out var transitions)
        ? transitions : Array.Empty<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Chi tiết hóa đơn</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Hóa đơn</a></li>
                <li class="breadcrumb-item active">@Model.Invoice_code</li>
            </ol>
        </nav>
    </div>
    <div>
        @if (Model.Status != InvoiceStatuses.Completed && Model.Status != InvoiceStatuses.Cancelled && (Model.Details?.Count > 1 || Model.Details?.Any(d => d.Quantity > 1) == true))
        {
            <a href="@Url.Action("Split", new { id = Model.Id })" class="btn btn-info me-2">
                <i class="fas fa-expand-arrows-alt me-1"></i>Tách hóa đơn
            </a>
        }
        @if (Model.Status == InvoiceStatuses.Split)
        {
            <form asp-action="UndoSplit" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn hoàn tác tách hóa đơn?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="parentInvoiceId" value="@Model.Id" />
                <button type="submit" class="btn btn-warning me-2" title="Hoàn tác tách hóa đơn">
                    <i class="fas fa-undo me-1"></i>Hoàn tác tách
                </button>
            </form>
        }
        @if (Model.Invoice_code.StartsWith("INV-M-"))
        {
            <form asp-action="UndoMerge" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn hoàn tác gộp hóa đơn?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="mergedInvoiceId" value="@Model.Id" />
                <button type="submit" class="btn btn-warning me-2" title="Hoàn tác gộp hóa đơn">
                    <i class="fas fa-undo me-1"></i>Hoàn tác gộp
                </button>
            </form>
        }
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Thông tin hóa đơn
            </div>
            <div class="card-body">
                <div class="info-row">
                    <span class="info-label">Mã hóa đơn</span>
                    <span class="info-value fw-semibold">@Model.Invoice_code</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Trạng thái</span>
                    <span class="info-value">
                        <span class="badge @statusClass">@statusText</span>
                        @if (canUpdate && allowedTransitions.Length > 0)
                        {
                            <form asp-action="UpdateStatus" method="post" class="mt-2" onsubmit="return confirm('Bạn có chắc muốn chuyển trạng thái?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <div class="input-group input-group-sm">
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (var nextStatus in allowedTransitions)
                                        {
                                            <option value="@nextStatus">@InvoiceStatuses.ToDisplayText(nextStatus)</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                            </form>
                        }
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Ngày lập</span>
                    <span class="info-value">@Model.Invoice_date.ToString("dd/MM/yyyy")</span>
                </div>
                @if (Model.Parent_invoice_id.HasValue)
                {
                    <div class="info-row">
                        <span class="info-label">Hóa đơn gốc</span>
                        <span class="info-value">
                            <a href="@Url.Action("Details", new { id = Model.Parent_invoice_id })">
                                @Model.Parent_invoice_code
                            </a>
                        </span>
                    </div>
                }
            </div>
        </div>
        
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-user me-2"></i>Khách hàng
            </div>
            <div class="card-body">
                <div class="info-row">
                    <span class="info-label">Khách hàng</span>
                    <span class="info-value fw-semibold">@Model.Customer_name</span>
                </div>
            </div>
        </div>
        
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-calculator me-2"></i>Tổng kết
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tổng tiền hàng:</span>
                    <span>@Model.Total_amount.ToString("N0") VNĐ</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Thuế:</span>
                    <span>@Model.Tax_amount.ToString("N0") VNĐ</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">Thành tiền:</span>
                    <span class="text-success fw-bold fs-5">@Model.Grand_total.ToString("N0") VNĐ</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-list me-2"></i>Chi tiết hóa đơn (@Model.Details.Count sản phẩm)
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thuế</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var index = 1;
                            }
                            @foreach (var detail in Model.Details)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@detail.Product_name</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end">@detail.Unit_price.ToString("N0")</td>
                                    <td class="text-end">@detail.Tax_rate%</td>
                                    <td class="text-end fw-semibold">@detail.Total_price.ToString("N0")</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="5" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end text-success fw-bold">@Model.Grand_total.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
