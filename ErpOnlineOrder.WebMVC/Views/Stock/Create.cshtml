@model ErpOnlineOrder.Application.DTOs.StockDTOs.CreateStockDto
@{
    ViewData["Title"] = "Thêm tồn kho";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0">Thêm tồn kho</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Stock")">Tồn kho</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Warehouse_id" class="form-label">Kho</label>
                        <select asp-for="Warehouse_id" asp-items="ViewBag.Warehouses" class="form-select">
                            <option value="">-- Chọn kho --</option>
                        </select>
                        <span asp-validation-for="Warehouse_id" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Product_id" class="form-label">Sản phẩm</label>
                        <select asp-for="Product_id" asp-items="ViewBag.Products" class="form-select">
                            <option value="">-- Chọn sản phẩm --</option>
                        </select>
                        <span asp-validation-for="Product_id" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Quantity" class="form-label">Số lượng tồn ban đầu</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Lưu tồn kho
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
