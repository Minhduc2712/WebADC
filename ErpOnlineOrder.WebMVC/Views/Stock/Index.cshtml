@model IEnumerable<ErpOnlineOrder.Application.DTOs.StockDTOs.StockDto>
@{
    ViewData["Title"] = "Quản lý tồn kho";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0">Quản lý tồn kho</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Tồn kho</li>
                </ol>
            </nav>
        </div>
        @if (Context.Session.HasPermission("STOCK_UPDATE"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Thêm tồn kho
            </a>
        }
    </div>

    <div class="table-card mb-4">
        <div class="card-header">
            <i class="fas fa-filter me-2"></i>Tìm kiếm & Lọc
        </div>
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Lọc theo kho</label>
                    @Html.DropDownList("warehouseId", ViewBag.Warehouses as SelectList, "-- Tất cả kho --", new { @class = "form-select" })
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tìm sản phẩm/kho</label>
                    <input type="text" class="form-control" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Nhập từ khóa..." />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter me-2"></i>Lọc
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo me-2"></i>Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-card">
        <div class="card-header">
            <i class="fas fa-boxes me-2"></i>Danh sách tồn kho (@Model.Count() dòng)
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Kho</th>
                            <th>Sản phẩm</th>
                            <th style="width:140px;">Số lượng tồn</th>
                            <th style="width:170px;">Cập nhật gần nhất</th>
                            <th style="width:120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                    <p class="text-muted mb-0">Không có dữ liệu tồn kho</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            var index = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@item.Warehouse_name</td>
                                    <td>@item.Product_name</td>
                                    <td>
                                        <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-danger")">@item.Quantity</span>
                                    </td>
                                    <td>@item.Updated_at.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        @if (item.AllowUpdate)
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                                                        data-bs-toggle="dropdown" data-bs-strategy="fixed" data-bs-offset="0,4" aria-expanded="false">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">
                                                            <i class="fas fa-edit me-2 text-primary"></i>Điều chỉnh tồn kho
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Không có quyền cập nhật">
                                                <i class="fas fa-lock"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
