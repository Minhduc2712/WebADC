@model ErpOnlineOrder.Application.DTOs.SettingsDTOs.CreateSettingDto
@{
    ViewData["Title"] = "Thêm cài đặt mới";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1 class="h4 mb-1 fw-bold text-dark">
            <i class="fas fa-plus-circle text-indigo me-2"></i>Thêm cài đặt mới
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Setting" asp-action="Index">Cài đặt</a></li>
                <li class="breadcrumb-item active">Thêm mới</li>
            </ol>
        </nav>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="CreateSetting" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="SettingKey" class="form-label">Mã cài đặt <span class="text-danger">*</span></label>
                        <input asp-for="SettingKey" class="form-control text-uppercase" placeholder="VD: APP_NAME" />
                        <span asp-validation-for="SettingKey" class="text-danger small"></span>
                        <small class="text-muted">Chữ in hoa, không dấu. VD: SMTP_HOST, APP_NAME</small>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SettingValue" class="form-label">Giá trị</label>
                        <input asp-for="SettingValue" class="form-control" placeholder="Giá trị" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <input asp-for="Description" class="form-control" placeholder="Mô tả ngắn" />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Lưu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
