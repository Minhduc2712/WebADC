@model List<ErpOnlineOrder.Application.DTOs.PackageDTOs.PackageDto>
@{
    ViewData["Title"] = "Quản lý gói sản phẩm";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-cubes me-2 text-primary"></i>Quản lý gói sản phẩm</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Gói sản phẩm</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Thêm gói mới
        </a>
    </div>

    <div class="table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list me-2"></i>Danh sách gói sản phẩm (@Model.Count gói)</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-inbox fa-3x mb-3 d-block opacity-50"></i>
                    <p class="mb-0">Chưa có gói sản phẩm nào</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Mã gói</th>
                                <th>Tên gói</th>
                                <th>Khu vực</th>
                                <th>Sản phẩm</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th style="width: 130px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Count; i++)
                            {
                                var pkg = Model[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td><span class="badge bg-secondary">@pkg.Package_code</span></td>
                                    <td>
                                        <strong>@pkg.Package_name</strong>
                                        @if (!string.IsNullOrEmpty(pkg.Description))
                                        {
                                            <div class="small text-muted">@pkg.Description</div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(pkg.Region_name))
                                        {
                                            <span class="badge bg-info me-1">@pkg.Region_name</span>
                                        }
                                        @if (!string.IsNullOrEmpty(pkg.Province_name))
                                        {
                                            <span class="badge bg-light text-dark me-1">@pkg.Province_name</span>
                                        }
                                        @if (!string.IsNullOrEmpty(pkg.Ward_name))
                                        {
                                            <span class="badge bg-light text-dark">@pkg.Ward_name</span>
                                        }
                                        @if (string.IsNullOrEmpty(pkg.Region_name) && string.IsNullOrEmpty(pkg.Province_name) && string.IsNullOrEmpty(pkg.Ward_name))
                                        {
                                            <span class="text-muted small">Toàn quốc</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@pkg.Products.Count SP</span>
                                    </td>
                                    <td>
                                        @if (pkg.Is_active)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng hoạt động</span>
                                        }
                                    </td>
                                    <td>@pkg.Created_at.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@pkg.Id"
                                               class="btn btn-outline-info" title="Chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@pkg.Id"
                                               class="btn btn-outline-primary" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger"
                                                    onclick="confirmDelete(@pkg.Id, '@pkg.Package_name')" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-warning me-2"></i>Xác nhận xóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa gói "<strong id="deletePackageName"></strong>"?</p>
                <p class="text-muted small">Lưu ý: Các khách hàng đang sử dụng gói này sẽ bị ảnh hưởng.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        document.getElementById('deletePackageName').textContent = name;
        document.getElementById('deleteForm').action = '@Url.Action("Delete")/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
}
