@model ErpOnlineOrder.Application.DTOs.PackageDTOs.UpdatePackageDto
@{
    ViewData["Title"] = "Sửa gói sản phẩm";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var packageId = (int)(ViewBag.PackageId ?? 0);
    var packageCode = ViewBag.PackageCode as string ?? "";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-edit me-2 text-primary"></i>Sửa gói sản phẩm</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Gói sản phẩm</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Details", new { id = packageId })">@packageCode</a></li>
                    <li class="breadcrumb-item active">Sửa</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Details" asp-route-id="@packageId" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    <div class="table-card">
        <div class="card-header">
            <i class="fas fa-cube me-2"></i>Thông tin gói — <span class="badge bg-secondary">@packageCode</span>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" asp-route-id="@packageId" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Package_name" class="form-label">Tên gói <span class="text-danger">*</span></label>
                        <input asp-for="Package_name" class="form-control" />
                        <span asp-validation-for="Package_name" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Organization_information_id" class="form-label">Tổ chức</label>
                        <select asp-for="Organization_information_id" asp-items="ViewBag.Organizations" class="form-select">
                            <option value="">-- Tất cả tổ chức --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Region_id" class="form-label">Vùng miền</label>
                        <select asp-for="Region_id" asp-items="ViewBag.Regions" class="form-select" id="regionSelect" onchange="loadProvinces(this.value)">
                            <option value="">-- Tất cả vùng --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Province_id" class="form-label">Tỉnh/Thành</label>
                        <select asp-for="Province_id" asp-items="ViewBag.Provinces" class="form-select" id="provinceSelect" onchange="loadWards(this.value)">
                            <option value="">-- Tất cả tỉnh --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Ward_id" class="form-label">Phường/Xã</label>
                        <select asp-for="Ward_id" asp-items="ViewBag.Wards" class="form-select" id="wardSelect">
                            <option value="">-- Tất cả phường/xã --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Trạng thái</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="Is_active" class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch" />
                            <label class="form-check-label" for="isActiveSwitch">Hoạt động</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Lưu thay đổi
                    </button>
                    <a asp-action="Details" asp-route-id="@packageId" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function loadProvinces(regionId) {
        const provinceSelect = document.getElementById('provinceSelect');
        const wardSelect = document.getElementById('wardSelect');
        provinceSelect.innerHTML = '<option value="">-- Tất cả tỉnh --</option>';
        wardSelect.innerHTML = '<option value="">-- Tất cả phường/xã --</option>';
        if (!regionId) return;
        fetch(`/api/province/by-region/${regionId}`, { headers: { 'Accept': 'application/json' } })
            .then(r => r.json()).then(data => {
                const items = data.data ?? data;
                items.forEach(p => provinceSelect.add(new Option(p.province_name ?? p.Province_name, p.id ?? p.Id)));
            });
    }
    function loadWards(provinceId) {
        const wardSelect = document.getElementById('wardSelect');
        wardSelect.innerHTML = '<option value="">-- Tất cả phường/xã --</option>';
        if (!provinceId) return;
        fetch(`/api/ward/by-province/${provinceId}`, { headers: { 'Accept': 'application/json' } })
            .then(r => r.json()).then(data => {
                const items = data.data ?? data;
                items.forEach(w => wardSelect.add(new Option(w.ward_name ?? w.Ward_name, w.id ?? w.Id)));
            });
    }
</script>
}
