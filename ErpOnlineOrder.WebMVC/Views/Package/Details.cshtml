@model ErpOnlineOrder.Application.DTOs.PackageDTOs.PackageDto
@using ErpOnlineOrder.Application.DTOs.PackageDTOs
@{
    ViewData["Title"] = Model.Package_name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var availableProducts = ViewBag.AvailableProducts as List<ErpOnlineOrder.Application.DTOs.ProductDTO>
                            ?? new List<ErpOnlineOrder.Application.DTOs.ProductDTO>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-cube me-2 text-primary"></i>Chi tiết gói sản phẩm</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Gói sản phẩm</a></li>
                    <li class="breadcrumb-item active">@Model.Package_name</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="fas fa-edit me-1"></i>Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Danh sách
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Package Info Card -->
    <div class="table-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-info-circle me-2"></i>Thông tin chung</span>
            @if (Model.Is_active)
            {
                <span class="badge bg-success">Hoạt động</span>
            }
            else
            {
                <span class="badge bg-secondary">Không hoạt động</span>
            }
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <small class="text-muted d-block">Mã gói</small>
                    <strong>@Model.Package_code</strong>
                </div>
                <div class="col-md-5">
                    <small class="text-muted d-block">Tên gói</small>
                    <strong>@Model.Package_name</strong>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Tổ chức</small>
                    @(Model.Organization_name ?? "—")
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Vùng miền</small>
                    @if (!string.IsNullOrEmpty(Model.Region_name))
                    {
                        <span class="badge bg-info text-dark">@Model.Region_name</span>
                    }
                    else
                    {
                        <span class="text-muted">Toàn quốc</span>
                    }
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Tỉnh/Thành</small>
                    @if (!string.IsNullOrEmpty(Model.Province_name))
                    {
                        <span class="badge bg-primary">@Model.Province_name</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Phường/Xã</small>
                    @if (!string.IsNullOrEmpty(Model.Ward_name))
                    {
                        <span class="badge bg-secondary">@Model.Ward_name</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="col-12">
                        <small class="text-muted d-block">Mô tả</small>
                        @Model.Description
                    </div>
                }
                <div class="col-md-6">
                    <small class="text-muted d-block">Ngày tạo</small>
                    @Model.Created_at.ToString("dd/MM/yyyy HH:mm")
                </div>
                @if (Model.Updated_at != default)
                {
                    <div class="col-md-6">
                        <small class="text-muted d-block">Cập nhật lần cuối</small>
                        @Model.Updated_at.ToString("dd/MM/yyyy HH:mm")
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Products in Package -->
    <div class="table-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-boxes me-2"></i>Sản phẩm trong gói
                <span class="badge bg-primary ms-1">@(Model.Products?.Count ?? 0)</span>
            </span>
        </div>
        <div class="card-body p-0">
            @if (Model.Products == null || !Model.Products.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-box-open fa-3x mb-3 d-block"></i>
                    Chưa có sản phẩm nào trong gói
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Mã SP</th>
                                <th>Tên sản phẩm</th>
                                <th class="text-end">Giá gốc</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var item in Model.Products)
                            {
                                <tr>
                                    <td class="text-muted">@rowNum</td>
                                    <td><span class="badge bg-light text-dark border">@item.Product_code</span></td>
                                    <td>@item.Product_name</td>
                                    <td class="text-end">
                                        @if (item.Original_price > 0)
                                        {
                                            @item.Original_price.ToString("N0")<text> đ</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.Is_active)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="RemoveProduct" method="post" class="d-inline"
                                              onsubmit="return confirm('Xóa sản phẩm @item.Product_name khỏi gói?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="packageId" value="@Model.Id" />
                                            <input type="hidden" name="productId" value="@item.Product_id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-times me-1"></i>Xóa khỏi gói
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Add Product to Package -->
    @if (availableProducts.Any())
    {
        <div class="table-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-plus-circle me-2"></i>Thêm sản phẩm vào gói</span>
                <span class="badge bg-secondary" id="selectedCount">0 đã chọn</span>
            </div>
            <div class="card-body">
                <form asp-action="AddProduct" method="post" id="addProductForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="packageId" value="@Model.Id" />

                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="productSearch" class="form-control" placeholder="Tìm theo mã hoặc tên sản phẩm..." />
                            <button type="button" class="btn btn-outline-secondary" id="selectAllBtn" onclick="toggleSelectAll()">
                                <i class="fas fa-check-double me-1"></i>Chọn tất cả
                            </button>
                        </div>
                    </div>

                    <div id="productList" style="max-height: 320px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 10px;">
                        @foreach (var p in availableProducts)
                        {
                            <label class="product-item d-flex align-items-center px-3 py-2 gap-3 border-bottom"
                                   style="cursor:pointer; transition: background 0.15s;"
                                   data-name="@p.Product_name.ToLower()" data-code="@p.Product_code.ToLower()">
                                <input type="checkbox" name="productIds" value="@p.Id" class="form-check-input product-checkbox flex-shrink-0" style="width:18px;height:18px;" />
                                <span class="badge bg-light text-dark border flex-shrink-0">@p.Product_code</span>
                                <span class="flex-grow-1">@p.Product_name</span>
                            </label>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted">Tổng <strong>@availableProducts.Count</strong> sản phẩm chưa có trong gói</small>
                        <button type="submit" class="btn btn-success" id="addBtn" disabled>
                            <i class="fas fa-plus me-1"></i>Thêm <span id="addBtnCount"></span> sản phẩm đã chọn
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    // Search filter
    document.getElementById('productSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.product-item').forEach(item => {
            const match = item.dataset.name.includes(q) || item.dataset.code.includes(q);
            item.style.display = match ? '' : 'none';
        });
    });

    // Update selected count & button state
    function updateSelection() {
        const checked = document.querySelectorAll('.product-checkbox:checked').length;
        document.getElementById('selectedCount').textContent = checked + ' đã chọn';
        document.getElementById('addBtn').disabled = checked === 0;
        document.getElementById('addBtnCount').textContent = checked > 0 ? checked : '';
        // Hover color
        document.querySelectorAll('.product-item').forEach(item => {
            item.style.background = item.querySelector('.product-checkbox').checked ? '#f0fdf4' : '';
        });
    }

    document.querySelectorAll('.product-checkbox').forEach(cb => cb.addEventListener('change', updateSelection));

    // Label click highlight
    document.querySelectorAll('.product-item').forEach(item => {
        item.addEventListener('mouseenter', () => {
            if (!item.querySelector('.product-checkbox').checked) item.style.background = '#f8fafc';
        });
        item.addEventListener('mouseleave', () => {
            if (!item.querySelector('.product-checkbox').checked) item.style.background = '';
        });
    });

    // Toggle select all (visible only)
    let allSelected = false;
    function toggleSelectAll() {
        const visible = Array.from(document.querySelectorAll('.product-item'))
            .filter(i => i.style.display !== 'none')
            .map(i => i.querySelector('.product-checkbox'));
        allSelected = !allSelected;
        visible.forEach(cb => cb.checked = allSelected);
        document.getElementById('selectAllBtn').innerHTML = allSelected
            ? '<i class="fas fa-times me-1"></i>Bỏ chọn tất cả'
            : '<i class="fas fa-check-double me-1"></i>Chọn tất cả';
        updateSelection();
    }

    // Confirm before submit
    document.getElementById('addProductForm').addEventListener('submit', function (e) {
        const count = document.querySelectorAll('.product-checkbox:checked').length;
        if (count === 0) { e.preventDefault(); return; }
    });
</script>
}
