@model ErpOnlineOrder.Application.DTOs.AdminDTOs.StaffAccountDto
@{
    ViewData["Title"] = "Chi tiết nhân viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1"><i class="fas fa-user me-2 text-primary"></i>Chi tiết nhân viên</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Quản lý nhân sự</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.User_id" class="btn btn-warning">
                <i class="fas fa-edit me-1"></i>Chỉnh sửa
            </a>
            <a asp-action="ResetPassword" asp-route-id="@Model.User_id" class="btn btn-outline-secondary">
                <i class="fas fa-key me-1"></i>Đặt lại mật khẩu
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="table-card mb-4">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 100px; height: 100px; font-size: 40px;">
                        @(string.IsNullOrEmpty(Model.Full_name) ? "?" : Model.Full_name[0].ToString().ToUpper())
                    </div>
                    <h5 class="mb-1">@Model.Full_name</h5>
                    <p class="text-muted mb-2"><span class="badge bg-secondary">@Model.Staff_code</span></p>
                    <div>
                        @if (Model.Is_active)
                        {
                            <span class="badge bg-success"><i class="fas fa-check me-1"></i>Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Vô hiệu hóa</span>
                        }
                    </div>
                </div>
            </div>

            <div class="table-card">
                <div class="card-header"><i class="fas fa-cogs me-2"></i>Thao tác</div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (Model.Is_active)
                        {
                            <form asp-action="ToggleStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.User_id" />
                                <input type="hidden" name="isActive" value="false" />
                                <button type="submit" class="btn btn-outline-danger w-100"
                                        onclick="return confirm('Vô hiệu hóa tài khoản này?');">
                                    <i class="fas fa-user-slash me-1"></i>Vô hiệu hóa
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="ToggleStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.User_id" />
                                <input type="hidden" name="isActive" value="true" />
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="fas fa-user-check me-1"></i>Kích hoạt
                                </button>
                            </form>
                        }
                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.User_id" />
                            <button type="submit" class="btn btn-danger w-100"
                                    onclick="return confirm('Xóa tài khoản này? Thao tác không thể hoàn tác!');">
                                <i class="fas fa-trash me-1"></i>Xóa tài khoản
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="table-card">
                <div class="card-header"><i class="fas fa-info-circle me-2"></i>Thông tin nhân viên</div>
                <div class="card-body">
                    <div class="info-row">
                        <span class="info-label">Tên đăng nhập</span>
                        <span class="info-value fw-semibold">@Model.Username</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Mã nhân viên</span>
                        <span class="info-value"><span class="badge bg-secondary">@Model.Staff_code</span></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value"><a href="mailto:@Model.Email">@Model.Email</a></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số điện thoại</span>
                        <span class="info-value">
                            @if (!string.IsNullOrEmpty(Model.Phone_number))
                            {
                                <a href="tel:@Model.Phone_number">@Model.Phone_number</a>
                            }
                            else
                            {
                                <span class="text-muted">Chưa cập nhật</span>
                            }
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Ngày tạo</span>
                        <span class="info-value">@Model.Created_at.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Vai trò</span>
                        <span class="info-value">
                            @if (Model.Roles.Any())
                            {
                                @foreach (var role in Model.Roles)
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Chưa phân quyền</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
