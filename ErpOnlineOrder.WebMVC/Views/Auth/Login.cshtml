@model ErpOnlineOrder.Application.DTOs.AuthDTOs.LoginUserDto
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

@section Styles {
<style>
    .password-toggle {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
        z-index: 10;
    }
    .password-wrapper { position: relative; }
</style>
}

<div class="auth-card">
    <div class="auth-header">
        <i class="fas fa-user-circle"></i>
        <h3 class="mb-0">Đăng nhập hệ thống</h3>
        <p class="mb-0 mt-2 opacity-75">ERP Online Order</p>
    </div>
    <div class="auth-body">
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>@ViewBag.SuccessMessage
            </div>
        }

        @if (TempData["Error"] is string errorMsg)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()
            @if (ViewBag.ReturnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            }

            <div class="mb-4">
                <label asp-for="Identifier" class="form-label fw-semibold">
                    <i class="fas fa-user me-1"></i> Tên đăng nhập / Email
                </label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input asp-for="Identifier" class="form-control" placeholder="Nhập tên đăng nhập hoặc email" autofocus />
                </div>
                <span asp-validation-for="Identifier" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i> Mật khẩu
                </label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <div class="password-wrapper flex-grow-1">
                        <input asp-for="Password" type="password" class="form-control" id="passwordInput" placeholder="Nhập mật khẩu" style="border-radius: 0 10px 10px 0;" />
                        <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <a asp-action="ForgotPassword" class="text-muted small">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-auth w-100 mb-3" id="btnLogin">
                <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập
            </button>

            <div class="text-center">
                <span class="text-muted">Chưa có tài khoản?</span>
                <a asp-controller="Auth" asp-action="CustomerRegister" class="auth-link ms-1">Đăng ký ngay</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        var passwordInput = document.getElementById('passwordInput');
        var icon = this;
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            passwordInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });
    document.getElementById('loginForm').addEventListener('submit', function () {
        var btn = document.getElementById('btnLogin');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang đăng nhập...';
        btn.disabled = true;
    });

    window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
            var btn = document.getElementById('btnLogin');
            btn.innerHTML = '<i class="fas fa-sign-in-alt me-2"></i> Đăng nhập';
            btn.disabled = false;
        }
    });
</script>
}
