@model ErpOnlineOrder.WebMVC.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <i class="fas fa-lock"></i>
        <h3 class="mb-0">Đặt lại mật khẩu</h3>
        <p class="mb-0 mt-2 opacity-75">Nhập mật khẩu mới cho tài khoản của bạn</p>
    </div>
    <div class="auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
            </div>
        }

        <form asp-controller="Auth" asp-action="ResetPassword" method="post" id="resetForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" value="@ViewBag.Token" />
            <input type="hidden" asp-for="Email" value="@ViewBag.Email" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i> Mật khẩu mới
                </label>
                <input type="password" asp-for="NewPassword" class="form-control"
                       placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" autofocus />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i> Xác nhận mật khẩu
                </label>
                <input type="password" asp-for="ConfirmPassword" class="form-control"
                       placeholder="Nhập lại mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-danger btn-auth w-100 mb-3" id="btnSubmit">
                <i class="fas fa-check me-2"></i> Đặt lại mật khẩu
            </button>
            <div class="text-center">
                <a asp-controller="Auth" asp-action="Login" class="auth-link">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.getElementById('resetForm').addEventListener('submit', function () {
        var btn = document.getElementById('btnSubmit');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang xử lý...';
        btn.disabled = true;
    });
</script>
}
