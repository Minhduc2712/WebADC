@model ErpOnlineOrder.Application.DTOs.AuthDTOs.RegisterCustomerAccountStepDto
@{
    ViewData["Title"] = "Đăng ký tài khoản - Bước 1";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="auth-card auth-card-wide">
    <div class="auth-header">
        <i class="fas fa-user-plus"></i>
        <h3 class="mb-0">Đăng ký khách hàng - Bước 1/3</h3>
        <p class="mb-0 mt-2 opacity-75">Thông tin tài khoản</p>
    </div>
    <div class="auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert-error">
                <div class="auth-alert-icon">
                    <i class="fas fa-exclamation-circle"></i>
                </div>
                <div class="auth-alert-content">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <form asp-controller="Auth" asp-action="CustomerRegister" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-user me-1"></i> Tên đăng nhập <span class="text-danger">*</span>
                </label>
                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-envelope me-1"></i> Email <span class="text-danger">*</span>
                </label>
                <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i> Mật khẩu <span class="text-danger">*</span>
                </label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fas fa-check-circle me-1"></i> Nhập lại mật khẩu <span class="text-danger">*</span>
                </label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-auth w-100 mb-3">
                <i class="fas fa-arrow-right me-2"></i> Tiếp tục bước 2
            </button>

            <div class="text-center">
                <span class="text-muted">Đã có tài khoản?</span>
                <a asp-controller="Auth" asp-action="Login" class="auth-link ms-1">Đăng nhập ngay</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
