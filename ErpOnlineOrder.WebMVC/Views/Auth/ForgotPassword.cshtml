@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <i class="fas fa-unlock-alt"></i>
        <h3 class="mb-0">Quên mật khẩu</h3>
        <p class="mb-0 mt-2 opacity-75">Khôi phục tài khoản của bạn</p>
    </div>
    <div class="auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
            </div>
        }

        <div class="alert alert-info small">
            <i class="fas fa-info-circle me-1"></i>
            Nhập email đăng ký của bạn. Chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu qua email.
        </div>

        <form asp-controller="Auth" asp-action="ForgotPassword" method="post" id="forgotForm">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-semibold">
                    <i class="fas fa-envelope me-1"></i> Email đăng ký
                </label>
                <input type="email" name="email" class="form-control" placeholder="Nhập email của bạn" value="@(ViewBag.Email)" required autofocus />
            </div>

            <button type="submit" class="btn btn-primary btn-auth w-100 mb-3" id="btnSubmit">
                <i class="fas fa-paper-plane me-2"></i> Gửi yêu cầu
            </button>

            <div class="text-center">
                <a asp-controller="Auth" asp-action="Login" class="auth-link">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('forgotForm').addEventListener('submit', function () {
        var btn = document.getElementById('btnSubmit');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang gửi...';
        btn.disabled = true;
    });
</script>
}
