@model ErpOnlineOrder.Application.DTOs.AuthDTOs.RegisterCustomerPersonalStepDto
@{
    ViewData["Title"] = "Đăng ký khách hàng - Bước 2";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
    var provinces = ViewBag.Provinces as List<ErpOnlineOrder.Application.DTOs.ProvinceDTOs.ProvinceDTO> ?? new List<ErpOnlineOrder.Application.DTOs.ProvinceDTOs.ProvinceDTO>();
}

<div class="auth-card auth-card-wide">
    <div class="auth-header">
        <i class="fas fa-id-card"></i>
        <h3 class="mb-0">Đăng ký khách hàng - Bước 2/3</h3>
        <p class="mb-0 mt-2 opacity-75">Thông tin cá nhân</p>
    </div>
    <div class="auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert-error">
                <div class="auth-alert-icon">
                    <i class="fas fa-exclamation-circle"></i>
                </div>
                <div class="auth-alert-content">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <form asp-controller="Auth" asp-action="CustomerRegisterPersonal" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Full_name" class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                <input asp-for="Full_name" class="form-control" placeholder="Nhập họ tên" />
                <span asp-validation-for="Full_name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone_number" class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                <input asp-for="Phone_number" class="form-control" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="Phone_number" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold">Địa chỉ cá nhân <span class="text-danger">*</span></label>
                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ cá nhân" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Province_id" class="form-label fw-semibold">
                    <i class="fas fa-map-marker-alt me-1 text-danger"></i>Tỉnh/Thành phố <span class="text-muted small">(tùy chọn)</span>
                </label>
                <select asp-for="Province_id" class="form-select" id="regProvinceSelect">
                    <option value="">-- Chọn tỉnh/thành phố --</option>
                    @foreach (var p in provinces)
                    {
                        <option value="@p.Id" selected="@(Model.Province_id == p.Id)">@p.Province_name</option>
                    }
                </select>
                <div class="form-text">Chọn địa bàn để được gán cán bộ phụ trách tự động</div>
            </div>

            <div class="mb-3">
                <label asp-for="Ward_id" class="form-label fw-semibold">
                    <i class="fas fa-map-pin me-1 text-info"></i>Phường/Xã <span class="text-muted small">(tùy chọn)</span>
                </label>
                <select asp-for="Ward_id" class="form-select" id="regWardSelect">
                    <option value="">-- Chọn phường/xã (hoặc bỏ trống nếu toàn tỉnh) --</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="CustomerRegister" class="btn btn-outline-secondary w-50">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
                <button type="submit" class="btn btn-primary w-50">
                    <i class="fas fa-arrow-right me-2"></i>Tiếp tục bước 3
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // If a province was previously selected (validation error), load its wards
        (function () {
            var savedProvince = document.getElementById('regProvinceSelect').value;
            var savedWard = '@(Model.Ward_id?.ToString() ?? "")';
            if (savedProvince) loadWards(savedProvince, savedWard);
        })();

        document.getElementById('regProvinceSelect').addEventListener('change', function () {
            loadWards(this.value, '');
        });

        function loadWards(provinceId, selectedWardId) {
            var wardSelect = document.getElementById('regWardSelect');
            wardSelect.innerHTML = '<option value="">-- Đang tải... --</option>';
            if (!provinceId) {
                wardSelect.innerHTML = '<option value="">-- Chọn phường/xã (hoặc bỏ trống nếu toàn tỉnh) --</option>';
                return;
            }
            fetch('/Auth/GetWardsByProvince?provinceId=' + provinceId)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    wardSelect.innerHTML = '<option value="">-- Chọn phường/xã (hoặc bỏ trống nếu toàn tỉnh) --</option>';
                    data.forEach(function (w) {
                        var opt = document.createElement('option');
                        opt.value = w.id;
                        opt.textContent = w.ward_name;
                        if (selectedWardId && w.id == selectedWardId) opt.selected = true;
                        wardSelect.appendChild(opt);
                    });
                })
                .catch(function () {
                    wardSelect.innerHTML = '<option value="">-- Chọn phường/xã (hoặc bỏ trống nếu toàn tỉnh) --</option>';
                });
        }
    </script>
}
