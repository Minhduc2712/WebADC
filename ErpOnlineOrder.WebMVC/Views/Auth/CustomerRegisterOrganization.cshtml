@model ErpOnlineOrder.Application.DTOs.AuthDTOs.RegisterCustomerOrganizationStepDto
@{
    ViewData["Title"] = "Đăng ký khách hàng - Bước 3";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="auth-card auth-card-wide">
    <div class="auth-header">
        <i class="fas fa-building"></i>
        <h3 class="mb-0">Đăng ký khách hàng - Bước 3/3</h3>
        <p class="mb-0 mt-2 opacity-75">Thông tin đơn vị</p>
    </div>
    <div class="auth-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert-error">
                <div class="auth-alert-icon">
                    <i class="fas fa-exclamation-circle"></i>
                </div>
                <div class="auth-alert-content">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <form asp-controller="Auth" asp-action="CustomerRegisterOrganization" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Organization_name" class="form-label fw-semibold">Tên đơn vị <span class="text-danger">*</span></label>
                <input asp-for="Organization_name" class="form-control" placeholder="Nhập tên đơn vị" />
                <span asp-validation-for="Organization_name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold">Địa chỉ đơn vị <span class="text-danger">*</span></label>
                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ đơn vị" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tax_number" class="form-label fw-semibold">Mã số thuế</label>
                <input asp-for="Tax_number" type="number" min="0" class="form-control" placeholder="Nhập mã số thuế" />
                <span asp-validation-for="Tax_number" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Recipient_name" class="form-label fw-semibold">Tên người nhận <span class="text-danger">*</span></label>
                <input asp-for="Recipient_name" class="form-control" placeholder="Nhập tên người nhận" />
                <span asp-validation-for="Recipient_name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Recipient_phone" class="form-label fw-semibold">Số điện thoại người nhận <span class="text-danger">*</span></label>
                <input asp-for="Recipient_phone" type="text" class="form-control" placeholder="Nhập số điện thoại người nhận" />
                <span asp-validation-for="Recipient_phone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Recipient_address" class="form-label fw-semibold">Địa chỉ nhận hàng <span class="text-danger">*</span></label>
                <input asp-for="Recipient_address" class="form-control" placeholder="Nhập địa chỉ nhận hàng" />
                <span asp-validation-for="Recipient_address" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="CustomerRegisterPersonal" class="btn btn-outline-secondary w-50">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
                <button type="submit" class="btn btn-primary w-50">
                    <i class="fas fa-check me-2"></i>Hoàn tất đăng ký
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
