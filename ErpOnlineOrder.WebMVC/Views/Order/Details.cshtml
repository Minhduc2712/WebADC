@model ErpOnlineOrder.Application.DTOs.OrderDTO
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var statusClass = Model.Order_status switch
    {
        "Pending" => "bg-warning text-dark",
        "Exporting" => "bg-primary",
        "Confirmed" => "bg-primary",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        "Split" => "bg-secondary",
        _ => "bg-secondary"
    };
    var statusText = Model.Order_status switch
    {
        "Pending" => "Chờ xử lý",
        "Exporting" => "Xuất kho",
        "Confirmed" => "Đã xác nhận",
        "Completed" => "Hoàn thành",
        "Cancelled" => "Đã hủy",
        "Split" => "Đã tách",
        _ => Model.Order_status
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Chi tiết đơn hàng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Đơn hàng</a></li>
                <li class="breadcrumb-item active">@Model.Order_code</li>
            </ol>
        </nav>
    </div>
    <div>
        @if (Model.Order_status == "Pending")
        {
            @if (ViewBag.CanUpdate == true)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                    <i class="fas fa-edit me-1"></i>Sửa đơn
                </a>
            }
            @if (ViewBag.CanApprove == true)
            {
                <button type="button" class="btn btn-success me-2" onclick="openApproveModal(@Model.Id, '@Model.Order_code')">
                    <i class="fas fa-check me-1"></i>Duyệt
                </button>
            }
            @if (ViewBag.CanReject == true)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="fas fa-times me-1"></i>Hủy đơn
                    </button>
                </form>
            }
        }
        @* @if (Model.Order_status == "Confirmed" && ViewBag.CanCreateInvoice == true)
        {
            <form asp-action="CreateInvoice" asp-route-id="@Model.Id" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-info me-2" onclick="return confirm('Tạo hóa đơn nháp từ đơn hàng này?')">
                    <i class="fas fa-file-invoice me-1"></i>Xuất hóa đơn
                </button>
            </form>
        } *@
        <a asp-action="PrintOrder" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-info me-2">
            <i class="fas fa-print me-1"></i>In đơn
        </a>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-check-circle text-success me-2"></i>Duyệt đơn hàng <span id="approveOrderCode" class="badge bg-secondary ms-1"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="approveForm" method="post">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="approveOrderId" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn sản phẩm cần duyệt</label>
                        <div class="table-responsive border rounded">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 56px;">Chọn</th>
                                        <th>Sản phẩm</th>
                                        <th style="width: 130px;">SL đặt</th>
                                        <th style="width: 150px;">SL duyệt</th>
                                    </tr>
                                </thead>
                                <tbody id="approveItemsBody"></tbody>
                            </table>
                        </div>
                        <div class="form-text">Phần sản phẩm không duyệt sẽ được tách sang đơn hàng con (trạng thái chờ xử lý).</div>
                    </div>

                    <div>
                        <label class="form-label fw-semibold">Hình thức gửi cho khách hàng</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Notify_method" id="notifyEmail" value="email" checked>
                            <label class="form-check-label" for="notifyEmail">Gửi qua email</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Notify_method" id="notifyDownload" value="download">
                            <label class="form-check-label" for="notifyDownload">Tải xuống file CSV</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success">Xác nhận duyệt</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const approveModal = new bootstrap.Modal(document.getElementById('approveModal'));

    function openApproveModal(id, orderCode) {
        document.getElementById('approveOrderCode').textContent = orderCode;
        document.getElementById('approveOrderId').value = id;
        document.getElementById('approveForm').action = '@Url.Action("Confirm")/' + id;
        renderApproveItems();
        approveModal.show();
    }

    function renderApproveItems() {
        const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Order_details.Select(x => new
                     {
                         product_id = x.Product_id,
                         product_name = x.Product_name,
                         quantity = x.Quantity
                     })));

        if (!items.length) {
            document.getElementById('approveItemsBody').innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">Không có sản phẩm để duyệt.</td></tr>';
            return;
        }

        const rows = items.map((item, index) => {
            return `<tr>
                <td>
                    <input class="form-check-input" type="checkbox" name="Approved_items[${index}].Is_selected" value="true" checked />
                    <input type="hidden" name="Approved_items[${index}].Product_id" value="${item.product_id}" />
                </td>
                <td>${item.product_name}</td>
                <td>${item.quantity}</td>
                <td>
                    <input type="number" class="form-control form-control-sm" min="1" max="${item.quantity}" value="${item.quantity}" name="Approved_items[${index}].Quantity" required />
                </td>
            </tr>`;
        }).join('');

        document.getElementById('approveItemsBody').innerHTML = rows;
    }
</script>
}

<div class="row">
    <div class="col-md-4">
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Thông tin đơn hàng
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small">Mã đơn hàng</label>
                    <p class="mb-0 fw-semibold">@Model.Order_code</p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Trạng thái</label>
                    <p class="mb-0"><span class="badge @statusClass">@statusText</span></p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Ngày đặt hàng</label>
                    <p class="mb-0">@Model.Order_date.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Tổng tiền</label>
                    <p class="mb-0 text-success fw-bold fs-5">@Model.Total_price.ToString("N0") VNĐ</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Shipping_address))
                {
                    <div class="mb-3">
                        <label class="text-muted small">Địa chỉ giao hàng</label>
                        <p class="mb-0">@Model.Shipping_address</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.note))
                {
                    <div class="mb-0">
                        <label class="text-muted small">Ghi chú</label>
                        <p class="mb-0">@Model.note</p>
                    </div>
                }
            </div>
        </div>
        
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-user me-2"></i>Thông tin khách hàng
            </div>
            <div class="card-body">
                <div class="mb-0">
                    <label class="text-muted small">Tên khách hàng</label>
                    <p class="mb-0 fw-semibold">@(string.IsNullOrWhiteSpace(Model.Customer_name) ? "—" : Model.Customer_name)</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-list me-2"></i>Chi tiết sản phẩm (@Model.Order_details.Count sản phẩm)
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var index = 1;
                            }
                            @foreach (var detail in Model.Order_details)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@detail.Product_name</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end">@detail.Unit_price.ToString("N0") VNĐ</td>
                                    <td class="text-end fw-semibold">@detail.Total_price.ToString("N0") VNĐ</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end text-success fw-bold fs-5">@Model.Total_price.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
