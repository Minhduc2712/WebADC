@model ErpOnlineOrder.Application.DTOs.CustomerProductDTOs.AssignProductsToCustomerDto
@{
    ViewData["Title"] = "Gán sản phẩm cho khách hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var customer = ViewBag.Customer as ErpOnlineOrder.Application.DTOs.CustomerDTO;
    var pagedProducts = ViewBag.PagedProducts as PagedResult<ErpOnlineOrder.Application.DTOs.ProductDTO>;
    var items = pagedProducts?.Items ?? new List<ErpOnlineOrder.Application.DTOs.ProductDTO>();
    var assignedProductIds = ViewBag.AssignedProductIds as HashSet<int> ?? new HashSet<int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/assign-products.css">
}

<div class="assign-products-page">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "CustomerManagement")">Khách hàng</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Details", "CustomerManagement", new { id = customer?.Id })" class="text-white-50">@(customer?.Full_name ?? "")</a></li>
                    <li class="breadcrumb-item active">Gán sản phẩm</li>
                </ol>
            </nav>
            <h4 class="mb-0 text-white"><i class="fas fa-box me-2"></i>Gán sản phẩm cho khách hàng</h4>
        </div>
        <a href="@Url.Action("Index", new { customerId = Model.Customer_id })" class="btn btn-light btn-back">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    @if (customer != null)
    {
        <div class="customer-card">
            <div class="d-flex align-items-center gap-3">
                <div class="customer-avatar">
                    @(customer.Full_name?.Length > 0 ? customer.Full_name.Substring(0, 1).ToUpper() : "?")
                </div>
                <div>
                    <div class="customer-name">@customer.Full_name</div>
                    <span class="customer-code">@customer.Customer_code</span>
                </div>
            </div>
        </div>
    }

    <!-- Bộ lọc -->
    <div class="table-card mb-4">
        <div class="card-header">
            <i class="fas fa-filter me-2"></i>Bộ lọc tìm kiếm
        </div>
        <div class="card-body p-4">
            <form asp-action="AssignProducts" method="get" id="filterForm">
                <input type="hidden" name="customerId" value="@Model.Customer_id" />
                <input type="hidden" name="page" value="1" />
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Tìm kiếm</label>
                        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên, mã sản phẩm..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Thể loại</label>
                        @Html.DropDownList("categoryId", ViewBag.Categories as SelectList, "-- Tất cả --", new { @class = "form-select", onchange = "this.form.submit()" })
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Số dòng/trang</label>
                        <select name="pageSize" class="form-select" onchange="this.form.submit()">
                            <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                            <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                            <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search me-1"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
                <div class="mt-2">
                    <a href="@Url.Action("AssignProducts", new { customerId = Model.Customer_id })" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-redo me-1"></i>Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Danh sách sản phẩm -->
    <div class="table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-check-square me-2"></i>Chọn sản phẩm để gán (@(pagedProducts?.TotalCount ?? 0) sản phẩm)</span>
        </div>
        <div class="card-body p-0">
            <form asp-action="AssignProducts" method="post" id="assignForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Customer_id" value="@Model.Customer_id" />

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="selectAll" title="Chọn tất cả" />
                                    </div>
                                </th>
                                <th style="width: 80px;">Ảnh</th>
                                <th>Mã SP</th>
                                <th>Tên sản phẩm</th>
                                <th>Tác giả</th>
                                <th>Giá</th>
                                <th>Danh mục</th>
                                <th style="width: 100px;">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!items.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">
                                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                        Không có sản phẩm nào
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var product in items)
                                {
                                    var isAssigned = assignedProductIds.Contains(product.Id);
                                    <tr class="@(isAssigned ? "table-success" : "")">
                                        <td>
                                            <div class="form-check">
                                                @if (isAssigned)
                                                {
                                                    <input class="form-check-input" type="checkbox" disabled checked />
                                                }
                                                else
                                                {
                                                    <input class="form-check-input product-checkbox" type="checkbox"
                                                           name="Product_ids" value="@product.Id" id="prod_@product.Id" />
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(product.Product_link))
                                            {
                                                <img src="@product.Product_link" alt="@product.Product_name"
                                                     style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" />
                                            }
                                            else
                                            {
                                                <div style="width: 50px; height: 50px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-image text-muted"></i>
                                                </div>
                                            }
                                        </td>
                                        <td><span class="badge bg-secondary">@product.Product_code</span></td>
                                        <td><strong>@product.Product_name</strong></td>
                                        <td>@string.Join(", ", product.Authors)</td>
                                        <td><span class="text-success fw-bold">@product.Product_price_formatted</span></td>
                                        <td>
                                            @foreach (var cat in product.Categories.Take(2))
                                            {
                                                <span class="badge bg-info me-1">@cat</span>
                                            }
                                            @if (product.Categories.Count > 2)
                                            {
                                                <span class="badge bg-secondary">+@(product.Categories.Count - 2)</span>
                                            }
                                        </td>
                                        <td>
                                            @if (isAssigned)
                                            {
                                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Đã gán</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-outline-secondary text-muted">Chưa gán</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @if (pagedProducts != null && pagedProducts.TotalPages > 1)
                {
                    ViewBag.PaginationItemLabel = "sản phẩm";
                    ViewBag.PaginationAction = "AssignProducts";
                    @await Html.PartialAsync("_Pagination", pagedProducts)
                }

                @if (items.Any())
                {
                    <div class="p-3 border-top">
                        <button type="submit" class="btn btn-primary" id="btnSubmit">
                            <i class="fas fa-user-tag me-2"></i>Gán sản phẩm đã chọn (<span id="selectedCount">0</span>)
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var selectAll = document.getElementById('selectAll');
    var btnSubmit = document.getElementById('btnSubmit');
    var selectedCount = document.getElementById('selectedCount');

    function getCheckboxes() {
        return document.querySelectorAll('.product-checkbox');
    }

    function updateCount() {
        var checked = document.querySelectorAll('.product-checkbox:checked').length;
        if (selectedCount) selectedCount.textContent = checked;
        if (btnSubmit) btnSubmit.disabled = checked === 0;
    }

    if (selectAll) {
        selectAll.addEventListener('change', function() {
            getCheckboxes().forEach(function(cb) {
                cb.checked = selectAll.checked;
            });
            updateCount();
        });
    }

    getCheckboxes().forEach(function(cb) {
        cb.addEventListener('change', function() {
            updateCount();
            if (selectAll) {
                var all = getCheckboxes();
                var checkedAll = Array.from(all).every(function(c) { return c.checked; });
                selectAll.checked = checkedAll && all.length > 0;
            }
        });
    });

    document.getElementById('assignForm')?.addEventListener('submit', function(e) {
        var checked = document.querySelectorAll('.product-checkbox:checked');
        if (checked.length === 0) {
            e.preventDefault();
            alert('Vui lòng chọn ít nhất một sản phẩm.');
        }
    });

    // Click row to toggle checkbox
    document.querySelectorAll('#assignForm tbody tr').forEach(function(row) {
        var cb = row.querySelector('.product-checkbox');
        if (!cb) return;
        row.style.cursor = 'pointer';
        row.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox' || e.target.tagName === 'A') return;
            cb.checked = !cb.checked;
            cb.dispatchEvent(new Event('change'));
        });
    });

    updateCount();
})();
</script>
}
