@model ErpOnlineOrder.Application.DTOs.StaffRegionRuleDTOs.CreateStaffRegionRuleDto
@using ErpOnlineOrder.Application.DTOs.AdminDTOs
@using ErpOnlineOrder.Application.DTOs.ProvinceDTOs
@using ErpOnlineOrder.Application.DTOs.WardDTOs
@{
    ViewData["Title"] = "Thêm quy tắc phân công vùng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var provinces = ViewBag.Provinces as List<ProvinceDTO> ?? new List<ProvinceDTO>();
    var staffList = ViewBag.StaffList as List<StaffAccountDto> ?? new List<StaffAccountDto>();
    var wards = ViewBag.Wards as List<WardDTO> ?? new List<WardDTO>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-plus-circle me-2 text-primary"></i>Thêm quy tắc phân công vùng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Phân công vùng</a></li>
                <li class="breadcrumb-item active">Thêm mới</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <strong><i class="fas fa-map-marked-alt me-2"></i>Thông tin quy tắc</strong>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

                    <div class="mb-3">
                        <label class="form-label">Cán bộ phụ trách <span class="text-danger">*</span></label>
                        <select name="Staff_id" class="form-select">
                            <option value="0">-- Chọn cán bộ --</option>
                            @foreach (var s in staffList)
                            {
                                <option value="@s.Staff_id" selected="@(s.Staff_id == Model.Staff_id)">@s.Full_name (@s.Staff_code)</option>
                            }
                        </select>
                        <span asp-validation-for="Staff_id" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh/Thành <span class="text-danger">*</span></label>
                        <select name="Province_id" class="form-select" id="provinceSelect" onchange="loadWards(this.value)">
                            <option value="0">-- Chọn tỉnh/thành --</option>
                            @foreach (var p in provinces)
                            {
                                <option value="@p.Id" selected="@(p.Id == Model.Province_id)">@p.Province_name</option>
                            }
                        </select>
                        <span asp-validation-for="Province_id" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phường/Xã <small class="text-muted">(không chọn = phụ trách toàn tỉnh)</small></label>

                        <div id="wardSection">
                            <div id="wardLoading" class="text-muted small py-2" style="display:none;">
                                <i class="fas fa-spinner fa-spin me-1"></i>Đang tải danh sách phường/xã...
                            </div>
                            <div id="wardPlaceholder" class="text-muted small fst-italic py-2">
                                Vui lòng chọn tỉnh/thành trước
                            </div>

                            <div id="wardCheckboxes" style="display:none;">
                                <div class="mb-2 d-flex gap-2 align-items-center">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllWards()">
                                        <i class="fas fa-check-double me-1"></i>Chọn tất cả
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearAllWards()">
                                        <i class="fas fa-times me-1"></i>Bỏ chọn tất cả
                                    </button>
                                    <span id="wardSelectedCount" class="text-muted small ms-2"></span>
                                </div>
                                <div id="wardList" class="border rounded p-3" style="max-height:280px; overflow-y:auto; background:#fafafa;">
                                    <!-- checkboxes injected here -->
                                </div>
                            </div>

                            <div id="wardEmptyMsg" class="text-muted small fst-italic py-2" style="display:none;">
                                Tỉnh/thành này chưa có danh sách phường/xã — quy tắc sẽ áp dụng toàn tỉnh.
                            </div>
                        </div>

                        <div class="form-text mt-1">
                            Nếu không chọn phường/xã nào → áp dụng toàn tỉnh/thành.
                            Tất cả phường/xã được chọn tạo thành <strong>1 quy tắc duy nhất</strong>.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Lưu quy tắc
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        async function loadWards(provinceId) {
            const loading = document.getElementById('wardLoading');
            const placeholder = document.getElementById('wardPlaceholder');
            const checkboxes = document.getElementById('wardCheckboxes');
            const wardList = document.getElementById('wardList');
            const emptyMsg = document.getElementById('wardEmptyMsg');

            placeholder.style.display = 'none';
            emptyMsg.style.display = 'none';
            checkboxes.style.display = 'none';
            wardList.innerHTML = '';

            if (!provinceId || provinceId === '0') {
                placeholder.style.display = 'block';
                return;
            }

            loading.style.display = 'block';
            try {
                const res = await fetch('@Url.Action("GetWardsByProvince")/?provinceId=' + provinceId);
                const wards = await res.json();
                loading.style.display = 'none';

                if (!wards || wards.length === 0) {
                    emptyMsg.style.display = 'block';
                    return;
                }

                wards.forEach(w => {
                    const div = document.createElement('div');
                    div.className = 'form-check' + (w.isUsed ? ' opacity-50' : '');
                    div.innerHTML = `<input class="form-check-input ward-cb" type="checkbox"
                        name="Ward_ids" value="${w.id}" id="ward_${w.id}" ${w.isUsed ? 'disabled' : ''} onchange="updateCount()">
                        <label class="form-check-label${w.isUsed ? ' text-muted fst-italic' : ''}" for="ward_${w.id}">
                            ${w.ward_name}${w.isUsed ? ' <span class="badge bg-secondary ms-1" style="font-size:0.7em;">Đã có CB</span>' : ''}
                        </label>`;
                    wardList.appendChild(div);
                });

                checkboxes.style.display = 'block';
                updateCount();
            } catch (e) {
                loading.style.display = 'none';
                emptyMsg.textContent = 'Lỗi tải phường/xã.';
                emptyMsg.style.display = 'block';
                console.error('Lỗi tải phường/xã:', e);
            }
        }

        function selectAllWards() {
            document.querySelectorAll('.ward-cb:not(:disabled)').forEach(cb => cb.checked = true);
            updateCount();
        }

        function clearAllWards() {
            document.querySelectorAll('.ward-cb:not(:disabled)').forEach(cb => cb.checked = false);
            updateCount();
        }

        function updateCount() {
            const available = document.querySelectorAll('.ward-cb:not(:disabled)').length;
            const selected = document.querySelectorAll('.ward-cb:not(:disabled):checked').length;
            const el = document.getElementById('wardSelectedCount');
            if (selected === 0)
                el.textContent = 'Không chọn = toàn tỉnh/thành';
            else
                el.textContent = `Đã chọn ${selected}/${available} phường/xã`;
        }

        // Nếu tỉnh đã được chọn sẵn (sau khi submit lỗi)
        document.addEventListener('DOMContentLoaded', () => {
            const prov = document.getElementById('provinceSelect');
            if (prov && prov.value && prov.value !== '0') loadWards(prov.value);
        });
    </script>
}
