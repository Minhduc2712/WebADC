@model ErpOnlineOrder.Application.DTOs.PackageDTOs.PackageDto
@{
    ViewData["Title"] = "Sản phẩm trong gói của khách hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var customer = ViewBag.Customer as ErpOnlineOrder.Application.DTOs.CustomerDTO;
    var customerPackage = ViewBag.CustomerPackage as ErpOnlineOrder.Application.DTOs.CustomerPackageDTOs.CustomerPackageDto;
    var excludedProductIds = ViewBag.ExcludedProductIds as HashSet<int> ?? new HashSet<int>();
    var canAssign = (bool)(ViewBag.CanAssign ?? false);
    var products = Model?.Products ?? new List<ErpOnlineOrder.Application.DTOs.PackageDTOs.PackageProductDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-cubes me-2 text-primary"></i>Sản phẩm trong gói của khách hàng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "CustomerPackage")">KH - Gói SP</a></li>
                <li class="breadcrumb-item active">Sản phẩm trong gói</li>
            </ol>
        </nav>
    </div>
    <a href="@Url.Action("Index", "CustomerPackage")" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="table-card">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <i class="fas fa-user-circle fa-2x text-primary me-3"></i>
                    <div>
                        <strong>@(customer?.Full_name ?? "")</strong>
                        <span class="badge bg-secondary ms-2">@(customer?.Customer_code ?? "")</span>
                        <div class="small text-muted">@(customer?.Phone_number ?? "")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="table-card">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <i class="fas fa-cube fa-2x text-info me-3"></i>
                    <div>
                        <strong>@Model?.Package_name</strong>
                        <span class="badge bg-info ms-2">@Model?.Package_code</span>
                        <div class="small text-muted">@(Model?.Description ?? "Không có mô tả")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var excludedInThisPackage = products.Count(p => excludedProductIds.Contains(p.Product_id));
}
@if (excludedInThisPackage > 0)
{
    <div class="alert alert-warning d-flex align-items-center">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <span>Khách hàng này đang bị loại bỏ <strong>@excludedInThisPackage</strong> sản phẩm khỏi gói.</span>
    </div>
}

<div class="table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>Sản phẩm trong gói (@products.Count)</span>
    </div>
    <div class="card-body p-0">
        @if (!products.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fa-3x mb-3 d-block opacity-50"></i>
                <p class="mb-0">Gói này chưa có sản phẩm nào.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Mã SP</th>
                            <th>Tên sản phẩm</th>
                            <th>Giá gốc</th>
                            <th>Trạng thái gói</th>
                            <th>Trạng thái KH</th>
                            @if (canAssign)
                            {
                                <th style="width: 150px;">Thao tác</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < products.Count; i++)
                        {
                            var product = products[i];
                            var isExcluded = excludedProductIds.Contains(product.Product_id);
                            <tr class="@(isExcluded ? "table-danger" : "")">
                                <td>@(i + 1)</td>
                                <td><span class="badge bg-secondary">@product.Product_code</span></td>
                                <td>@product.Product_name</td>
                                <td>@product.Original_price.ToString("N0")</td>
                                <td>
                                    @if (product.Is_active)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Tạm khóa</span>
                                    }
                                </td>
                                <td>
                                    @if (isExcluded)
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-ban me-1"></i>Đã loại bỏ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Được phép</span>
                                    }
                                </td>
                                @if (canAssign)
                                {
                                    <td>
                                        @if (isExcluded)
                                        {
                                            <form asp-action="UnexcludeProduct" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="customerPackageId" value="@customerPackage?.Id" />
                                                <input type="hidden" name="customerId" value="@(customer?.Id ?? 0)" />
                                                <input type="hidden" name="productId" value="@product.Product_id" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Khôi phục sản phẩm">
                                                    <i class="fas fa-undo me-1"></i>Khôi phục
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    data-product-id="@product.Product_id"
                                                    data-product-name="@product.Product_name"
                                                    onclick="confirmExclude(this)"
                                                    title="Loại bỏ sản phẩm cho khách hàng này">
                                                <i class="fas fa-ban me-1"></i>Loại bỏ
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (canAssign)
{
    <div class="modal fade" id="excludeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-warning me-2"></i>Xác nhận loại bỏ sản phẩm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có chắc chắn muốn loại bỏ sản phẩm "<strong id="excludeProductName"></strong>" khỏi gói của khách hàng <strong>@(customer?.Full_name ?? "")</strong>?</p>
                    <p class="text-muted mb-0"><i class="fas fa-info-circle me-1"></i>Các khách hàng khác sử dụng gói này sẽ không bị ảnh hưởng.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <form id="excludeForm" method="post" asp-action="ExcludeProduct" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="customerPackageId" value="@customerPackage?.Id" />
                        <input type="hidden" name="customerId" value="@(customer?.Id ?? 0)" />
                        <input type="hidden" name="productId" id="excludeProductId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-ban me-1"></i>Loại bỏ
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    function confirmExclude(button) {
        var productId = button.getAttribute('data-product-id');
        var productName = button.getAttribute('data-product-name');
        document.getElementById('excludeProductName').textContent = productName;
        document.getElementById('excludeProductId').value = productId;
        new bootstrap.Modal(document.getElementById('excludeModal')).show();
    }
</script>
}
