@model List<ErpOnlineOrder.Application.DTOs.CustomerPackageDTOs.CustomerPackageDto>
@{
    ViewData["Title"] = "Gói sản phẩm của khách hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var customer = ViewBag.Customer as ErpOnlineOrder.Application.DTOs.CustomerDTO;
    var canAssign = (bool)(ViewBag.CanAssign ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-cubes me-2 text-primary"></i>Gói sản phẩm được phép đặt</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "CustomerManagement")">Khách hàng</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Details", "CustomerManagement", new { id = customer?.Id })">@(customer?.Full_name ?? "")</a></li>
                <li class="breadcrumb-item active">Gói sản phẩm</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        @if (canAssign)
        {
            <a href="@Url.Action("AssignPackages", new { customerId = customer?.Id })" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Gán gói sản phẩm
            </a>
        }
        <a href="@Url.Action("Details", "CustomerManagement", new { id = customer?.Id })" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

@if (customer != null)
{
    <div class="table-card mb-4">
        <div class="card-body p-3">
            <div>
                <strong>@customer.Full_name</strong>
                <span class="badge bg-secondary ms-2">@customer.Customer_code</span>
                <div class="small text-muted">@(customer.Phone_number ?? "")</div>
            </div>
        </div>
    </div>
}

<div class="table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>Danh sách gói sản phẩm (@Model.Count)</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fa-3x mb-3 d-block opacity-50"></i>
                <p class="mb-2">Chưa có gói sản phẩm nào được gán</p>
                <p class="small mb-0">Gán gói sản phẩm để cho phép khách hàng đặt hàng theo gói.</p>
                @if (canAssign)
                {
                    <a href="@Url.Action("AssignPackages", new { customerId = customer?.Id })" class="btn btn-primary mt-3">
                        <i class="fas fa-plus me-1"></i>Gán gói sản phẩm
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Mã gói</th>
                            <th>Tên gói</th>
                            <th>Ngày gán</th>
                            <th>Trạng thái</th>
                            @if (canAssign)
                            {
                                <th style="width: 150px;">Thao tác</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td><span class="badge bg-secondary">@item.Package_code</span></td>
                                <td><strong>@item.Package_name</strong></td>
                                <td>@item.Created_at.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Is_active)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Tạm khóa</span>
                                    }
                                </td>
                                @if (canAssign)
                                {
                                    <td>
                                        <form method="post" asp-action="ToggleActive" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="customerId" value="@item.Customer_id" />
                                            <button type="submit" class="btn btn-sm @(item.Is_active ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(item.Is_active ? "Tạm khóa" : "Kích hoạt")">
                                                <i class="fas @(item.Is_active ? "fa-pause" : "fa-play")"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Hủy gán"
                                                onclick="confirmUnassign(@item.Id, '@item.Package_name', @item.Customer_id)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Modal xác nhận hủy gán -->
<div class="modal fade" id="unassignModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-warning me-2"></i>Xác nhận hủy gán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn hủy gán gói "<strong id="unassignPackageName"></strong>" khỏi khách hàng này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="unassignForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="unassignCustomerId" name="customerId" value="" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Hủy gán
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmUnassign(id, packageName, customerId) {
        document.getElementById('unassignPackageName').textContent = packageName;
        document.getElementById('unassignCustomerId').value = customerId;
        document.getElementById('unassignForm').action = '@Url.Action("Unassign")/' + id;
        new bootstrap.Modal(document.getElementById('unassignModal')).show();
    }
</script>
}
