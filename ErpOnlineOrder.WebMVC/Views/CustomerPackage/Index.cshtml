@model PagedResult<ErpOnlineOrder.Application.DTOs.CustomerPackageDTOs.CustomerPackageDto>
@using ErpOnlineOrder.WebMVC.Extensions
@{
    ViewData["Title"] = "Quản lý khách hàng - gói sản phẩm";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var items = Model?.Items ?? new List<ErpOnlineOrder.Application.DTOs.CustomerPackageDTOs.CustomerPackageDto>();
    var canAssign = (bool)(ViewBag.CanAssign ?? false);
    var customers = ViewBag.Customers as List<ErpOnlineOrder.Application.DTOs.CustomerDTOs.CustomerSelectDto>
                    ?? new List<ErpOnlineOrder.Application.DTOs.CustomerDTOs.CustomerSelectDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-cubes me-2 text-primary"></i>Quản lý khách hàng - gói sản phẩm</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                <li class="breadcrumb-item active">Khách hàng - Gói sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>

<div class="table-card mb-4">
    <div class="card-header">
        <i class="fas fa-filter me-2"></i>Tìm kiếm
    </div>
    <div class="card-body p-4">
        <form asp-action="Index" method="get" id="filterForm">
            <input type="hidden" name="page" value="1" />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tìm kiếm</label>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                           placeholder="Tên khách hàng, mã gói, tên gói..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Số dòng/trang</label>
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                        <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-1"></i>Tìm kiếm
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo me-1"></i>Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>Danh sách khách hàng - gói sản phẩm (@(Model?.TotalCount ?? 0) bản ghi)</span>
        @if (canAssign)
        {
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#assignModal">
                <i class="fas fa-plus me-1"></i>Gán gói mới
            </button>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Khách hàng</th>
                        <th>Mã gói</th>
                        <th>Tên gói</th>
                        <th>Ngày gán</th>
                        <th>Trạng thái</th>
                        @if (canAssign)
                        {
                            <th style="width: 150px;">Thao tác</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="@(canAssign ? 7 : 6)" class="text-center py-4 text-muted">
                                <i class="fas fa-box-open fa-3x mb-3 d-block opacity-50"></i>
                                Không có bản ghi nào
                            </td>
                        </tr>
                    }
                    else
                    {
                        var stt = (Model!.Page - 1) * Model.PageSize;
                        @foreach (var cp in items)
                        {
                            stt++;
                            <tr>
                                <td>@stt</td>
                                <td>
                                    <strong>@cp.Customer_name</strong>
                                </td>
                                <td><span class="badge bg-secondary">@cp.Package_code</span></td>
                                <td>@cp.Package_name</td>
                                <td>@cp.Created_at.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (cp.Is_active)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Tạm khóa</span>
                                    }
                                </td>
                                @if (canAssign)
                                {
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                                                    data-bs-toggle="dropdown" data-bs-strategy="fixed" data-bs-offset="0,4" aria-expanded="false">
                                                <i class="fas fa-ellipsis-v"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <form asp-action="ToggleActive" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@cp.Id" />
                                                        <input type="hidden" name="customerId" value="@cp.Customer_id" />
                                                        <input type="hidden" name="returnToAll" value="true" />
                                                        <button type="submit" class="dropdown-item @(cp.Is_active ? "text-warning" : "text-success")">
                                                            <i class="fas @(cp.Is_active ? "fa-ban" : "fa-check") me-2"></i>
                                                            @(cp.Is_active ? "Tạm khóa" : "Kích hoạt")
                                                        </button>
                                                    </form>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <a href="@Url.Action("CustomerPackageProducts", "CustomerPackage", new { id = cp.Id })"
                                                       class="dropdown-item">
                                                        <i class="fas fa-boxes me-2"></i>Quản lý sản phẩm trong gói
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger"
                                                            onclick="confirmUnassign(@cp.Id, @cp.Customer_id, '@cp.Customer_name', '@cp.Package_name')">
                                                        <i class="fas fa-unlink me-2"></i>Hủy gán
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model != null && Model.TotalPages > 1)
        {
            ViewBag.PaginationItemLabel = "bản ghi";
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>

@if (canAssign)
{
    <div class="modal fade" id="assignModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-cubes me-2 text-primary"></i>Gán gói cho khách hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label fw-semibold">Chọn khách hàng</label>
                    <select id="selectCustomerId" class="form-select" style="max-height:300px;">
                        <option value="">-- Chọn khách hàng --</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.Id">@c.Full_name (@c.Customer_code)</option>
                        }
                    </select>
                    <div id="selectCustomerError" class="text-danger mt-1 d-none">Vui lòng chọn khách hàng.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="goToAssign()">
                        <i class="fas fa-arrow-right me-1"></i>Tiếp tục
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="unassignModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-danger me-2"></i>Xác nhận hủy gán</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có chắc chắn muốn hủy gán gói "<strong id="unassignPackageName"></strong>" khỏi khách hàng "<strong id="unassignCustomerName"></strong>"?</p>
                    <p class="text-muted mb-0">Hành động này không thể hoàn tác.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <form id="unassignForm" method="post" asp-action="Unassign" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="unassignId" />
                        <input type="hidden" name="customerId" id="unassignCustomerId" />
                        <input type="hidden" name="returnToAll" value="true" />
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-unlink me-1"></i>Hủy gán
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });

    function goToAssign() {
        var customerId = document.getElementById('selectCustomerId').value;
        if (!customerId) {
            document.getElementById('selectCustomerError').classList.remove('d-none');
            return;
        }
        window.location.href = '@Url.Action("AssignPackages", "CustomerPackage")' + '?customerId=' + customerId;
    }

    function confirmUnassign(id, customerId, customerName, packageName) {
        document.getElementById('unassignId').value = id;
        document.getElementById('unassignCustomerId').value = customerId;
        document.getElementById('unassignCustomerName').textContent = customerName;
        document.getElementById('unassignPackageName').textContent = packageName;
        new bootstrap.Modal(document.getElementById('unassignModal')).show();
    }
</script>
}
