@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<nav class="account-navbar" style="background: #fff; border-radius: 14px; border: 1.5px solid #e5e7eb; padding: 10px 16px; margin-bottom: 28px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div class="d-flex align-items-center flex-wrap gap-2" style="overflow-x: auto; white-space: nowrap; -webkit-overflow-scrolling: touch;">
        @* User info *@
        <div class="d-flex align-items-center me-3" style="padding: 10px 16px; min-width: fit-content;">
            <div style="width: 42px; height: 42px; background: linear-gradient(135deg, #e8f5e9, #c8e6c9); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
                <i class="fas fa-user" style="color: #1a7f37; font-size: 1rem;"></i>
            </div>
            <span style="font-weight: 700; color: #333; font-size: 1.05rem;">@Context.Session.GetString("FullName")</span>
        </div>

        <div style="width: 1.5px; height: 36px; background: #e0e0e0; margin: 0 6px; flex-shrink: 0;"></div>

        @* Nav items *@
        <a asp-controller="Shop" asp-action="Account"
           class="account-nav-item @(currentAction == "Account" && currentController == "Shop" ? "active" : "")"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 500; color: #555; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-home" style="font-size: 1rem;"></i>
            <span>Tổng quan</span>
        </a>

        <a asp-controller="Shop" asp-action="Orders"
           class="account-nav-item @(currentAction == "Orders" && currentController == "Shop" ? "active" : "")"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 500; color: #555; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-box" style="font-size: 1rem;"></i>
            <span>Đơn hàng</span>
        </a>

        <a asp-controller="Shop" asp-action="UpdateOrganization"
           class="account-nav-item @(currentAction == "UpdateOrganization" && currentController == "Shop" ? "active" : "")"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 500; color: #555; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-building" style="font-size: 1rem;"></i>
            <span>Đơn vị</span>
        </a>

        <a asp-controller="Shop" asp-action="Cart"
           class="account-nav-item @(currentAction == "Cart" && currentController == "Shop" ? "active" : "")"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 500; color: #555; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-shopping-cart" style="font-size: 1rem;"></i>
            <span>Giỏ hàng</span>
        </a>

        <a asp-controller="Shop" asp-action="ChangePassword"
           class="account-nav-item @(currentAction == "ChangePassword" && currentController == "Shop" ? "active" : "")"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 500; color: #555; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-key" style="font-size: 1rem;"></i>
            <span>Đổi mật khẩu</span>
        </a>

        <div style="flex: 1;"></div>

        <a asp-controller="Auth" asp-action="LogoutGet"
           class="account-nav-item"
           style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; text-decoration: none; font-size: 1rem; font-weight: 600; color: #e53935; transition: all 0.2s; white-space: nowrap;">
            <i class="fas fa-sign-out-alt" style="font-size: 1rem;"></i>
            <span>Đăng xuất</span>
        </a>
    </div>
</nav>
