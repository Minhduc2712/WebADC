                            <div class="small text-muted">@username</div>
                            <div class="fw-semibold">@fullName</div>
                            <span class="badge mt-1" style="background: var(--primary); color: white;">@roleDisplay</span>
                        </li>
                        <li><a class="dropdown-item py-2" href="@Url.Action("ChangePassword", "Auth")"><i class="fas fa-key me-2 text-secondary"></i> Đổi mật khẩu</a></li>
                        @if (Context.Session.HasPermission("SETTINGS_VIEW"))
                        {
                            <li><a class="dropdown-item py-2" href="@Url.Action("Index", "Setting")"><i class="fas fa-sliders-h me-2 text-secondary"></i> Cài đặt hệ thống</a></li>
                        }
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item py-2 text-danger">
                                    <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                                </button>
