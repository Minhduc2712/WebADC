@{
    var username = Context.Session.GetString("Username") ?? "Người dùng";
    var fullName = Context.Session.GetString("FullName") ?? username;
    var roles = Context.Session.GetString("Roles") ?? "";
    var roleDisplay = roles.Contains("ROLE_ADMIN") ? "Quản trị viên" : 
                      roles.Contains("ROLE_STAFF") ? "Nhân viên" : 
                      roles.Contains("ROLE_CUSTOMER") ? "Khách hàng" : "Người dùng";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-width: 260px;
            --primary: #4f46e5;
            --primary-dark: #4338ca;
            --primary-light: #e0e7ff;
            --sidebar-bg: #0f172a;
            --sidebar-hover: rgba(255,255,255,0.06);
            --sidebar-active: rgba(79, 70, 229, 0.2);
            --sidebar-text: rgba(255,255,255,0.9);
            --sidebar-muted: rgba(255,255,255,0.45);
            --content-bg: #f8fafc;
            --card-shadow: 0 1px 2px rgba(0,0,0,0.05);
            --card-shadow-hover: 0 8px 24px rgba(0,0,0,0.08);
        }
        body {
            font-family: 'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--content-bg);
            color: #1e293b;
        }
        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            z-index: 1000;
            overflow-y: auto;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .sidebar-header {
            padding: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .sidebar-header h4 {
            color: white;
            margin: 0;
            font-weight: 700;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-header .logo-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.35);
        }
        .sidebar-menu {
            padding: 16px 12px;
            list-style: none;
            margin: 0;
        }
        .sidebar-menu li {
            margin-bottom: 2px;
        }
        .sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--sidebar-text);
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.2s;
            font-size: 0.9375rem;
        }
        .sidebar-menu a:hover {
            background: var(--sidebar-hover);
            color: white;
        }
        .sidebar-menu a.active {
            background: var(--sidebar-active);
            color: #a5b4fc;
            font-weight: 500;
        }
        .sidebar-menu a i {
            width: 22px;
            margin-right: 12px;
            opacity: 0.9;
        }
        .menu-title {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--sidebar-muted);
            padding: 20px 16px 6px;
        }
        /* Submenu */
        .menu-item-toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            color: var(--sidebar-text);
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            border-radius: 10px;
            font-size: 0.9375rem;
        }
        .menu-item-toggle:hover {
            background: var(--sidebar-hover);
            color: white;
        }
        .menu-item-toggle .fa-chevron-down {
            transition: transform 0.25s;
            font-size: 0.7rem;
            opacity: 0.7;
        }
        .menu-item-toggle[aria-expanded="true"] .fa-chevron-down {
            transform: rotate(180deg);
        }
        .menu-item-toggle.active {
            background: var(--sidebar-active);
            color: #a5b4fc;
            font-weight: 500;
        }
        .submenu {
            list-style: none;
            margin: 0;
            padding: 4px 0 4px 8px;
            border-left: 2px solid rgba(255,255,255,0.1);
            margin-left: 22px;
        }
        .submenu li a {
            padding: 10px 16px 10px 12px;
            font-size: 0.875rem;
            border-radius: 8px;
        }
        .submenu li a i {
            width: 18px;
            margin-right: 10px;
            font-size: 0.8rem;
        }
        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }
        /* Top Navbar */
        .top-navbar {
            position: relative;
            z-index: 1050;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(12px);
            padding: 14px 28px;
            box-shadow: 0 1px 0 rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #f1f5f9;
        }
        .search-box {
            position: relative;
            width: 280px;
        }
        .search-box input {
            padding: 10px 16px 10px 40px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            width: 100%;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }
        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-light);
        }
        .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }
        .user-dropdown {
            display: flex;
            align-items: center;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 10px;
            transition: background 0.2s;
        }
        .user-dropdown:hover {
            background: #f1f5f9;
        }
        .top-navbar .dropdown {
            position: relative;
            z-index: 1100;
        }
        .top-navbar .dropdown-menu,
        .dropdown-menu.show {
            z-index: 9999 !important;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            font-weight: 600;
            font-size: 0.9rem;
        }
        /* Content Area */
        .content-wrapper {
            padding: 24px 28px 40px;
        }
        /* Stat Cards */
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--card-shadow);
            transition: all 0.25s;
            border: 1px solid #f1f5f9;
        }
        .stat-card:hover {
            box-shadow: var(--card-shadow-hover);
            transform: translateY(-2px);
        }
        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: white;
        }
        .stat-icon.blue { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .stat-icon.green { background: linear-gradient(135deg, #10b981, #059669); }
        .stat-icon.orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .stat-icon.red { background: linear-gradient(135deg, #ef4444, #dc2626); }
        /* Stat Cards - Compact (dùng chung) */
        .stat-card-compact {
            border-radius: 8px;
            padding: 0 !important;
            transition: transform 0.2s;
        }
        .stat-card-compact:hover { transform: translateY(-1px); }
        .stat-card-compact .card-body { padding: 0.5rem 0.75rem !important; }
        .stat-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; color: #6c757d; margin-bottom: 0.1rem; }
        .stat-value { font-size: 1.1rem; font-weight: 700; color: #2d3748; }
        .stat-icon-sm {
            width: 28px; height: 28px;
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem;
        }
        .stat-icon-sm.blue { background: linear-gradient(135deg, #3b82f6, #2563eb) !important; color: white !important; }
        .stat-icon-sm.green { background: linear-gradient(135deg, #10b981, #059669) !important; color: white !important; }
        .stat-icon-sm.orange { background: linear-gradient(135deg, #f59e0b, #d97706) !important; color: white !important; }
        .stat-icon-sm.red { background: linear-gradient(135deg, #ef4444, #dc2626) !important; color: white !important; }
        .stat-icon-sm.yellow { background: linear-gradient(135deg, #ffc107, #ff9800) !important; color: white !important; }
        /* Badge màu cam cho WaitingCustomer */
        .badge.bg-orange { background-color: #f97316 !important; color: #fff; }
        /* Table Cards */
        .table-card {
            background: white;
            border-radius: 14px;
            box-shadow: var(--card-shadow);
            overflow: visible;
            border: 1px solid #f1f5f9;
        }
        .table-card > :first-child {
            border-radius: 14px 14px 0 0;
        }
        .table-card > :last-child {
            border-radius: 0 0 14px 14px;
        }
        .table-card > :only-child {
            border-radius: 14px;
        }
        .table-card .card-header {
            background: #fafbfc;
            border-bottom: 1px solid #f1f5f9;
            padding: 18px 24px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #334155;
        }
        /* Buttons override */
        .btn-primary {
            background: var(--primary);
            border-color: var(--primary);
        }
        .btn-primary:hover {
            background: var(--primary-dark);
            border-color: var(--primary-dark);
        }
        .breadcrumb-item a { color: var(--primary); }
        .breadcrumb-item a:hover { text-decoration: underline; }
        /* Table styling */
        .table-card .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            color: #64748b;
            padding: 14px 20px;
            border-bottom: 1px solid #e2e8f0;
        }
        .table-card .table tbody td {
            padding: 14px 20px;
            vertical-align: middle;
        }
        .table-card .table tbody tr:hover {
            background: #f8fafc;
        }
        .table-card .table .btn-group-sm .btn {
            border-radius: 8px;
        }
        /* ===== Detail Info Sections ===== */
        .table-card .card-body {
            padding: 20px 24px;
        }
        .table-card .card-body.p-0 {
            padding: 0 !important;
        }
        /* info-row: horizontal label + value rows for detail pages */
        .info-row {
            display: flex;
            align-items: flex-start;
            padding: 10px 0;
            border-bottom: 1px solid #f1f5f9;
            gap: 16px;
        }
        .info-row:last-child { border-bottom: none; }
        .info-label {
            flex-shrink: 0;
            width: 140px;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #94a3b8;
            padding-top: 2px;
            line-height: 1.4;
        }
        .info-value {
            flex: 1;
            font-weight: 500;
            color: #1e293b;
            font-size: 0.875rem;
            word-break: break-word;
            line-height: 1.5;
        }
        /* Table action dropdowns - float above table */
        .table .dropdown-menu {
            max-height: 260px;
            overflow-y: auto;
            overflow-x: hidden;
            min-width: 170px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            border: 1px solid #e2e8f0;
            border-radius: 10px;
        }
        .table .dropdown-menu .dropdown-item {
            font-size: 0.875rem;
            padding: 8px 16px;
        }
        .table .dropdown-menu .dropdown-item:hover {
            background: #f1f5f9;
        }
        .table .dropdown-menu::-webkit-scrollbar {
            width: 4px;
        }
        .table .dropdown-menu::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        .table .dropdown-menu::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        /* Form controls in content */
        .content-wrapper .form-control, .content-wrapper .form-select {
            border-radius: 10px;
            border-color: #e2e8f0;
        }
        .content-wrapper .form-control:focus, .content-wrapper .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-light);
        }
        /* Card in pages using shadow-sm */
        .content-wrapper .card.shadow-sm {
            border-radius: 14px;
            border: 1px solid #f1f5f9;
        }
        .content-wrapper .card {
            border-radius: 14px;
            border: 1px solid #f1f5f9;
        }
        .text-indigo { color: #4f46e5 !important; }
        .btn-outline-primary { border-color: #4f46e5; color: #4f46e5; }
        .btn-outline-primary:hover { background: #4f46e5; border-color: #4f46e5; color: white; }

        /* ===== MOBILE TOGGLE BUTTON ===== */
        .sidebar-toggle {
            display: none;
            background: none;
            border: none;
            color: #334155;
            font-size: 1.25rem;
            padding: 6px 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
        }
        .sidebar-toggle:hover { background: #f1f5f9; }

        /* ===== SIDEBAR OVERLAY ===== */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 999;
        }
        .sidebar-overlay.active { display: block; }

        /* ===== RESPONSIVE: TABLET (<=1024px) ===== */
        @@media (max-width: 1024px) {
            :root { --sidebar-width: 220px; }
            .content-wrapper { padding: 20px 16px 32px; }
            .top-navbar { padding: 12px 16px; }
            .search-box { width: 200px; }
            .table-card .table thead th,
            .table-card .table tbody td { padding: 10px 12px; font-size: 0.85rem; }
        }

        /* ===== RESPONSIVE: MOBILE (<=768px) ===== */
        @@media (max-width: 768px) {
            .sidebar-toggle { display: block; }
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
                z-index: 1100;
            }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0 !important; }
            .top-navbar { padding: 10px 12px; }
            .search-box { width: 100%; max-width: 180px; }
            .search-box input { padding: 8px 12px 8px 36px; font-size: 0.85rem; }
            .content-wrapper { padding: 16px 12px 24px; }
            .content-wrapper h4 { font-size: 1.1rem; }
            /* Stack header actions */
            .d-flex.justify-content-between.align-items-center.mb-4 {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 12px;
            }
            .d-flex.justify-content-between.align-items-center.mb-4 .d-flex.gap-2 {
                width: 100%;
                flex-wrap: wrap;
            }
            .d-flex.justify-content-between.align-items-center.mb-4 .d-flex.gap-2 .btn {
                flex: 1;
                min-width: 0;
                font-size: 0.8rem;
                white-space: nowrap;
            }
            /* Stats grid */
            .row .col-md-3, .row .col-md-4 { flex: 0 0 50%; max-width: 50%; }
            .stat-card { padding: 14px; }
            .stat-icon { width: 40px; height: 40px; font-size: 1rem; }
            /* Table responsive */
            .table-card .table thead th,
            .table-card .table tbody td { padding: 8px 8px; font-size: 0.8rem; }
            .table-card .table .btn-group-sm .btn { padding: 4px 6px; font-size: 0.75rem; }
            /* Filter form */
            .table-card .card-body.p-4 { padding: 12px !important; }
            /* User dropdown */
            .user-dropdown > div:not(.user-avatar) { display: none; }
            .user-dropdown .fa-chevron-down { display: none; }
            .user-avatar { margin-right: 0; }
        }

        /* ===== RESPONSIVE: SMALL MOBILE (<=480px) ===== */
        @@media (max-width: 480px) {
            .search-box { display: none; }
            .content-wrapper { padding: 12px 8px 20px; }
            .content-wrapper h4 { font-size: 1rem; }
            .breadcrumb { font-size: 0.75rem; }
            /* Stack stats vertically */
            .row .col-md-3, .row .col-md-4, .row .col-sm-6 { flex: 0 0 100%; max-width: 100%; }
            /* Table scroll */
            .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
            .table-card .table { min-width: 600px; }
            /* Full width buttons */
            .d-flex.justify-content-between.align-items-center.mb-4 .d-flex.gap-2 .btn { flex: 1 1 100%; }
            .btn-group.btn-group-sm { flex-wrap: nowrap; }
            .btn-group.btn-group-sm .btn { padding: 3px 5px; }
            /* Form inputs */
            .row.g-3 > div { flex: 0 0 100% !important; max-width: 100% !important; }
            /* Modal */
            .modal-dialog { margin: 8px; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <h4>
                <span class="logo-icon"><i class="fas fa-cube"></i></span>
                ERP System
            </h4>
        </div>
        <ul class="sidebar-menu">
            <li class="menu-title">CHÍNH</li>
            <li><a href="@Url.Action("Index", "Order")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fas fa-home"></i> Trang chủ</a></li>
            
            @* QUẢN LÝ - Hiển thị nếu có ít nhất 1 quyền VIEW *@
            @if (Context.Session.HasAnyPermission("PRODUCT_VIEW", "ORDER_VIEW", "CUSTOMER_VIEW", "CUSTOMER_ASSIGN", "CUSTOMER_PRODUCT_VIEW", "INVOICE_VIEW", "CUSTOMER_PACKAGE_VIEW"))
            {
                <li class="menu-title">QUẢN LÝ</li>
                
                @if (Context.Session.HasPermission("CUSTOMER_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "CustomerManagement")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "CustomerManagement" && ViewContext.RouteData.Values["action"]?.ToString() != "StaffAssignment" ? "active" : "")"><i class="fas fa-users"></i> Khách hàng</a></li>
                }
                
                @if (Context.Session.HasPermission("ORDER_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Order")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"><i class="fas fa-shopping-cart"></i> Đơn hàng</a></li>
                }
                
                @if (Context.Session.HasPermission("PRODUCT_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Product")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"><i class="fas fa-box"></i> Sản phẩm</a></li>
                }
                @if (Context.Session.HasPermission("STAFF_REGION_RULE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "StaffRegionRule")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "StaffRegionRule" ? "active" : "")"><i class="fas fa-map-marked-alt"></i> Phân công theo vùng</a></li>
                }
                
                @if (Context.Session.HasPermission("INVOICE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Invoice")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"><i class="fas fa-file-invoice"></i> Hóa đơn</a></li>
                }
                @if (Context.Session.HasPermission("CUSTOMER_PACKAGE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "CustomerPackage")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "CustomerPackage" ? "active" : "")"><i class="fas fa-user-tag"></i> Gói khách hàng</a></li>
                }
            }
            
            @* QUẢN LÝ XUẤT KHO - Phiếu xuất kho *@
            @if (Context.Session.HasPermission("WAREHOUSE_EXPORT_VIEW"))
            {
                <li class="menu-title">QUẢN LÝ XUẤT KHO</li>
                <li><a href="@Url.Action("Index", "WarehouseExport")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "WarehouseExport" ? "active" : "")"><i class="fas fa-truck-loading"></i> Phiếu xuất kho</a></li>
            }

            @if (Context.Session.HasPermission("STOCK_VIEW"))
            {
                <li><a href="@Url.Action("Index", "Stock")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")"><i class="fas fa-boxes"></i> Tồn kho</a></li>
            }
            
            @* NHÂN SỰ - Hiển thị nếu có quyền STAFF_VIEW *@
            @if (Context.Session.HasPermission("STAFF_VIEW"))
            {
                <li class="menu-title">NHÂN SỰ</li>
                <li><a href="@Url.Action("Index", "Staff")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" ? "active" : "")"><i class="fas fa-users-cog"></i> Quản lý nhân sự</a></li>
            }
            
            @* DANH MỤC CHUNG - Mỗi danh mục 1 menu nav, 1 màn CRUD riêng *@
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            }
            @if (Context.Session.HasAnyPermission("CATEGORY_VIEW", "DISTRIBUTOR_VIEW", "REGION_VIEW", "PROVINCE_VIEW", "WAREHOUSE_VIEW", "PACKAGE_VIEW"))
            {
                <li class="menu-title">DANH MỤC CHUNG</li>
                @if (Context.Session.HasPermission("CATEGORY_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Category")" class="@(controller == "Category" ? "active" : "")"><i class="fas fa-tags"></i> Thể loại</a></li>
                }
                @if (Context.Session.HasPermission("CATEGORY_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Author")" class="@(controller == "Author" ? "active" : "")"><i class="fas fa-user-edit"></i> Tác giả</a></li>
                }
                @if (Context.Session.HasPermission("CATEGORY_VIEW"))
