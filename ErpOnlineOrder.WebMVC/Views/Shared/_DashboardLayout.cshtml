            @* HỆ THỐNG - Mỗi chức năng 1 nav riêng *@
            @if (Context.Session.HasPermission("ROLE_VIEW") || Context.Session.HasPermission("ROLE_ASSIGN") || Context.Session.HasPermission("PERMISSION_VIEW") || Context.Session.HasPermission("PERMISSION_ASSIGN") || Context.Session.HasPermission("SETTINGS_VIEW"))
            {
                <li class="menu-title">HỆ THỐNG</li>
                @if (Context.Session.HasPermission("ROLE_VIEW") || Context.Session.HasPermission("ROLE_ASSIGN"))
                {
                    <li><a href="@Url.Action("Index", "Role")" class="@(controller == "Role" ? "active" : "")"><i class="fas fa-user-shield"></i> Phân quyền Role</a></li>
                }
                @if (Context.Session.HasPermission("PERMISSION_ASSIGN"))
                {
                    <li><a href="@Url.Action("UserPermissions", "Permission")" class="@(controller == "Permission" && (ViewContext.RouteData.Values["action"]?.ToString() == "UserPermissions" || ViewContext.RouteData.Values["action"]?.ToString() == "UserPermissionDetails") ? "active" : "")"><i class="fas fa-user-tag"></i> Gán quyền User</a></li>
                }
                @if (Context.Session.HasPermission("PERMISSION_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Permission")" class="@(controller == "Permission" && ViewContext.RouteData.Values["action"]?.ToString() != "UserPermissions" && ViewContext.RouteData.Values["action"]?.ToString() != "UserPermissionDetails" ? "active" : "")"><i class="fas fa-list"></i> Quản lý quyền</a></li>
