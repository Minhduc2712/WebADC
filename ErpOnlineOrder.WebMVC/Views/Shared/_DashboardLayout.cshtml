                }
                @if (Context.Session.HasPermission("CATEGORY_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "CoverType")" class="@(controller == "CoverType" ? "active" : "")"><i class="fas fa-book"></i> Loại bìa</a></li>
                }
                @if (Context.Session.HasPermission("REGION_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Region")" class="@(controller == "Region" ? "active" : "")"><i class="fas fa-map"></i> Khu vực</a></li>
                }
                @if (Context.Session.HasPermission("PROVINCE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Province")" class="@(controller == "Province" ? "active" : "")"><i class="fas fa-map-marker-alt"></i> Tỉnh thành</a></li>
                }
                @if (Context.Session.HasPermission("DISTRIBUTOR_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Distributor")" class="@(controller == "Distributor" ? "active" : "")"><i class="fas fa-truck"></i> Nhà phân phối</a></li>
                }
                @if (Context.Session.HasPermission("WAREHOUSE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Warehouse")" class="@(controller == "Warehouse" ? "active" : "")"><i class="fas fa-warehouse"></i> Kho hàng</a></li>
                }
                @if (Context.Session.HasPermission("PACKAGE_VIEW"))
                {
                    <li><a href="@Url.Action("Index", "Package")" class="@(controller == "Package" ? "active" : "")"><i class="fas fa-cube"></i> Gói sản phẩm</a></li>
                }
