        <!-- Content -->
        <div class="content-wrapper">
            <!-- Thông báo tự động từ TempData -->
            <partial name="_NotificationPartial" />
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ===== Table Dropdown – Fixed Positioning =====
        // Bootstrap 5.3 does NOT support data-bs-strategy; must use popperConfig via JS.
        // .table-responsive has overflow-x:auto which also clips overflow-y, so we
        // pre-initialise all table dropdowns with strategy:'fixed' so Popper uses
        // position:fixed and the menu escapes the overflow container completely.
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.table .dropdown-toggle').forEach(function (el) {
                new bootstrap.Dropdown(el, {
                    popperConfig: { strategy: 'fixed' }
                });
            });
        });
    </script>
    <script>
        (function() {
            var SIDEBAR_SCROLL_KEY = 'erp_sidebar_scroll';
            var sidebar = document.querySelector('.sidebar');
            if (!sidebar) return;

            function saveScroll() {
                try { sessionStorage.setItem(SIDEBAR_SCROLL_KEY, sidebar.scrollTop); } catch (e) {}
            }

            function restoreScroll() {
                try {
                    var saved = sessionStorage.getItem(SIDEBAR_SCROLL_KEY);
                    if (saved !== null) sidebar.scrollTop = parseInt(saved, 10);
                } catch (e) {}
            }

            var scrollTimeout;
            sidebar.addEventListener('scroll', function() {
                clearTimeout(scrollTimeout);
                scrollTimeout = setTimeout(saveScroll, 100);
            }, { passive: true });

            sidebar.querySelectorAll('a[href]').forEach(function(link) {
                link.addEventListener('click', saveScroll);
            });

            restoreScroll();
        })();

        // ===== Sidebar Toggle (Mobile) =====
        (function() {
            var sidebar = document.querySelector('.sidebar');
            var toggle = document.getElementById('sidebarToggle');
            var overlay = document.getElementById('sidebarOverlay');
            if (!sidebar || !toggle || !overlay) return;

            function openSidebar() {
                sidebar.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            function closeSidebar() {
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            toggle.addEventListener('click', function() {
                sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
            });
            overlay.addEventListener('click', closeSidebar);

            // Close sidebar when clicking a menu link on mobile
            sidebar.querySelectorAll('a[href]').forEach(function(link) {
                link.addEventListener('click', function() {
                    if (window.innerWidth <= 768) closeSidebar();
                });
            });

            // Close on resize to desktop
            window.addEventListener('resize', function() {
                if (window.innerWidth > 768) closeSidebar();
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
