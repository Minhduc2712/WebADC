@model ErpOnlineOrder.Application.DTOs.CustomerDTOs.UpdateOrganizationByCustomerDto
@{
    ViewData["Title"] = "Cập Nhật Thông Tin Tổ Chức";
    var organizations = ViewBag.Organizations as List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO> ?? new List<ErpOnlineOrder.Application.DTOs.OrganizationDTOs.OrganizationDTO>();
}

<div class="container mt-4">
    <h2><i class="fas fa-building me-2"></i>@ViewData["Title"]</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success"><i class="fas fa-check-circle me-1"></i>@TempData["SuccessMessage"]</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
        </div>
    }

    <form asp-action="UpdateOrganization" method="post" class="card p-4 shadow-sm">
        @Html.AntiForgeryToken()
        <input asp-for="Customer_id" type="hidden" />

        <div class="mb-3">
            <label asp-for="Organization_information_id" class="form-label fw-semibold">
                Đơn vị <span class="text-danger">*</span>
            </label>
            <select asp-for="Organization_information_id" class="form-select">
                <option value="0">-- Chọn đơn vị --</option>
                @foreach (var org in organizations)
                {
                    <option value="@org.Id" selected="@(Model.Organization_information_id == org.Id)">
                        @org.Organization_name (@org.Organization_code)
                    </option>
                }
            </select>
            <span asp-validation-for="Organization_information_id" class="text-danger small"></span>
        </div>

        <hr />
        <h5 class="mb-3">Thông tin người nhận hàng</h5>

        <div class="mb-3">
            <label asp-for="Recipient_name" class="form-label fw-semibold">Tên người nhận hàng</label>
            <input asp-for="Recipient_name" class="form-control" placeholder="Nhập tên người nhận hàng" />
            <span asp-validation-for="Recipient_name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Recipient_phone" class="form-label fw-semibold">
                Số điện thoại nhận hàng <span class="text-danger">*</span>
            </label>
            <input asp-for="Recipient_phone" class="form-control" placeholder="Nhập số điện thoại nhận hàng" />
            <span asp-validation-for="Recipient_phone" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Recipient_address" class="form-label fw-semibold">Địa chỉ nhận hàng</label>
            <input asp-for="Recipient_address" class="form-control" placeholder="Nhập địa chỉ nhận hàng" />
            <span asp-validation-for="Recipient_address" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i>Cập Nhật
            </button>
            <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">Quay Lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
