@model PagedResult<ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.WarehouseExportDto>
@using ErpOnlineOrder.Domain.Constants
@{
    ViewData["Title"] = "Quản lý xuất kho";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var items = Model?.Items ?? new List<ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.WarehouseExportDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Quản lý xuất kho</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item active">Xuất kho</li>
            </ol>
        </nav>
    </div>
    <div>
        @if (Context.Session.HasPermission("WAREHOUSE_CREATE"))
        {
            <a href="@Url.Action("Create")" class="btn btn-primary me-2">
                <i class="fas fa-plus me-1"></i>Tạo phiếu xuất
            </a>
        }
        @if (Context.Session.HasPermission("WAREHOUSE_UPDATE"))
        {
            <a href="@Url.Action("Merge")" class="btn btn-outline-primary me-2">
                <i class="fas fa-compress-arrows-alt me-1"></i>Gộp phiếu
            </a>
        }
        <a href="@Url.Action("ExportExcel", new { status = ViewBag.Status })" class="btn btn-success">
            <i class="fas fa-file-excel me-1"></i>Xuất Excel
        </a>
    </div>
</div>

<!-- Bộ lọc -->
<div class="table-card mb-4">
    <div class="card-header">
        <i class="fas fa-filter me-2"></i>Bộ lọc
    </div>
    <div class="card-body p-4">
        <form asp-action="Index" method="get" id="filterForm">
            <input type="hidden" name="page" value="1" />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả --</option>
                        <option value="Draft" selected="@(ViewBag.Status == "Draft")">Nháp</option>
                        <option value="Pending" selected="@(ViewBag.Status == "Pending")">Chờ xuất</option>
                        <option value="Confirmed" selected="@(ViewBag.Status == "Confirmed")">Đã xác nhận</option>
                        <option value="Shipping" selected="@(ViewBag.Status == "Shipping")">Đang giao</option>
                        <option value="Completed" selected="@(ViewBag.Status == "Completed")">Hoàn thành</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Số dòng/trang</label>
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                        <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-1"></i>Lọc
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="fas fa-redo me-1"></i>Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Thống kê nhanh - Compact -->
<div class="row mb-2 g-2">
    @{
        var pending = items.Count(e => e.Status == "Pending");
        var shipping = items.Count(e => e.Status == "Shipping");
        var completed = items.Count(e => e.Status == "Completed");
        var totalQuantity = items.Sum(e => e.Total_quantity);
    }
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Tổng phiếu</div>
                    <div class="stat-value">@(Model?.TotalCount ?? 0)</div>
                </div>
                <div class="stat-icon-sm blue"><i class="fas fa-warehouse"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Chờ xuất</div>
                    <div class="stat-value">@pending</div>
                </div>
                <div class="stat-icon-sm yellow"><i class="fas fa-clock"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Đang giao</div>
                    <div class="stat-value">@shipping</div>
                </div>
                <div class="stat-icon-sm orange"><i class="fas fa-truck"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card-compact shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-1 px-2">
                <div>
                    <div class="stat-label">Hoàn thành</div>
                    <div class="stat-value">@completed</div>
                </div>
                <div class="stat-icon-sm green"><i class="fas fa-check-double"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách phiếu xuất kho -->
<div class="table-card">
    <div class="card-header">
        <i class="fas fa-warehouse me-2"></i>Danh sách phiếu xuất kho (@(Model?.TotalCount ?? 0) phiếu)
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã phiếu</th>
                        <th>Hóa đơn</th>
                        <th>Khách hàng</th>
                        <th>Kho</th>
                        <th>Ngày xuất</th>
                        <th>Ngày đến</th>
                        <th class="text-center">Số SP</th>
                        <th>Trạng thái</th>
                        <th>Giao hàng</th>
                        <th style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                Không có phiếu xuất kho nào
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var export in items.OrderByDescending(e => e.Export_date))
                        {
                            var statusClass = ErpOnlineOrder.Domain.Constants.ExportStatuses.ToCssClass(export.Status);
                            var statusText = ErpOnlineOrder.Domain.Constants.ExportStatuses.ToDisplayText(export.Status);
                            var deliveryClass = ErpOnlineOrder.Domain.Constants.DeliveryStatuses.ToCssClass(export.Delivery_status);
                            var deliveryText = ErpOnlineOrder.Domain.Constants.DeliveryStatuses.ToDisplayText(export.Delivery_status);
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@export.Warehouse_export_code</span>
                                    @if (export.Parent_export_id.HasValue)
                                    {
                                        <br /><small class="text-muted">Từ: @export.Parent_export_code</small>
                                    }
                                </td>
                                <td><span class="badge bg-info">@export.Invoice_code</span></td>
                                <td>@export.Customer_name</td>
                                <td>@export.Warehouse_name</td>
                                <td>@export.Export_date.ToString("dd/MM/yyyy")</td>
                                <td>@(export.Arrival_date?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td class="text-center"><span class="badge bg-primary">@export.Total_quantity</span></td>
                                <td>
                                    @{
                                        var allowedExport = ExportStatuses.AllowedTransitions.TryGetValue(export.Status, out var et) ? et : Array.Empty<string>();
                                    }
                                    <span class="badge @statusClass">@statusText</span>
                                    @if (allowedExport.Length > 0)
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="mt-1" style="min-width:140px" onsubmit="return confirm('Xác nhận chuyển trạng thái?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@export.Id" />
                                            <div class="input-group input-group-sm">
                                                <select name="status" class="form-select form-select-sm">
                                                    @foreach (var ns in allowedExport)
                                                    {
                                                        <option value="@ns">@ExportStatuses.ToDisplayText(ns)</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-sync-alt"></i></button>
                                            </div>
                                        </form>
                                    }
                                </td>
                                <td>
                                    @{
                                        var allowedDelivery = DeliveryStatuses.AllowedTransitions.TryGetValue(export.Delivery_status, out var dt) ? dt : Array.Empty<string>();
                                    }
                                    <span class="badge @deliveryClass">@deliveryText</span>
                                    @if (allowedDelivery.Length > 0 && export.Status != ExportStatuses.Cancelled)
                                    {
                                        <form asp-action="UpdateDeliveryStatus" method="post" class="mt-1" style="min-width:140px" onsubmit="return confirm('Xác nhận chuyển trạng thái giao hàng?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@export.Id" />
                                            <div class="input-group input-group-sm">
                                                <select name="status" class="form-select form-select-sm">
                                                    @foreach (var ns in allowedDelivery)
                                                    {
                                                        <option value="@ns">@DeliveryStatuses.ToDisplayText(ns)</option>
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-info btn-sm"><i class="fas fa-sync-alt"></i></button>
                                            </div>
                                        </form>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@export.Id" class="btn btn-outline-primary" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (export.Status == ExportStatuses.Draft && Context.Session.HasPermission("WAREHOUSE_UPDATE"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@export.Id" class="btn btn-outline-warning" title="Chỉnh sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        }
                                        @if (export.Status == "Pending")
                                        {
                                            <button type="button" class="btn btn-outline-success" title="Xác nhận"
                                                    onclick="confirmAction(@export.Id, 'confirm', '@export.Warehouse_export_code')">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        }
                                        @if (export.Status != "Completed" && export.Status != "Cancelled" && export.Details.Count > 1)
                                        {
                                            <a asp-action="Split" asp-route-id="@export.Id" class="btn btn-outline-info" title="Tách phiếu">
                                                <i class="fas fa-expand-arrows-alt"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model != null && Model.TotalPages > 1)
        {
            ViewBag.PaginationItemLabel = "phiếu";
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>

<!-- Modal xác nhận -->
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="modalMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="actionForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmAction(id, action, code) {
        document.getElementById('modalTitle').innerHTML = '<i class="fas fa-check-circle text-success me-2"></i>Xác nhận xuất kho';
        document.getElementById('modalMessage').innerHTML = 'Bạn có chắc chắn muốn xác nhận phiếu xuất kho <strong>' + code + '</strong>?';
        document.getElementById('actionForm').action = '@Url.Action("Confirm")/' + id;
        new bootstrap.Modal(document.getElementById('actionModal')).show();
    }
</script>
}
