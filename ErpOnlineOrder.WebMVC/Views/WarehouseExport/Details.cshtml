@model ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.WarehouseExportDto
@using ErpOnlineOrder.Domain.Constants
@{
    ViewData["Title"] = "Chi tiết phiếu xuất kho";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var statusClass = ExportStatuses.ToCssClass(Model.Status);
    var statusText = ExportStatuses.ToDisplayText(Model.Status);
    var canUpdate = (bool)(ViewBag.CanUpdate ?? false);
    var allowedTransitions = ExportStatuses.AllowedTransitions.TryGetValue(Model.Status, out var transitions)
        ? transitions : Array.Empty<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Chi tiết phiếu xuất kho</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Xuất kho</a></li>
                <li class="breadcrumb-item active">@Model.Warehouse_export_code</li>
            </ol>
        </nav>
    </div>
    <div>
        @if (Model.Status == ExportStatuses.Draft)
        {
            @if (canUpdate)
            {
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary me-2">
                    <i class="fas fa-edit me-1"></i>Chỉnh sửa
                </a>
            }
            <form asp-action="Confirm" asp-route-id="@Model.Id" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success me-2">
                    <i class="fas fa-check me-1"></i>Xác nhận
                </button>
            </form>
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger me-2">
                    <i class="fas fa-times me-1"></i>Hủy
                </button>
            </form>
        }
        @if (Model.Status != ExportStatuses.Completed && Model.Status != ExportStatuses.Cancelled && Model.Details.Count > 1)
        {
            <a href="@Url.Action("Split", new { id = Model.Id })" class="btn btn-info me-2">
                <i class="fas fa-expand-arrows-alt me-1"></i>Tách phiếu
            </a>
        }
        @if (Model.Status == ExportStatuses.Split)
        {
            <form asp-action="UndoSplit" asp-route-id="@Model.Id" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn hoàn tác tách phiếu xuất kho?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning me-2">
                    <i class="fas fa-undo me-1"></i>Hoàn tác tách
                </button>
            </form>
        }
        @if (Model.Warehouse_export_code.StartsWith("EXP-M-"))
        {
            <form asp-action="UndoMerge" asp-route-id="@Model.Id" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn hoàn tác gộp phiếu xuất kho?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning me-2">
                    <i class="fas fa-undo me-1"></i>Hoàn tác gộp
                </button>
            </form>
        }
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-info-circle me-2"></i>Thông tin phiếu
            </div>
            <div class="card-body">
                <div class="info-row">
                    <span class="info-label">Mã phiếu xuất</span>
                    <span class="info-value fw-semibold">@Model.Warehouse_export_code</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Trạng thái</span>
                    <span class="info-value">
                        <span class="badge @statusClass">@statusText</span>
                        @if (canUpdate && allowedTransitions.Length > 0)
                        {
                            <form asp-action="UpdateStatus" method="post" class="mt-2" onsubmit="return confirm('Bạn có chắc muốn chuyển trạng thái?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <div class="input-group input-group-sm">
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (var nextStatus in allowedTransitions)
                                        {
                                            <option value="@nextStatus">@ExportStatuses.ToDisplayText(nextStatus)</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                            </form>
                        }
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Ngày xuất</span>
                    <span class="info-value">@Model.Export_date.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Ngày vận chuyển</span>
                    <span class="info-value">@(Model.Arrival_date?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Kho xuất</span>
                    <span class="info-value">@Model.Warehouse_name</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Hóa đơn LQ</span>
                    <span class="info-value">
                        @if (!string.IsNullOrEmpty(Model.Invoice_code))
                        {
                            <span class="badge bg-info text-dark">@Model.Invoice_code</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </span>
                </div>
                @if (Model.Parent_export_id.HasValue)
                {
                    <div class="info-row">
                        <span class="info-label">Phiếu gốc</span>
                        <span class="info-value">
                            <a href="@Url.Action("Details", new { id = Model.Parent_export_id })">
                                @Model.Parent_export_code
                            </a>
                        </span>
                    </div>
                }
            </div>
        </div>
        
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-user me-2"></i>Thông tin khách hàng
            </div>
            <div class="card-body">
                <div class="info-row">
                    <span class="info-label">Khách hàng</span>
                    <span class="info-value fw-semibold">@Model.Customer_name</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Nhân viên xuất</span>
                    <span class="info-value">@Model.Staff_name</span>
                </div>
            </div>
        </div>
        
        <div class="table-card mb-4">
            <div class="card-header">
                <i class="fas fa-truck me-2"></i>Thông tin giao hàng
            </div>
            <div class="card-body">
                @{
                    var deliveryClass = DeliveryStatuses.ToCssClass(Model.Delivery_status);
                    var deliveryText = DeliveryStatuses.ToDisplayText(Model.Delivery_status);
                    var allowedDeliveryTransitions = DeliveryStatuses.AllowedTransitions.TryGetValue(Model.Delivery_status, out var dTransitions)
                        ? dTransitions : Array.Empty<string>();
                }
                <div class="info-row">
                    <span class="info-label">Trạng thái</span>
                    <span class="info-value">
                        <span class="badge @deliveryClass">@deliveryText</span>
                        @if (canUpdate && allowedDeliveryTransitions.Length > 0 && Model.Status != ExportStatuses.Cancelled)
                        {
                            <form asp-action="UpdateDeliveryStatus" asp-route-id="@Model.Id" method="post" class="mt-2" onsubmit="return confirm('Bạn có chắc muốn chuyển trạng thái giao hàng?');">
                                @Html.AntiForgeryToken()
                                <div class="input-group input-group-sm">
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (var nextDelivery in allowedDeliveryTransitions)
                                        {
                                            <option value="@nextDelivery">@DeliveryStatuses.ToDisplayText(nextDelivery)</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-info btn-sm">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                            </form>
                        }
                    </span>
                </div>
            </div>
        </div>
        
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-calculator me-2"></i>Tổng kết
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tổng số sản phẩm:</span>
                    <span class="fw-semibold">@Model.Total_quantity</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Tổng giá trị:</span>
                    <span class="text-success fw-bold">@Model.Total_amount.ToString("N0") VNĐ</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-list me-2"></i>Chi tiết xuất kho (@Model.Details.Count sản phẩm)
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Mã SP</th>
                                <th>Tên sản phẩm</th>
                                <th class="text-center">SL xuất</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var index = 1;
                            }
                            @foreach (var detail in Model.Details)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td><span class="badge bg-secondary">@detail.Product_code</span></td>
                                    <td>@detail.Product_name</td>
                                    <td class="text-center">@detail.Quantity_shipped</td>
                                    <td class="text-end">@detail.Unit_price.ToString("N0")</td>
                                    <td class="text-end fw-semibold">@detail.Total_price.ToString("N0")</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-center fw-bold">@Model.Total_quantity</td>
                                <td></td>
                                <td class="text-end text-success fw-bold">@Model.Total_amount.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
        
        @if (Model.Child_exports.Any())
        {
            <div class="table-card mt-4">
                <div class="card-header">
                    <i class="fas fa-project-diagram me-2"></i>Phiếu con (đã tách)
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã phiếu</th>
                                    <th>Ngày xuất</th>
                                    <th class="text-center">Số SP</th>
                                    <th>Trạng thái</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var child in Model.Child_exports)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@child.Warehouse_export_code</span></td>
                                        <td>@child.Export_date.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@child.Total_quantity</td>
                                        <td><span class="badge bg-info">@child.Status</span></td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@child.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
