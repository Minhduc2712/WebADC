@model ErpOnlineOrder.Application.DTOs.WarehouseExportDTOs.UpdateWarehouseExportDto
@{
    ViewData["Title"] = "Chỉnh sửa phiếu xuất kho";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid">
    <div class="mb-4">
        <h4 class="mb-0">Chỉnh sửa phiếu xuất kho</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Order")">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index")">Xuất kho</a></li>
                <li class="breadcrumb-item active">@ViewBag.ExportCode</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0"><i class="fas fa-edit me-2"></i>Thông tin cần chỉnh sửa</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Kho xuất <span class="text-danger">*</span></label>
                            <select asp-for="Warehouse_id" class="form-select" asp-items="ViewBag.Warehouses" required>
                                <option value="">-- Chọn kho --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ngày xuất <span class="text-danger">*</span></label>
                            <input asp-for="Export_date" class="form-control" type="date" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ngày vận chuyển đến</label>
                            <input asp-for="Arrival_date" class="form-control" type="date" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ghi chú</label>
                            <textarea asp-for="Split_merge_note" class="form-control" rows="3" placeholder="Nhập ghi chú (nếu có)"></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Details" asp-route-id="@ViewBag.ExportId" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Quy tắc chỉnh sửa</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-0">
                        <ul class="mb-0">
                            <li>Chỉ chỉnh sửa được phiếu xuất kho ở trạng thái Nháp.</li>
                            <li>Không thay đổi hóa đơn liên kết để tránh sai lệch dữ liệu.</li>
                            <li>Ngày vận chuyển đến có thể để trống nếu chưa xác định.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
