@{
    ViewData["Title"] = "Gán quyền cho Role";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var roleId = (int)ViewBag.RoleId;
    var roleName = ViewBag.RoleName as string ?? "";
    var currentPermissions = ViewBag.CurrentPermissions as List<int> ?? new List<int>();
    var permissionTree = ViewBag.PermissionTree as List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto> ?? new List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto>();
    var specialPermissions = ViewBag.SpecialPermissions as List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto> ?? new List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto>();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1 fw-bold text-dark">
                <i class="fas fa-shield-alt text-indigo me-2"></i>Gán quyền cho Role
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Phân quyền</a></li>
                    <li class="breadcrumb-item active">@roleName</li>
                </ol>
            </nav>
        </div>
        <span class="badge rounded-pill px-3 py-2 fs-6" style="background: #4f46e5; color: white;">
            <i class="fas fa-check-double me-1"></i>@currentPermissions.Count quyền
        </span>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fas fa-key me-2 text-indigo"></i>Role: <span class="text-dark">@roleName</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AssignPermissions" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@roleId" />

                        <div class="d-flex gap-2 mb-4">
                            <button type="button" class="btn btn-sm" id="selectAll" style="background: #4f46e5; color: white; border: none;">
                                <i class="fas fa-check-double me-1"></i>Chọn tất cả
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAll">
                                <i class="fas fa-times me-1"></i>Bỏ chọn
                            </button>
                        </div>

                        <div class="permission-tree" style="max-height: 480px; overflow-y: auto;">
                            @if (permissionTree.Any())
                            {
                                <div class="accordion accordion-flush" id="permAccordion">
                                    @for (var i = 0; i < permissionTree.Count; i++)
                                    {
                                        var parent = permissionTree[i];
                                        var childPerms = parent.Children ?? new List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto>();
                                        var leafPerms = GetLeafPermissions(parent);
                                        var checkedCount = leafPerms.Count(p => currentPermissions.Contains(p.Id));
                                        var allChecked = leafPerms.Count > 0 && checkedCount == leafPerms.Count;
                                        var groupKey = (parent.Module_name ?? parent.Permission_code).Replace(" ", "_");
                                        var collapseId = "collapse_" + i;
                                        var isNested = childPerms.Any(c => c.Children?.Any() == true);

                                        <div class="accordion-item border rounded-3 mb-2 overflow-hidden">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed py-3 px-4 bg-light border-0" type="button"
                                                        data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                                    <div class="d-flex align-items-center w-100">
                                                        <input type="checkbox" class="form-check-input me-3 module-checkbox flex-shrink-0"
                                                               id="mod_@groupKey" data-module="@(parent.Module_name ?? parent.Permission_code)"
                                                               onclick="event.stopPropagation()"
                                                               @(allChecked ? "checked" : "")>
                                                        <span class="fw-semibold text-dark flex-grow-1">
                                                            <i class="fas fa-folder text-indigo me-2"></i>@parent.Module_name
                                                        </span>
                                                        <span class="badge bg-secondary rounded-pill module-count" data-module="@(parent.Module_name ?? parent.Permission_code)">@checkedCount/@leafPerms.Count</span>
                                                    </div>
                                                </button>
                                            </h2>
                                            <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#permAccordion">
                                                <div class="accordion-body pt-0 pb-3 px-4">
                                                    @if (isNested)
                                                    {
                                                        @foreach (var sub in childPerms.Where(c => c.Children?.Any() == true))
                                                        {
                                                            <div class="mb-3">
                                                                <h6 class="text-muted small mb-2">@sub.Module_name</h6>
                                                                <div class="row g-2">
                                                                    @foreach (var p in sub.Children!)
                                                                    {
                                                                        var isChecked = currentPermissions.Contains(p.Id);
                                                                        <div class="col-md-6 col-lg-4">
                                                                            <label class="perm-item d-flex align-items-center gap-2 p-2 rounded-2 border cursor-pointer @(isChecked ? "border-indigo perm-checked" : "border-light")" onclick="event.stopPropagation()">
                                                                                <input type="checkbox" class="form-check-input flex-shrink-0 permission-checkbox"
                                                                                       name="Permission_ids" value="@p.Id" data-module="@(parent.Module_name ?? parent.Permission_code)"
                                                                                       @(isChecked ? "checked" : "")>
                                                                                <i class="fas fa-@GetActionIcon(p.Permission_code) text-muted small"></i>
                                                                                <span class="small flex-grow-1">@p.Action_name</span>
                                                                            </label>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="row g-2">
                                                            @foreach (var p in childPerms)
                                                            {
                                                                var isChecked = currentPermissions.Contains(p.Id);
                                                                <div class="col-md-6 col-lg-4">
                                                                    <label class="perm-item d-flex align-items-center gap-2 p-2 rounded-2 border cursor-pointer @(isChecked ? "border-indigo perm-checked" : "border-light")" onclick="event.stopPropagation()">
                                                                        <input type="checkbox" class="form-check-input flex-shrink-0 permission-checkbox"
                                                                               name="Permission_ids" value="@p.Id" data-module="@(parent.Module_name ?? parent.Permission_code)"
                                                                               @(isChecked ? "checked" : "")>
                                                                        <i class="fas fa-@GetActionIcon(p.Permission_code) text-muted small"></i>
                                                                        <span class="small flex-grow-1">@p.Action_name</span>
                                                                    </label>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">Chưa có quyền nào trong hệ thống</p>
                                </div>
                            }
                        </div>

                        @if (specialPermissions.Any())
                        {
                            <div class="mt-4 p-4 rounded-3 bg-amber-50 border border-amber-200">
                                <h6 class="fw-semibold text-amber-800 mb-3">
                                    <i class="fas fa-star me-2"></i>Quyền đặc thù
                                </h6>
                                <div class="row g-2">
                                    @foreach (var sp in specialPermissions)
                                    {
                                        var isChecked = currentPermissions.Contains(sp.Id);
                                        <div class="col-md-6 col-lg-4">
                                            <label class="perm-item d-flex align-items-center gap-2 p-2 rounded-2 border cursor-pointer @(isChecked ? "border-indigo perm-checked" : "border-amber-200")">
                                                <input type="checkbox" class="form-check-input flex-shrink-0 permission-checkbox"
                                                       name="Permission_ids" value="@sp.Id" data-module="SPECIAL"
                                                       @(isChecked ? "checked" : "")>
                                                <i class="fas fa-print text-amber-600 small"></i>
                                                <span class="small flex-grow-1">@(sp.Action_name ?? sp.Permission_code)</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <hr class="my-4">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại
                            </a>
                            <button type="submit" class="btn text-white" style="background: #4f46e5;">
                                <i class="fas fa-save me-1"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold text-muted mb-3">
                        <i class="fas fa-info-circle me-2"></i>Thông tin
                    </h6>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">Role</span>
                        <strong>@roleName</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">Đã gán</span>
                        <span class="badge" id="totalCount" style="background: #4f46e5;">@currentPermissions.Count</span>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-semibold text-muted mb-3">
                        <i class="fas fa-lightbulb me-2"></i>Chú thích
                    </h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="py-1"><i class="fas fa-eye text-info me-2"></i><strong>Xem</strong> – Danh sách, chi tiết</li>
                        <li class="py-1"><i class="fas fa-plus text-success me-2"></i><strong>Thêm</strong> – Thêm mới</li>
                        <li class="py-1"><i class="fas fa-edit text-warning me-2"></i><strong>Cập nhật</strong> – Sửa dữ liệu</li>
                        <li class="py-1"><i class="fas fa-trash text-danger me-2"></i><strong>Xóa</strong> – Xóa dữ liệu</li>
                        <li class="py-1"><i class="fas fa-user-tag text-primary me-2"></i><strong>Phân quyền</strong> – Gán quyền</li>
                        <li class="py-1"><i class="fas fa-star text-amber me-2"></i><strong>Đặc thù</strong> – In theo năm, v.v.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .perm-item { transition: all 0.2s; cursor: pointer; }
    .perm-item:hover { background: rgba(79, 70, 229, 0.06) !important; }
    .perm-checked { background: rgba(79, 70, 229, 0.08) !important; }
    .text-indigo { color: #4f46e5; }
    .accordion-button:not(.collapsed) { box-shadow: none; }
    .accordion-button:focus { box-shadow: none; }
    .accordion-item { border-radius: 12px !important; }
</style>

@functions {
    List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto> GetLeafPermissions(ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto node)
    {
        var list = new List<ErpOnlineOrder.Application.DTOs.PermissionDTOs.PermissionDto>();
        if (node.Children == null || !node.Children.Any()) return list;
        foreach (var c in node.Children)
        {
            if (c.Children?.Any() == true)
                list.AddRange(GetLeafPermissions(c));
            else if (c.Id != 0)
                list.Add(c);
        }
        return list;
    }
    string GetActionIcon(string code)
    {
        var action = code.Contains("_") ? code.Substring(code.LastIndexOf('_') + 1).ToUpper() : code;
        return action switch
        {
            "VIEW" => "eye", "CREATE" => "plus", "UPDATE" => "edit", "DELETE" => "trash",
            "EXPORT" => "file-export", "IMPORT" => "file-import", "APPROVE" => "check-circle",
            "REJECT" => "times-circle", "ASSIGN" => "user-tag",
            "PRINT" or "2023" or "2025" => "print", _ => "key"
        };
    }
}

@section Scripts {
<script>
(function() {
    var selectAll = document.getElementById('selectAll');
    var deselectAll = document.getElementById('deselectAll');
    if (selectAll) selectAll.onclick = function() {
        document.querySelectorAll('.permission-checkbox, .module-checkbox').forEach(function(c) { c.checked = true; });
        updateCounts();
    };
    if (deselectAll) deselectAll.onclick = function() {
        document.querySelectorAll('.permission-checkbox, .module-checkbox').forEach(function(c) { c.checked = false; });
        updateCounts();
    };

    document.querySelectorAll('.module-checkbox').forEach(function(m) {
        m.onclick = function(e) { e.stopPropagation(); };
        m.addEventListener('change', function() {
            var mod = this.dataset.module;
            document.querySelectorAll('.permission-checkbox[data-module="' + mod + '"]').forEach(function(p) {
                p.checked = this.checked;
            }.bind(this));
            updateCounts();
        });
    });

    document.querySelectorAll('.permission-checkbox').forEach(function(p) {
        p.addEventListener('change', function() {
            var mod = this.dataset.module;
            if (mod !== 'SPECIAL') {
                var all = document.querySelectorAll('.permission-checkbox[data-module="' + mod + '"]');
                var checked = document.querySelectorAll('.permission-checkbox[data-module="' + mod + '"]:checked');
                var mcb = document.querySelector('.module-checkbox[data-module="' + mod + '"]');
                if (mcb) {
                    mcb.checked = all.length === checked.length;
                    mcb.indeterminate = checked.length > 0 && checked.length < all.length;
                }
            }
            updateCounts();
        });
    });

    function updateCounts() {
        var total = document.querySelectorAll('.permission-checkbox:checked').length;
        var el = document.getElementById('totalCount');
        if (el) el.textContent = total;
        document.querySelectorAll('.module-count').forEach(function(b) {
            var mod = b.dataset.module;
            if (mod) {
                var checked = document.querySelectorAll('.permission-checkbox[data-module="' + mod + '"]:checked').length;
                var all = document.querySelectorAll('.permission-checkbox[data-module="' + mod + '"]').length;
                b.textContent = checked + '/' + all;
            }
        });
    }
})();
</script>
}
